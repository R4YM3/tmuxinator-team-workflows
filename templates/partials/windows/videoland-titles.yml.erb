<%
editor_cmd = overrides["editor_cmd"] if overrides.is_a?(Hash)
editor_cmd = nil unless editor_cmd.is_a?(String) && !editor_cmd.strip.empty?
%>

  - titles:
      root: <%= folder %>
      layout: main-vertical
      panes:
<% if editor_cmd %>
        - editor: '<%= editor_cmd %>'
<% end %>
        - server: 'ASPNETCORE_ENVIRONMENT=Development dotnet run --project src/Rtl.VideolandTitles.Api'
