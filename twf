#!/usr/bin/env bash
set -euo pipefail

SCRIPT_PATH="${BASH_SOURCE[0]}"
while [[ -L "$SCRIPT_PATH" ]]; do
  SCRIPT_DIR="$(cd -P "$(dirname "$SCRIPT_PATH")" && pwd)"
  SCRIPT_PATH="$(readlink "$SCRIPT_PATH")"
  [[ "$SCRIPT_PATH" == /* ]] || SCRIPT_PATH="$SCRIPT_DIR/$SCRIPT_PATH"
done

RUNTIME_DIR="$(cd -P "$(dirname "$SCRIPT_PATH")" && pwd)"
DEFAULT_TWF_HOME="${HOME}/.local/share/twf"
DEFAULT_TWF_BIN_DIR="${HOME}/.local/bin"
TMUXINATOR_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/tmuxinator"
PLUGINS_DIR="$RUNTIME_DIR/plugins"
PLUGIN_STATE_ROOT="${XDG_DATA_HOME:-$HOME/.local/share}/twf/state/plugins"

ok() { printf "\033[1;32m[ok]\033[0m %s\n" "$1"; }
info() { printf "\033[1;34m[info]\033[0m %s\n" "$1"; }
warn() { printf "\033[1;33m[warn]\033[0m %s\n" "$1"; }
error() { printf "\033[1;31m[error]\033[0m %s\n" "$1" >&2; }

usage() {
  cat <<'EOF'
Usage: twf <command> [options]

Commands:
  add <project-name> [--dry-run] [--with-demo]
                               Create workflow repo (if empty) or add a project
  remove <project-name> [--yes]
                               Remove tmuxinator alias; optionally remove local files
  plugin <command> [...]       Manage project plugins
  validate                     Validate templates in current workflow repo
  doctor                       Run environment and template diagnostics
  update                       Pull latest twf runtime repo
  list                         List local templates and installed tmuxinator aliases
  start <project> [args...]    Run tmuxinator start <project>
  uninstall [--yes]            Remove global twf CLI installation
  version                      Print twf version
  help                         Show this help

Examples:
  twf add landing-site
  twf add landing-site --dry-run
  twf add landing-site --with-demo
  twf remove landing-site
  twf plugin add node --project landing-site
  twf plugin install --project landing-site
  twf validate
  twf doctor
  twf update
  twf start landing-site
EOF
}

version() {
  if command -v git >/dev/null 2>&1 && git -C "$RUNTIME_DIR" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    git -C "$RUNTIME_DIR" describe --tags --always --dirty 2>/dev/null || true
    return 0
  fi

  echo "0.1.0"
}

validate_project_name() {
  local project_name="$1"
  if [[ ! "$project_name" =~ ^[a-z0-9][a-z0-9-]*$ ]]; then
    error "Invalid project name: '$project_name'"
    info "Use lowercase letters, numbers, and dashes only (must start with letter or number)."
    exit 1
  fi
}

is_workflow_repo() {
  local dir="$1"
  [[ -d "$dir/templates/projects" && -d "$dir/developer/projects" ]]
}

detect_workflow_repo() {
  if is_workflow_repo "$PWD"; then
    echo "$PWD"
  else
    echo ""
  fi
}

require_workflow_repo() {
  local repo
  repo="$(detect_workflow_repo)"
  if [[ -z "$repo" ]]; then
    error "No workflow repository detected in current directory"
    info "Run this inside a workflow repo (contains templates/projects and developer/projects)."
    info "To create one: twf add <project-name>"
    exit 1
  fi
  echo "$repo"
}

plugin_script_path() {
  local plugin_name="$1"
  echo "$PLUGINS_DIR/$plugin_name.sh"
}

plugin_exists() {
  local plugin_name="$1"
  [[ -f "$(plugin_script_path "$plugin_name")" ]]
}

require_plugin() {
  local plugin_name="$1"
  if ! plugin_exists "$plugin_name"; then
    error "Unknown plugin: $plugin_name"
    info "Run 'twf plugin list' to see available plugins."
    exit 1
  fi
}

list_available_plugins() {
  if [[ ! -d "$PLUGINS_DIR" ]]; then
    return 0
  fi

  local files=()
  local file
  shopt -s nullglob
  files=("$PLUGINS_DIR"/*.sh)
  shopt -u nullglob

  for file in "${files[@]}"; do
    basename "${file%.sh}"
  done
}

hash_text() {
  local value="$1"
  if command -v shasum >/dev/null 2>&1; then
    printf '%s' "$value" | shasum -a 256 | awk '{print $1}'
  elif command -v openssl >/dev/null 2>&1; then
    printf '%s' "$value" | openssl dgst -sha256 | awk '{print $NF}'
  else
    printf '%s' "$value" | cksum | awk '{print $1}'
  fi
}

project_template_file() {
  local repo="$1"
  local project_name="$2"
  echo "$repo/templates/projects/$project_name.yml"
}

project_override_file() {
  local repo="$1"
  local project_name="$2"
  echo "$repo/developer/projects/$project_name.override.yml"
}

ensure_project_exists() {
  local repo="$1"
  local project_name="$2"
  local template_file
  template_file="$(project_template_file "$repo" "$project_name")"

  if [[ ! -f "$template_file" ]]; then
    error "Project template not found: $template_file"
    info "Add the project first: twf add $project_name"
    exit 1
  fi
}

enabled_plugins_for_project() {
  local repo="$1"
  local project_name="$2"
  local override_file
  override_file="$(project_override_file "$repo" "$project_name")"

  ruby -ryaml -e '
path = ARGV[0]
if !File.exist?(path)
  exit 0
end
raw = YAML.safe_load(File.read(path), aliases: false)
data = raw.is_a?(Hash) ? raw : {}
plugins = data["plugins"].is_a?(Hash) ? data["plugins"] : {}
enabled = plugins["enabled"].is_a?(Array) ? plugins["enabled"] : []
enabled.select { |v| v.is_a?(String) && !v.strip.empty? }.each { |v| puts v }
' "$override_file"
}

plugin_config_json_for_project() {
  local repo="$1"
  local project_name="$2"
  local plugin_name="$3"
  local override_file
  override_file="$(project_override_file "$repo" "$project_name")"

  ruby -ryaml -rjson -e '
path = ARGV[0]
plugin = ARGV[1]
if !File.exist?(path)
  puts "{}"
  exit 0
end
raw = YAML.safe_load(File.read(path), aliases: false)
data = raw.is_a?(Hash) ? raw : {}
plugins = data["plugins"].is_a?(Hash) ? data["plugins"] : {}
config = plugins["config"].is_a?(Hash) ? plugins["config"] : {}
value = config[plugin]
value = {} unless value.is_a?(Hash)
puts JSON.generate(value)
' "$override_file" "$plugin_name"
}

add_plugin_to_project_config() {
  local repo="$1"
  local project_name="$2"
  local plugin_name="$3"
  local override_file
  override_file="$(project_override_file "$repo" "$project_name")"

  mkdir -p "$(dirname "$override_file")"
  [[ -f "$override_file" ]] || printf '{}\n' >"$override_file"

  ruby -ryaml -e '
path = ARGV[0]
plugin = ARGV[1]
raw = YAML.safe_load(File.read(path), aliases: false)
data = raw.is_a?(Hash) ? raw : {}
data["plugins"] = {} unless data["plugins"].is_a?(Hash)
plugins = data["plugins"]
plugins["enabled"] = [] unless plugins["enabled"].is_a?(Array)
enabled = plugins["enabled"].select { |v| v.is_a?(String) && !v.strip.empty? }
enabled << plugin unless enabled.include?(plugin)
plugins["enabled"] = enabled
File.write(path, data.to_yaml(line_width: -1))
' "$override_file" "$plugin_name"
}

remove_plugin_from_project_config() {
  local repo="$1"
  local project_name="$2"
  local plugin_name="$3"
  local override_file
  override_file="$(project_override_file "$repo" "$project_name")"

  if [[ ! -f "$override_file" ]]; then
    return 0
  fi

  ruby -ryaml -e '
path = ARGV[0]
plugin = ARGV[1]
raw = YAML.safe_load(File.read(path), aliases: false)
data = raw.is_a?(Hash) ? raw : {}
plugins = data["plugins"].is_a?(Hash) ? data["plugins"] : nil
if plugins
  if plugins["enabled"].is_a?(Array)
    plugins["enabled"] = plugins["enabled"].select { |v| v.is_a?(String) && v != plugin }
  end
  if plugins["config"].is_a?(Hash)
    plugins["config"].delete(plugin)
  end
  plugins.delete("enabled") if plugins["enabled"].is_a?(Array) && plugins["enabled"].empty?
  plugins.delete("config") if plugins["config"].is_a?(Hash) && plugins["config"].empty?
  data.delete("plugins") if plugins.empty?
end
File.write(path, data.to_yaml(line_width: -1))
' "$override_file" "$plugin_name"
}

plugin_state_file() {
  local project_name="$1"
  local plugin_name="$2"
  echo "$PLUGIN_STATE_ROOT/$project_name/$plugin_name.state"
}

plugin_version() {
  local plugin_name="$1"
  local plugin_script
  plugin_script="$(plugin_script_path "$plugin_name")"
  bash "$plugin_script" version
}

plugin_state_matches() {
  local project_name="$1"
  local plugin_name="$2"
  local expected_version="$3"
  local expected_hash="$4"
  local state_file
  state_file="$(plugin_state_file "$project_name" "$plugin_name")"

  [[ -f "$state_file" ]] || return 1

  local saved_version=""
  local saved_hash=""
  while IFS='=' read -r key value; do
    case "$key" in
    VERSION) saved_version="$value" ;;
    CONFIG_HASH) saved_hash="$value" ;;
    esac
  done <"$state_file"

  [[ "$saved_version" == "$expected_version" && "$saved_hash" == "$expected_hash" ]]
}

write_plugin_state() {
  local project_name="$1"
  local plugin_name="$2"
  local version="$3"
  local config_hash="$4"
  local state_file
  state_file="$(plugin_state_file "$project_name" "$plugin_name")"

  mkdir -p "$(dirname "$state_file")"
  cat >"$state_file" <<EOF
VERSION=$version
CONFIG_HASH=$config_hash
UPDATED_AT=$(date -u +%Y-%m-%dT%H:%M:%SZ)
EOF
}

ensure_bin_on_path() {
  local bin_dir="$1"
  case ":$PATH:" in
  *":$bin_dir:"*)
    ok "$bin_dir is on PATH"
    ;;
  *)
    warn "$bin_dir is not on PATH"
    info "Add this line to your shell rc file:"
    printf '  export PATH="%s:$PATH"\n' "$bin_dir"
    ;;
  esac
}

confirm_remove() {
  local prompt="$1"
  local response=""
  read -r -p "$prompt [y/N]: " response
  [[ "${response:-N}" =~ ^[Yy]$ ]]
}

is_directory_empty() {
  local dir="$1"
  local entries=()
  shopt -s nullglob dotglob
  entries=("$dir"/*)
  shopt -u nullglob dotglob
  [[ ${#entries[@]} -eq 0 ]]
}

render_project_template() {
  local project_name="$1"
  local with_demo="$2"

  if [[ "$with_demo" == true ]]; then
    local template_src="$RUNTIME_DIR/templates/projects/example-includes.yml"

    [[ -f "$template_src" ]] || {
      error "Missing source template: $template_src"
      exit 1
    }

    sed \
      -e "s/^name: .*/name: $project_name/" \
      -e "s|^root: .*|root: .|" \
      -e "s|load_project_override(\"example-includes\")|load_project_override(\"$project_name\")|" \
      "$template_src"
    return 0
  fi

  cat <<EOF
name: $project_name
root: .

startup_window: app

<%
Kernel.load ENV.fetch("TEAM_WORKFLOWS_HELPER_FILE")
override_data = load_project_override("$project_name")
%>

windows:
<%= include_window("example-app", folder: ".", overrides: partial_override(override_data, "example-app")) %>

<%= render_extra_windows(override_data) %>
EOF
}

scaffold_workflow_repo() {
  local repo="$1"

  mkdir -p "$repo/templates/projects"
  mkdir -p "$repo/templates/partials/pre_window"
  mkdir -p "$repo/templates/partials/on_project_start"
  mkdir -p "$repo/templates/partials/windows"
  mkdir -p "$repo/developer/projects"

  cp "$RUNTIME_DIR/.gitignore" "$repo/.gitignore"
  cp "$RUNTIME_DIR/developer/.gitkeep" "$repo/developer/.gitkeep"
  cp "$RUNTIME_DIR/developer/projects/.gitkeep" "$repo/developer/projects/.gitkeep"

  cp "$RUNTIME_DIR/templates/partials/pre_window/node-nvm-use.sh.erb" "$repo/templates/partials/pre_window/node-nvm-use.sh.erb"
  cp "$RUNTIME_DIR/templates/partials/on_project_start/node-bootstrap.sh.erb" "$repo/templates/partials/on_project_start/node-bootstrap.sh.erb"
  cp "$RUNTIME_DIR/templates/partials/windows/example-app.yml.erb" "$repo/templates/partials/windows/example-app.yml.erb"
}

write_repo_readme() {
  local repo="$1"
  local first_project="$2"

  cat >"$repo/README.md" <<EOF
# Team workflow repository

This repository is managed with \`twf\` and is intended to live outside application repositories.

- Shared workflow templates: \`templates/projects/\`
- Reusable partials: \`templates/partials/\`
- Personal overrides: \`developer/projects/\`

Typical flow:

\`\`\`bash
twf plugin install --project $first_project
twf validate
twf doctor
twf start $first_project
\`\`\`

You can add more projects later from this same repo:

\`\`\`bash
twf add another-project
\`\`\`
EOF
}

resolve_alias_conflict() {
  local repo="$1"
  local project_name="$2"
  local dry_run="$3"

  local name="$project_name"

  while :; do
    local project_file="$repo/templates/projects/$name.yml"
    local override_file="$repo/developer/projects/$name.override.yml"
    local tmuxinator_file="$TMUXINATOR_DIR/$name.yml"

    if [[ -e "$project_file" || -e "$override_file" ]]; then
      error "Project files already exist for '$name' in this workflow repo"
      info "Choose a different project name."
      exit 1
    fi

    if [[ ! -e "$tmuxinator_file" ]]; then
      printf '%s|%s\n' "$name" "create"
      return 0
    fi

    if [[ -L "$tmuxinator_file" ]]; then
      local target=""
      target="$(readlink "$tmuxinator_file")"
      if [[ "$target" == "$project_file" ]]; then
        printf '%s|%s\n' "$name" "same"
        return 0
      fi
    elif [[ ! -f "$tmuxinator_file" ]]; then
      error "Refusing to manage non-file alias path: $tmuxinator_file"
      exit 1
    fi

    echo
    warn "tmuxinator alias already exists: $tmuxinator_file"
    if [[ -L "$tmuxinator_file" ]]; then
      info "Current alias target: $(readlink "$tmuxinator_file")"
    fi
    echo "Choose one:"
    echo "  [r] rename project"
    echo "  [p] replace alias"
    local choice=""
    read -r -p "Your choice [r/p]: " choice

    case "${choice:-}" in
    r | R)
      local renamed=""
      read -r -p "Enter new project name: " renamed
      if [[ -z "$renamed" ]]; then
        error "Project name cannot be empty"
        continue
      fi
      validate_project_name "$renamed"
      name="$renamed"
      ;;
    p | P)
      if [[ "$dry_run" == true ]]; then
        printf '%s|%s\n' "$name" "replace"
        return 0
      fi
      if confirm_remove "Replace existing alias '$tmuxinator_file'?"; then
        printf '%s|%s\n' "$name" "replace"
        return 0
      fi
      error "Alias replacement cancelled"
      exit 1
      ;;
    *)
      error "Invalid choice"
      ;;
    esac
  done
}

link_project_alias() {
  local repo="$1"
  local project_name="$2"
  local mode="$3"

  local source_file="$repo/templates/projects/$project_name.yml"
  local tmuxinator_file="$TMUXINATOR_DIR/$project_name.yml"

  mkdir -p "$TMUXINATOR_DIR"

  case "$mode" in
  create)
    ln -s "$source_file" "$tmuxinator_file"
    ok "Created tmuxinator alias: $tmuxinator_file -> $source_file"
    ;;
  replace)
    rm -f "$tmuxinator_file"
    ln -s "$source_file" "$tmuxinator_file"
    ok "Replaced tmuxinator alias: $tmuxinator_file -> $source_file"
    ;;
  same)
    ok "tmuxinator alias already points to project file: $tmuxinator_file"
    ;;
  *)
    error "Unknown alias mode: $mode"
    exit 1
    ;;
  esac
}

cmd_add() {
  local dry_run=false
  local with_demo=false
  local project_name=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
    --dry-run)
      dry_run=true
      shift
      ;;
    --with-demo)
      with_demo=true
      shift
      ;;
    -h | --help)
      cat <<'EOF'
Usage: twf add <project-name> [--dry-run] [--with-demo]

- In an empty directory: creates a workflow repository and adds the project.
- In an existing workflow repo: adds another project.
EOF
      return 0
      ;;
    *)
      if [[ -z "$project_name" ]]; then
        project_name="$1"
        shift
      else
        error "Unexpected argument: $1"
        exit 1
      fi
      ;;
    esac
  done

  if [[ -z "$project_name" ]]; then
    error "Missing required project name"
    info "Usage: twf add <project-name> [--dry-run]"
    exit 1
  fi

  validate_project_name "$project_name"

  local workflow_repo=""
  local scaffold_repo=false

  workflow_repo="$(detect_workflow_repo)"
  if [[ -z "$workflow_repo" ]]; then
    if is_directory_empty "$PWD"; then
      workflow_repo="$PWD"
      scaffold_repo=true
      info "Empty directory detected; creating a new workflow repository"
    else
      error "Current directory is not an empty directory or workflow repo"
      info "Use an empty directory to create a workflow repo, or run inside an existing workflow repo."
      exit 1
    fi
  fi

  local resolution
  resolution="$(resolve_alias_conflict "$workflow_repo" "$project_name" "$dry_run")"
  local final_name="${resolution%%|*}"
  local alias_mode="${resolution#*|}"

  local project_file="$workflow_repo/templates/projects/$final_name.yml"
  local override_file="$workflow_repo/developer/projects/$final_name.override.yml"
  local override_src="$RUNTIME_DIR/developer/projects/example-includes.override.yml"

  if [[ "$with_demo" == true ]]; then
    [[ -f "$override_src" ]] || {
      error "Missing source override template: $override_src"
      exit 1
    }
  fi

  if [[ "$dry_run" == true ]]; then
    info "Dry run: no files were written"
    if [[ "$scaffold_repo" == true ]]; then
      echo "Would create workflow repo scaffold in: $workflow_repo"
      echo "  README.md"
      echo "  .gitignore"
      echo "  templates/partials/pre_window/node-nvm-use.sh.erb"
      echo "  templates/partials/on_project_start/node-bootstrap.sh.erb"
      echo "  templates/partials/windows/example-app.yml.erb"
      echo "  developer/.gitkeep"
      echo "  developer/projects/.gitkeep"
    fi
    echo "Would create project files:"
    echo "  $project_file"
    echo "  $override_file"
    if [[ "$with_demo" == true ]]; then
      echo "Mode: with demo project content"
    else
      echo "Mode: minimal project content"
    fi

    case "$alias_mode" in
    create)
      echo "Would create tmuxinator alias: $TMUXINATOR_DIR/$final_name.yml"
      ;;
    replace)
      echo "Would replace tmuxinator alias: $TMUXINATOR_DIR/$final_name.yml"
      ;;
    same)
      echo "tmuxinator alias already points to this project"
      ;;
    esac
    return 0
  fi

  if [[ "$scaffold_repo" == true ]]; then
    scaffold_workflow_repo "$workflow_repo"
    write_repo_readme "$workflow_repo" "$final_name"
    ok "Created workflow repository scaffold"
  fi

  render_project_template "$final_name" "$with_demo" >"$project_file"

  if [[ "$with_demo" == true ]]; then
    cp "$override_src" "$override_file"
  else
    cat >"$override_file" <<'EOF'
partials:
  example-app:
    editor_cmd: "nvim"
EOF
  fi

  link_project_alias "$workflow_repo" "$final_name" "$alias_mode"

  ok "Created workflow template: $project_file"
  ok "Created developer override: $override_file"
  info "Next steps:"
  echo "  twf validate"
  echo "  twf doctor"
  echo "  twf start $final_name"
}

cmd_remove() {
  local assume_yes=false
  local project_name=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
    --yes)
      assume_yes=true
      shift
      ;;
    -h | --help)
      cat <<'EOF'
Usage: twf remove <project-name> [--yes]

Removes the tmuxinator alias for a project, then optionally removes
local override/template files when running inside a workflow repo.
EOF
      return 0
      ;;
    *)
      if [[ -z "$project_name" ]]; then
        project_name="$1"
        shift
      else
        error "Unexpected argument: $1"
        exit 1
      fi
      ;;
    esac
  done

  if [[ -z "$project_name" ]]; then
    error "Missing project name"
    info "Usage: twf remove <project-name> [--yes]"
    exit 1
  fi

  validate_project_name "$project_name"

  local tmuxinator_file="$TMUXINATOR_DIR/$project_name.yml"
  if [[ ! -e "$tmuxinator_file" ]]; then
    error "Project alias not found: $tmuxinator_file"
    info "Nothing removed."
    exit 1
  fi

  if [[ -L "$tmuxinator_file" || -f "$tmuxinator_file" ]]; then
    rm -f "$tmuxinator_file"
    ok "Removed tmuxinator alias: $tmuxinator_file"
  else
    error "Refusing to remove non-file path: $tmuxinator_file"
    exit 1
  fi

  local repo
  repo="$(detect_workflow_repo)"
  if [[ -z "$repo" ]]; then
    info "No local workflow repository detected; skipped optional file cleanup."
    return 0
  fi

  local override_file="$repo/developer/projects/$project_name.override.yml"
  local template_file="$repo/templates/projects/$project_name.yml"

  if [[ -f "$override_file" ]]; then
    if [[ "$assume_yes" == true ]] || confirm_remove "Remove override file '$override_file'?"; then
      rm -f "$override_file"
      ok "Removed override file: $override_file"
    else
      info "Kept override file: $override_file"
    fi
  else
    info "No override file found at: $override_file"
  fi

  if [[ -f "$template_file" ]]; then
    if [[ "$assume_yes" == true ]] || confirm_remove "Remove template file '$template_file'?"; then
      rm -f "$template_file"
      ok "Removed template file: $template_file"
    else
      info "Kept template file: $template_file"
    fi
  else
    info "No template file found at: $template_file"
  fi
}

load_enabled_plugins_for_project() {
  local repo="$1"
  local project_name="$2"
  local plugin=""

  LOADED_PROJECT_PLUGINS=()
  while IFS= read -r plugin; do
    [[ -n "$plugin" ]] || continue
    LOADED_PROJECT_PLUGINS+=("$plugin")
  done < <(enabled_plugins_for_project "$repo" "$project_name")
}

build_plugin_state_context() {
  local repo="$1"
  local project_name="$2"
  local plugin_name="$3"

  PLUGIN_CTX_SCRIPT="$(plugin_script_path "$plugin_name")"
  PLUGIN_CTX_VERSION="$(plugin_version "$plugin_name")"
  PLUGIN_CTX_CONFIG_JSON="$(plugin_config_json_for_project "$repo" "$project_name" "$plugin_name")"
  PLUGIN_CTX_CONFIG_HASH="$(hash_text "$PLUGIN_CTX_CONFIG_JSON")"
}

run_plugin_install_for_project() {
  local repo="$1"
  local project_name="$2"
  local assume_yes="$3"
  local plugin=""

  ensure_project_exists "$repo" "$project_name"
  load_enabled_plugins_for_project "$repo" "$project_name"

  if [[ ${#LOADED_PROJECT_PLUGINS[@]} -eq 0 ]]; then
    info "No plugins configured for project '$project_name'."
    return 0
  fi

  for plugin in "${LOADED_PROJECT_PLUGINS[@]}"; do
    require_plugin "$plugin"
    build_plugin_state_context "$repo" "$project_name" "$plugin"

    if plugin_state_matches "$project_name" "$plugin" "$PLUGIN_CTX_VERSION" "$PLUGIN_CTX_CONFIG_HASH"; then
      ok "Plugin '$plugin' is already installed for project '$project_name'"
      continue
    fi

    info "Installing plugin '$plugin' for project '$project_name'"
    if ! TWF_PLUGIN_CONFIG_JSON="$PLUGIN_CTX_CONFIG_JSON" TWF_PLUGIN_ASSUME_YES="$assume_yes" bash "$PLUGIN_CTX_SCRIPT" install; then
      error "Plugin install failed: $plugin"
      exit 1
    fi

    if ! TWF_PLUGIN_CONFIG_JSON="$PLUGIN_CTX_CONFIG_JSON" bash "$PLUGIN_CTX_SCRIPT" check; then
      error "Plugin check failed after install: $plugin"
      exit 1
    fi

    write_plugin_state "$project_name" "$plugin" "$PLUGIN_CTX_VERSION" "$PLUGIN_CTX_CONFIG_HASH"
    ok "Plugin ready: $plugin"
  done
}

check_plugins_ready_for_project() {
  local repo="$1"
  local project_name="$2"
  local plugin=""

  ensure_project_exists "$repo" "$project_name"
  load_enabled_plugins_for_project "$repo" "$project_name"

  if [[ ${#LOADED_PROJECT_PLUGINS[@]} -eq 0 ]]; then
    return 0
  fi

  for plugin in "${LOADED_PROJECT_PLUGINS[@]}"; do
    require_plugin "$plugin"
    build_plugin_state_context "$repo" "$project_name" "$plugin"

    if ! plugin_state_matches "$project_name" "$plugin" "$PLUGIN_CTX_VERSION" "$PLUGIN_CTX_CONFIG_HASH"; then
      error "Plugin '$plugin' is not installed or is out of date for project '$project_name'"
      info "Run: twf plugin install --project $project_name"
      exit 1
    fi
  done
}

parse_plugin_project_args() {
  local usage="$1"
  shift

  PARSED_PLUGIN_NAME=""
  PARSED_PROJECT_NAME=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
    --project)
      [[ $# -ge 2 ]] || {
        error "--project requires a project name"
        exit 1
      }
      PARSED_PROJECT_NAME="$2"
      shift 2
      ;;
    *)
      if [[ -z "$PARSED_PLUGIN_NAME" ]]; then
        PARSED_PLUGIN_NAME="$1"
        shift
      else
        error "Unexpected argument: $1"
        exit 1
      fi
      ;;
    esac
  done

  [[ -n "$PARSED_PLUGIN_NAME" ]] || {
    error "Missing plugin name"
    info "$usage"
    exit 1
  }
  [[ -n "$PARSED_PROJECT_NAME" ]] || {
    error "Missing --project"
    info "$usage"
    exit 1
  }
}

parse_plugin_scope_args() {
  local usage="$1"
  local allow_yes="$2"
  shift 2

  PARSED_PROJECT_NAME=""
  PARSED_GLOBAL=false
  PARSED_ASSUME_YES=false

  while [[ $# -gt 0 ]]; do
    case "$1" in
    --project)
      [[ $# -ge 2 ]] || {
        error "--project requires a project name"
        exit 1
      }
      PARSED_PROJECT_NAME="$2"
      shift 2
      ;;
    --global)
      PARSED_GLOBAL=true
      shift
      ;;
    --yes)
      if [[ "$allow_yes" == true ]]; then
        PARSED_ASSUME_YES=true
        shift
      else
        error "Unexpected argument: --yes"
        exit 1
      fi
      ;;
    *)
      error "Unexpected argument: $1"
      info "$usage"
      exit 1
      ;;
    esac
  done

  if [[ -n "$PARSED_PROJECT_NAME" && "$PARSED_GLOBAL" == true ]]; then
    error "Use either --project or --global, not both"
    exit 1
  fi
}

cmd_plugin_add() {
  parse_plugin_project_args "Usage: twf plugin add <plugin> --project <project>" "$@"
  validate_project_name "$PARSED_PROJECT_NAME"
  require_plugin "$PARSED_PLUGIN_NAME"

  local repo
  repo="$(require_workflow_repo)"
  ensure_project_exists "$repo" "$PARSED_PROJECT_NAME"

  add_plugin_to_project_config "$repo" "$PARSED_PROJECT_NAME" "$PARSED_PLUGIN_NAME"
  ok "Added plugin '$PARSED_PLUGIN_NAME' to project '$PARSED_PROJECT_NAME'"
  info "Run: twf plugin install --project $PARSED_PROJECT_NAME"
}

cmd_plugin_remove() {
  parse_plugin_project_args "Usage: twf plugin remove <plugin> --project <project>" "$@"
  validate_project_name "$PARSED_PROJECT_NAME"

  local repo
  repo="$(require_workflow_repo)"
  ensure_project_exists "$repo" "$PARSED_PROJECT_NAME"

  remove_plugin_from_project_config "$repo" "$PARSED_PROJECT_NAME" "$PARSED_PLUGIN_NAME"
  ok "Removed plugin '$PARSED_PLUGIN_NAME' from project '$PARSED_PROJECT_NAME'"
}

cmd_plugin_list() {
  parse_plugin_scope_args "Usage: twf plugin list [--project <project> | --global]" false "$@"

  echo "Available plugins:"
  local available=()
  local p=""
  while IFS= read -r p; do
    [[ -n "$p" ]] || continue
    available+=("$p")
    echo "  - $p"
  done < <(list_available_plugins)
  if [[ ${#available[@]} -eq 0 ]]; then
    echo "  (none)"
  fi

  if [[ -z "$PARSED_PROJECT_NAME" && "$PARSED_GLOBAL" != true ]]; then
    return 0
  fi

  local repo
  repo="$(require_workflow_repo)"

  if [[ -n "$PARSED_PROJECT_NAME" ]]; then
    validate_project_name "$PARSED_PROJECT_NAME"
    ensure_project_exists "$repo" "$PARSED_PROJECT_NAME"
    echo
    echo "Configured plugins for '$PARSED_PROJECT_NAME':"
    local any=false
    while IFS= read -r p; do
      [[ -n "$p" ]] || continue
      any=true
      echo "  - $p"
    done < <(enabled_plugins_for_project "$repo" "$PARSED_PROJECT_NAME")
    [[ "$any" == true ]] || echo "  (none)"
    return 0
  fi

  echo
  echo "Configured plugins by project:"
  local files=()
  local f=""
  shopt -s nullglob
  files=("$repo/templates/projects"/*.yml)
  shopt -u nullglob
  for f in "${files[@]}"; do
    local proj
    proj="$(basename "${f%.yml}")"
    echo "- $proj"
    local any=false
    while IFS= read -r p; do
      [[ -n "$p" ]] || continue
      any=true
      echo "    - $p"
    done < <(enabled_plugins_for_project "$repo" "$proj")
    [[ "$any" == true ]] || echo "    (none)"
  done
}

cmd_plugin_install() {
  parse_plugin_scope_args "Usage: twf plugin install --project <project> [--yes] | --global [--yes]" true "$@"

  if [[ -z "$PARSED_PROJECT_NAME" && "$PARSED_GLOBAL" != true ]]; then
    error "Missing scope: use --project <name> or --global"
    exit 1
  fi

  local repo
  repo="$(require_workflow_repo)"

  if [[ -n "$PARSED_PROJECT_NAME" ]]; then
    validate_project_name "$PARSED_PROJECT_NAME"
    run_plugin_install_for_project "$repo" "$PARSED_PROJECT_NAME" "$PARSED_ASSUME_YES"
    return 0
  fi

  local files=()
  local f=""
  shopt -s nullglob
  files=("$repo/templates/projects"/*.yml)
  shopt -u nullglob
  for f in "${files[@]}"; do
    local proj
    proj="$(basename "${f%.yml}")"
    run_plugin_install_for_project "$repo" "$proj" "$PARSED_ASSUME_YES"
  done
}

cmd_plugin_help() {
  cat <<'EOF'
Usage: twf plugin <command> [options]

Commands:
  add <plugin> --project <project>
  remove <plugin> --project <project>
  list [--project <project> | --global]
  install --project <project> [--yes]
  install --global [--yes]
EOF
}

cmd_plugin() {
  local subcommand="${1:-}"
  shift || true

  case "$subcommand" in
  add)
    cmd_plugin_add "$@"
    ;;
  remove)
    cmd_plugin_remove "$@"
    ;;
  list)
    cmd_plugin_list "$@"
    ;;
  install)
    cmd_plugin_install "$@"
    ;;
  help | -h | --help | "")
    cmd_plugin_help
    ;;
  *)
    error "Unknown plugin subcommand: $subcommand"
    info "Run: twf plugin --help"
    exit 1
    ;;
  esac
}

cmd_validate() {
  local workflow_repo
  workflow_repo="$(require_workflow_repo)"
  TWF_WORKFLOW_REPO="$workflow_repo" bash "$RUNTIME_DIR/scripts/validate-workflows.sh"
}

cmd_doctor() {
  local workflow_repo
  workflow_repo="$(require_workflow_repo)"
  TWF_WORKFLOW_REPO="$workflow_repo" bash "$RUNTIME_DIR/scripts/doctor.sh"
}

cmd_update() {
  if ! command -v git >/dev/null 2>&1; then
    error "git is required for twf update"
    exit 1
  fi

  if ! git -C "$RUNTIME_DIR" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    error "twf update requires a git checkout at: $RUNTIME_DIR"
    exit 1
  fi

  info "Updating twf runtime repo at $RUNTIME_DIR"
  git -C "$RUNTIME_DIR" pull --ff-only

  local bin_dir="${TWF_BIN_DIR:-$DEFAULT_TWF_BIN_DIR}"
  mkdir -p "$bin_dir"
  ln -sfn "$RUNTIME_DIR/twf" "$bin_dir/twf"
  ok "Refreshed CLI symlink: $bin_dir/twf"
  ensure_bin_on_path "$bin_dir"
  ok "Update complete"
}

cmd_list() {
  local repo
  repo="$(detect_workflow_repo)"

  if [[ -n "$repo" ]]; then
    echo "Template workflows ($repo/templates/projects):"
    local files=()
    local file
    shopt -s nullglob
    files=("$repo/templates/projects"/*.yml)
    shopt -u nullglob

    if [[ ${#files[@]} -eq 0 ]]; then
      echo "  (none)"
    else
      for file in "${files[@]}"; do
        echo "  - $(basename "${file%.yml}")"
      done
    fi
    echo
  else
    info "No local workflow repo detected in current directory."
    echo
  fi

  echo "Installed tmuxinator workflows ($TMUXINATOR_DIR):"
  if [[ -d "$TMUXINATOR_DIR" ]]; then
    local installed=()
    local item
    shopt -s nullglob
    installed=("$TMUXINATOR_DIR"/*.yml)
    shopt -u nullglob

    if [[ ${#installed[@]} -eq 0 ]]; then
      echo "  (none)"
    else
      for item in "${installed[@]}"; do
        echo "  - $(basename "${item%.yml}")"
      done
    fi
  else
    echo "  (tmuxinator dir not found)"
  fi
}

workflow_repo_from_alias() {
  local project_name="$1"
  local alias_file="$TMUXINATOR_DIR/$project_name.yml"

  [[ -L "$alias_file" ]] || {
    echo ""
    return 0
  }

  local target
  target="$(readlink "$alias_file")"
  if [[ "$target" != /* ]]; then
    target="$(cd "$(dirname "$alias_file")" && pwd)/$target"
  fi

  local expected_suffix="/templates/projects/$project_name.yml"
  if [[ "$target" == *"$expected_suffix" ]]; then
    local repo
    repo="${target%$expected_suffix}"
    if is_workflow_repo "$repo"; then
      echo "$repo"
      return 0
    fi
  fi

  echo ""
}

resolved_project_config_file() {
  local project_name="$1"
  local alias_file="$TMUXINATOR_DIR/$project_name.yml"

  if [[ -L "$alias_file" ]]; then
    local target
    target="$(readlink "$alias_file")"
    if [[ "$target" != /* ]]; then
      target="$(cd "$(dirname "$alias_file")" && pwd)/$target"
    fi
    echo "$target"
    return 0
  fi

  echo "$alias_file"
}

render_project_config_for_start() {
  local source_file="$1"
  local project_name="$2"
  local workflow_repo="$3"
  local helper_file="$4"
  local rendered_file="$5"
  local repositories_root="${REPOSITORIES_ROOT:-$workflow_repo}"

  REPOSITORIES_ROOT="$repositories_root" TEAM_WORKFLOWS_REPO_DIR="$workflow_repo" TEAM_WORKFLOWS_HELPER_FILE="$helper_file" ruby -rerubi -e '
file = ARGV[0]
source = File.read(file)
rendered = eval(Erubi::Engine.new(source).src)
require "yaml"
YAML.safe_load(rendered, aliases: true)
puts rendered
' "$source_file" >"$rendered_file"
}

infer_start_project_from_context() {
  local cwd_name
  cwd_name="$(basename "$PWD")"

  if [[ -e "$TMUXINATOR_DIR/$cwd_name.yml" ]]; then
    echo "$cwd_name"
    return 0
  fi

  local repo
  repo="$(detect_workflow_repo)"
  if [[ -z "$repo" ]]; then
    echo ""
    return 0
  fi

  if [[ -f "$repo/templates/projects/$cwd_name.yml" ]]; then
    echo "$cwd_name"
    return 0
  fi

  local files=()
  shopt -s nullglob
  files=("$repo/templates/projects"/*.yml)
  shopt -u nullglob

  if [[ ${#files[@]} -eq 1 ]]; then
    echo "$(basename "${files[0]%.yml}")"
    return 0
  fi

  echo ""
}

cmd_start() {
  local project_name=""

  if [[ $# -eq 0 || "${1:-}" == -* ]]; then
    if [[ "${1:-}" == "--project" ]]; then
      error "Invalid option for twf start: --project"
      info "Usage: twf start <project-name> [tmuxinator args...]"
      info "Tip: use 'twf start test-repo' or run from that repo and use 'twf start'"
      exit 1
    fi

    project_name="$(infer_start_project_from_context)"
    if [[ -z "$project_name" ]]; then
      error "Missing project name and could not infer one from current directory"
      info "Usage: twf start <project-name> [tmuxinator args...]"
      info "Tip: run from your project repo and use 'twf start', or pass project explicitly"
      exit 1
    fi

    info "No project name provided; inferred '$project_name'"
  else
    project_name="$1"
    shift
  fi

  local alias_file="$TMUXINATOR_DIR/$project_name.yml"
  local current_repo=""
  local workflow_repo=""
  local local_template=""
  local config_source_file=""
  local rendered_config_file=""
  local tmuxinator_status=0
  local helper_file="$RUNTIME_DIR/templates/helpers/workflow.rb"
  shift

  if ! command -v tmuxinator >/dev/null 2>&1; then
    error "tmuxinator is not installed or not on PATH"
    exit 1
  fi

  if [[ ! -e "$alias_file" ]]; then
    workflow_repo="$(detect_workflow_repo)"
    if [[ -n "$workflow_repo" ]]; then
      local_template="$workflow_repo/templates/projects/$project_name.yml"
      if [[ -f "$local_template" ]]; then
        error "Missing tmuxinator alias for '$project_name': $alias_file"
        info "Project template exists locally: $local_template"
        info "Relink manually with:"
        printf '  ln -s "%s" "%s"\n' "$local_template" "$alias_file"
        exit 1
      fi
    fi

    error "Project alias not found: $alias_file"
    info "Add the project first with: twf add $project_name"
    exit 1
  fi

  if [[ ! -L "$alias_file" && ! -f "$alias_file" ]]; then
    error "Project alias path is not a file: $alias_file"
    exit 1
  fi

  current_repo="$(detect_workflow_repo)"
  if [[ -n "$current_repo" && -f "$current_repo/templates/projects/$project_name.yml" ]]; then
    workflow_repo="$current_repo"
  else
    workflow_repo="$(workflow_repo_from_alias "$project_name")"
  fi

  if [[ -n "$workflow_repo" ]]; then
    check_plugins_ready_for_project "$workflow_repo" "$project_name"
  fi

  if [[ -n "$workflow_repo" ]]; then
    config_source_file="$(resolved_project_config_file "$project_name")"
    rendered_config_file="$(mktemp "${TMPDIR:-/tmp}/twf-${project_name}-XXXXXX")"

    if ! render_project_config_for_start "$config_source_file" "$project_name" "$workflow_repo" "$helper_file" "$rendered_config_file"; then
      rm -f "$rendered_config_file"
      error "Failed to render workflow template for '$project_name'"
      exit 1
    fi

    tmuxinator start -p "$rendered_config_file" "$@"
    tmuxinator_status=$?
    rm -f "$rendered_config_file"
    return "$tmuxinator_status"
  else
    tmuxinator start "$project_name" "$@"
  fi
}

cmd_uninstall() {
  local assume_yes=false
  local arg

  for arg in "$@"; do
    case "$arg" in
    --yes)
      assume_yes=true
      ;;
    -h | --help)
      cat <<'EOF'
Usage: twf uninstall [--yes]

Removes global twf CLI installation (symlink and install root).
This does not remove tmuxinator project aliases.
EOF
      return 0
      ;;
    *)
      error "Unknown option for uninstall: $arg"
      info "Usage: twf uninstall [--yes]"
      exit 1
      ;;
    esac
  done

  local bin_dir="${TWF_BIN_DIR:-$DEFAULT_TWF_BIN_DIR}"
  local install_root="${TWF_INSTALL_ROOT:-$DEFAULT_TWF_HOME}"
  local symlink_path="$bin_dir/twf"

  if [[ -L "$symlink_path" || -f "$symlink_path" ]]; then
    rm -f "$symlink_path"
    ok "Removed CLI link: $symlink_path"
  else
    info "CLI link not found: $symlink_path"
  fi

  if [[ ! -d "$install_root" ]]; then
    info "Install root not found: $install_root"
    return 0
  fi

  local can_remove_root=false
  if [[ -f "$install_root/twf" && -f "$install_root/scripts/bootstrap.sh" ]]; then
    can_remove_root=true
  fi

  if [[ "$can_remove_root" != true ]]; then
    warn "Install root does not look like a twf install: $install_root"
    warn "Skipping removal for safety"
    return 0
  fi

  local remove_root=false
  if [[ "$assume_yes" == true ]]; then
    remove_root=true
  else
    if confirm_remove "Remove install root '$install_root'?"; then
      remove_root=true
    fi
  fi

  if [[ "$remove_root" == true ]]; then
    rm -rf "$install_root"
    ok "Removed install root: $install_root"
  else
    info "Kept install root: $install_root"
  fi
}

main() {
  local command="${1:-help}"
  shift || true

  case "$command" in
  help | -h | --help)
    usage
    ;;
  version | -v | --version)
    version
    ;;
  add)
    cmd_add "$@"
    ;;
  remove)
    cmd_remove "$@"
    ;;
  plugin)
    cmd_plugin "$@"
    ;;
  validate)
    cmd_validate "$@"
    ;;
  doctor)
    cmd_doctor "$@"
    ;;
  update)
    cmd_update "$@"
    ;;
  list)
    cmd_list "$@"
    ;;
  start)
    cmd_start "$@"
    ;;
  uninstall)
    cmd_uninstall "$@"
    ;;
  *)
    error "Unknown command: $command"
    usage
    exit 1
    ;;
  esac
}

main "$@"
