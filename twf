#!/usr/bin/env bash
set -euo pipefail

SCRIPT_PATH="${BASH_SOURCE[0]}"
while [[ -L "$SCRIPT_PATH" ]]; do
  SCRIPT_DIR="$(cd -P "$(dirname "$SCRIPT_PATH")" && pwd)"
  SCRIPT_PATH="$(readlink "$SCRIPT_PATH")"
  [[ "$SCRIPT_PATH" == /* ]] || SCRIPT_PATH="$SCRIPT_DIR/$SCRIPT_PATH"
done

RUNTIME_DIR="$(cd -P "$(dirname "$SCRIPT_PATH")" && pwd)"
DEFAULT_TWF_HOME="${HOME}/.local/share/twf"
DEFAULT_TWF_BIN_DIR="${HOME}/.local/bin"
TMUXINATOR_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/tmuxinator"
TWF_CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/twf"
TWF_CONFIG_FILE="$TWF_CONFIG_DIR/config.yml"
SERVICES_DIR="$RUNTIME_DIR/services"
SERVICE_STATE_ROOT="${XDG_DATA_HOME:-$HOME/.local/share}/twf/state/services"
SERVICE_CHECK_TIMEOUT_SEC="${TWF_SERVICE_CHECK_TIMEOUT_SEC:-4.0}"

START_MISSING_SERVICES=()
START_TIMEOUT_SERVICES=()
START_FAILED_SERVICES=()
INSTALL_CANDIDATES=()
CHECKBOX_SELECTED=()
PROJECT_DEP_COMMANDS=()
PROJECT_DEP_LABELS=()

ok() { printf "\033[1;32m[ok]\033[0m %s\n" "$1"; }
info() { printf "\033[1;34m[info]\033[0m %s\n" "$1"; }
warn() { printf "\033[1;33m[warn]\033[0m %s\n" "$1"; }
error() { printf "\033[1;31m[error]\033[0m %s\n" "$1" >&2; }

usage() {
  cat <<'EOF'
Usage: twf <command> [options]

Commands:
  add [project-name] [--dry-run]
                               Create a project workflow
  remove <project-name> [--yes]
                               Remove project workflow and alias
  service <command> [...]       Manage reusable services
  demo [target-dir]             Scaffold a working demo project
  status                       Show running projects and service health
  validate                     Validate workflow files
  doctor                       Run environment diagnostics
  install [--project <name>] [--yes]
                               Install machine readiness and project dependencies
  update                       Pull latest twf runtime repo
  list                         List projects and installed aliases
  start <project> [args...]    Start a project workflow (supports --strict)
  stop <project>               Stop a running project workflow
  uninstall [--yes]            Remove global twf CLI installation
  version                      Print twf version
  help                         Show this help

Examples:
  twf add my-project
  twf add my-project --dry-run
  twf add
  twf remove my-project
  twf service add node
  twf service install
  twf service add redis --project other-project
  twf demo
  twf status
  twf validate
  twf doctor
  twf install
  twf install --yes
  twf update
  twf start my-project
  twf stop my-project
EOF
}

usage_quick() {
  cat <<'EOF'
Usage: twf <command> [options]

Common commands:
  twf add [project-name]          Create a project workflow
  twf service add <service>       Add service to current project
  twf service install             Install services for current project
  twf start [project]             Start workflow
  twf stop [project]              Stop workflow
  twf status                      Show running workflows and health
  twf doctor                      Diagnose issues and show fixes
  twf install                     Install environment setup for project

Help:
  twf help                        Show this quick help
  twf help --all                  Show full command reference
  twf help <command>              Show help for a command

Examples:
  twf add
  twf service add web
  twf service install
  twf install
  twf start
EOF
}

closest_command() {
  local needle="$1"
  local commands=(add remove service demo status validate doctor install update list start stop uninstall version help)

  if command -v python3 >/dev/null 2>&1; then
    python3 - "$needle" "${commands[@]}" <<'PY'
import difflib
import sys

needle = sys.argv[1]
commands = sys.argv[2:]
matches = difflib.get_close_matches(needle, commands, n=1, cutoff=0.5)
print(matches[0] if matches else "")
PY
    return 0
  fi

  local cmd

  for cmd in "${commands[@]}"; do
    if [[ "$cmd" == "$needle"* || "$needle" == "$cmd"* ]]; then
      echo "$cmd"
      return 0
    fi
  done

  for cmd in "${commands[@]}"; do
    if [[ "$cmd" == *"$needle"* || "$needle" == *"$cmd"* ]]; then
      echo "$cmd"
      return 0
    fi
  done

  echo ""
}

cmd_help() {
  local topic="${1:-}"

  if [[ -z "$topic" ]]; then
    usage_quick
    return 0
  fi

  case "$topic" in
  --all)
    usage
    ;;
  add | remove | service | doctor | install | uninstall)
    "$0" "$topic" --help
    ;;
  start)
    cat <<'EOF'
Usage: twf start <project-name> [tmuxinator args...] [--strict]

Starts a workflow session.
If no project is provided, twf tries to infer it from current context.
EOF
    ;;
  stop)
    cat <<'EOF'
Usage: twf stop <project-name>

Stops a running workflow session.
If no project is provided, twf tries to infer it from current context.
EOF
    ;;
  demo)
    cat <<'EOF'
Usage: twf demo [target-dir]

Scaffolds a demo workspace with web + api services.
EOF
    ;;
  status)
    cat <<'EOF'
Usage: twf status

Shows running project sessions and service readiness.
EOF
    ;;
  list)
    cat <<'EOF'
Usage: twf list

Lists team workflow projects and installed tmuxinator aliases.
EOF
    ;;
  validate)
    cat <<'EOF'
Usage: twf validate

Validates workflow project files in the configured team workflow root.
EOF
    ;;
  update)
    cat <<'EOF'
Usage: twf update

Pulls latest twf runtime and refreshes the twf CLI symlink.
EOF
    ;;
  install)
    cat <<'EOF'
Usage: twf install [--project <project>] [--yes]

Installs machine readiness requirements and project dependencies.
If no project is provided, twf tries to infer it from current context.
EOF
    ;;
  version)
    version
    ;;
  help)
    usage_quick
    ;;
  *)
    error "Unknown help topic: $topic"
    local suggestion
    suggestion="$(closest_command "$topic")"
    if [[ -n "$suggestion" ]]; then
      info "Did you mean: twf help $suggestion"
    fi
    ;;
  esac
}

version() {
  if command -v git >/dev/null 2>&1 && git -C "$RUNTIME_DIR" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    git -C "$RUNTIME_DIR" describe --tags --always --dirty 2>/dev/null || true
    return 0
  fi

  echo "0.1.0"
}

validate_project_name() {
  local project_name="$1"
  if [[ ! "$project_name" =~ ^[a-z0-9][a-z0-9-]*$ ]]; then
    error "Invalid project name: '$project_name'"
    info "Use lowercase letters, numbers, and dashes only (must start with letter or number)."
    exit 1
  fi
}

expand_path() {
  local path="$1"
  if [[ "$path" == ~* ]]; then
    path="${path/#\~/$HOME}"
  fi

  if [[ "$path" != /* ]]; then
    path="$(cd "$PWD" && pwd)/$path"
  fi

  echo "$path"
}

read_configured_workflow_root() {
  if [[ -n "${TEAM_WORKFLOWS_ROOT:-}" ]]; then
    expand_path "$TEAM_WORKFLOWS_ROOT"
    return 0
  fi

  if [[ ! -f "$TWF_CONFIG_FILE" ]]; then
    echo ""
    return 0
  fi

  local configured
  configured="$(ruby -ryaml -e 'path = ARGV[0]; raw = YAML.safe_load(File.read(path), aliases: false); data = raw.is_a?(Hash) ? raw : {}; value = data["team_workflows_root"]; puts(value.is_a?(String) ? value : "")' "$TWF_CONFIG_FILE" 2>/dev/null || true)"
  if [[ -z "$configured" ]]; then
    echo ""
    return 0
  fi

  expand_path "$configured"
}

save_configured_workflow_root() {
  local root="$1"
  if [[ "$root" == "$RUNTIME_DIR" ]]; then
    error "team workflow root cannot be the twf runtime repository"
    info "Choose a separate directory, e.g. ../team-workflows"
    exit 1
  fi
  mkdir -p "$TWF_CONFIG_DIR"
  cat >"$TWF_CONFIG_FILE" <<EOF
team_workflows_root: "$root"
EOF
}

default_workflow_root_for_dir() {
  local base="$1"
  echo "$(cd "$base/.." && pwd)/team-workflows"
}

ensure_workflow_root_for_add() {
  local dry_run="${1:-false}"
  local configured
  configured="$(read_configured_workflow_root)"
  if [[ -n "$configured" ]]; then
    if [[ "$configured" == "$RUNTIME_DIR" ]]; then
      error "Configured team workflow root points to twf runtime repository"
      info "Run twf add from your project and choose a separate workflow root"
      exit 1
    fi
    echo "$configured"
    return 0
  fi

  local suggested
  suggested="$(default_workflow_root_for_dir "$PWD")"

  if [[ "$dry_run" == true ]]; then
    echo "$suggested"
    return 0
  fi

  if [[ ! -t 0 ]]; then
    mkdir -p "$suggested"
    save_configured_workflow_root "$suggested"
    echo "$suggested"
    return 0
  fi

  echo "No team workflow root configured yet."
  echo "Where should workflows be stored?"
  read -r -p "Path [$suggested]: " configured
  configured="${configured:-$suggested}"
  configured="$(expand_path "$configured")"

  mkdir -p "$configured"
  save_configured_workflow_root "$configured"
  ok "Configured team workflow root: $configured"
  echo "$configured"
}

detect_workflow_repo() {
  local configured
  configured="$(read_configured_workflow_root)"
  if [[ -n "$configured" && -d "$configured" ]]; then
    echo "$configured"
    return 0
  fi

  local linked_project
  linked_project="$(infer_project_from_local_link)"
  if [[ -n "$linked_project" ]]; then
    local local_link="$PWD/.twf/project.yml"
    local resolved
    resolved="$(python3 - "$local_link" <<'PY'
import os
import sys
print(os.path.realpath(sys.argv[1]))
PY
    )"
    local repo
    repo="$(dirname "$(dirname "$resolved")")"
    if [[ -d "$repo" ]]; then
      echo "$repo"
      return 0
    fi
  fi

  echo ""
}

require_workflow_repo() {
  local repo
  repo="$(detect_workflow_repo)"
  if [[ -z "$repo" ]]; then
    error "No team workflow root is configured"
    info "Run: twf add <project-name>"
    exit 1
  fi
  echo "$repo"
}

service_script_path() {
  local service_name="$1"
  echo "$SERVICES_DIR/$service_name.sh"
}

service_exists() {
  local service_name="$1"
  [[ -f "$(service_script_path "$service_name")" ]]
}

require_service() {
  local service_name="$1"
  if ! service_exists "$service_name"; then
    error "Unknown service: $service_name"
    info "Run 'twf service list' to see available services."
    exit 1
  fi
}

list_available_services() {
  if [[ ! -d "$SERVICES_DIR" ]]; then
    return 0
  fi

  local files=()
  local file
  shopt -s nullglob
  files=("$SERVICES_DIR"/*.sh)
  shopt -u nullglob

  for file in "${files[@]}"; do
    basename "${file%.sh}"
  done
}

hash_text() {
  local value="$1"
  if command -v shasum >/dev/null 2>&1; then
    printf '%s' "$value" | shasum -a 256 | awk '{print $1}'
  elif command -v openssl >/dev/null 2>&1; then
    printf '%s' "$value" | openssl dgst -sha256 | awk '{print $NF}'
  else
    printf '%s' "$value" | cksum | awk '{print $1}'
  fi
}

detect_suggested_services() {
  local source_root="$1"
  local suggestions=()

  has_path_match() {
    local base="$1"
    shift
    local pattern
    for pattern in "$@"; do
      if compgen -G "$base/$pattern" >/dev/null 2>&1; then
        return 0
      fi
    done
    return 1
  }

  if has_path_match "$source_root" \
    "package.json" \
    "pnpm-lock.yaml" \
    "yarn.lock" \
    "npm-shrinkwrap.json" \
    "bun.lockb" \
    "bun.lock" \
    "bunfig.toml" \
    "nx.json" \
    "turbo.json" \
    "lerna.json"; then
    suggestions+=("node")
  fi

  if has_path_match "$source_root" \
    "docker-compose.yml" \
    "docker-compose.yaml" \
    "compose.yml" \
    "compose.yaml" \
    "Dockerfile" \
    "Dockerfile.*" \
    ".devcontainer/devcontainer.json"; then
    suggestions+=("containers")
  fi

  if has_path_match "$source_root" \
    "requirements.txt" \
    "requirements-*.txt" \
    "pyproject.toml" \
    "Pipfile" \
    "poetry.lock" \
    "setup.py" \
    "setup.cfg"; then
    suggestions+=("python")
  fi

  if has_path_match "$source_root" \
    "*.sln" \
    "*.csproj" \
    "global.json"; then
    suggestions+=("dotnet")
  fi

  if has_path_match "$source_root" \
    "redis.conf" \
    "redis/*.conf"; then
    suggestions+=("redis")
  fi

  if has_path_match "$source_root" \
    "pom.xml" \
    "build.gradle" \
    "build.gradle.kts" \
    "settings.gradle" \
    "settings.gradle.kts" \
    "gradlew" \
    "mvnw"; then
    suggestions+=("java")
  fi

  if has_path_match "$source_root" \
    "go.mod" \
    "go.sum" \
    "go.work"; then
    suggestions+=("go")
  fi

  if has_path_match "$source_root" \
    "Gemfile" \
    "Gemfile.lock" \
    ".ruby-version" \
    "Rakefile"; then
    suggestions+=("ruby")
  fi

  if has_path_match "$source_root" \
    "composer.json" \
    "composer.lock" \
    "phpunit.xml" \
    "phpunit.xml.dist"; then
    suggestions+=("php")
  fi

  if has_path_match "$source_root" \
    "Cargo.toml" \
    "Cargo.lock" \
    "rust-toolchain.toml"; then
    suggestions+=("rust")
  fi

  if has_path_match "$source_root" \
    "postgresql.conf" \
    "postgres.conf" \
    "pg_hba.conf"; then
    suggestions+=("postgres")
  fi

  if has_path_match "$source_root" \
    "CMakeLists.txt" \
    "meson.build" \
    "Makefile" \
    "*.c" \
    "*.h"; then
    suggestions+=("c")
  fi

  if has_path_match "$source_root" \
    "CMakeLists.txt" \
    "meson.build" \
    "Makefile" \
    "*.cpp" \
    "*.cc" \
    "*.cxx" \
    "*.hpp" \
    "*.hh" \
    "*.hxx"; then
    suggestions+=("cpp")
  fi

  local seen=","
  local service
  for service in "${suggestions[@]}"; do
    if [[ "$seen" != *",$service,"* ]]; then
      echo "$service"
      seen+="$service,"
    fi
  done
}

project_dir() {
  local repo="$1"
  local project_name="$2"
  echo "$repo/$project_name"
}

project_template_file() {
  local repo="$1"
  local project_name="$2"
  echo "$(project_dir "$repo" "$project_name")/project.yml"
}

project_override_file() {
  local repo="$1"
  local project_name="$2"
  echo "$(project_dir "$repo" "$project_name")/developer.yml"
}

ensure_project_exists() {
  local repo="$1"
  local project_name="$2"
  local template_file
  template_file="$(project_template_file "$repo" "$project_name")"

  if [[ ! -f "$template_file" ]]; then
    error "Project template not found: $template_file"
    info "Add the project first: twf add $project_name"
    exit 1
  fi
}

enabled_services_for_project() {
  local repo="$1"
  local project_name="$2"
  local override_file
  override_file="$(project_override_file "$repo" "$project_name")"

  ruby -ryaml -e '
path = ARGV[0]
if !File.exist?(path)
  exit 0
end
raw = YAML.safe_load(File.read(path), aliases: false)
data = raw.is_a?(Hash) ? raw : {}
services = data["services"].is_a?(Hash) ? data["services"] : {}
enabled = services["enabled"].is_a?(Array) ? services["enabled"] : []
enabled.select { |v| v.is_a?(String) && !v.strip.empty? }.each { |v| puts v }
' "$override_file"
}

service_config_json_for_project() {
  local repo="$1"
  local project_name="$2"
  local service_name="$3"
  local override_file
  override_file="$(project_override_file "$repo" "$project_name")"

  ruby -ryaml -rjson -e '
path = ARGV[0]
service = ARGV[1]
if !File.exist?(path)
  puts "{}"
  exit 0
end
raw = YAML.safe_load(File.read(path), aliases: false)
data = raw.is_a?(Hash) ? raw : {}
services = data["services"].is_a?(Hash) ? data["services"] : {}
config = services["config"].is_a?(Hash) ? services["config"] : {}
value = config[service]
value = {} unless value.is_a?(Hash)
puts JSON.generate(value)
' "$override_file" "$service_name"
}

add_service_to_project_config() {
  local repo="$1"
  local project_name="$2"
  local service_name="$3"
  local override_file
  override_file="$(project_override_file "$repo" "$project_name")"

  mkdir -p "$(dirname "$override_file")"
  [[ -f "$override_file" ]] || printf '{}\n' >"$override_file"

  ruby -ryaml -e '
path = ARGV[0]
service = ARGV[1]
raw = YAML.safe_load(File.read(path), aliases: false)
data = raw.is_a?(Hash) ? raw : {}
data["services"] = {} unless data["services"].is_a?(Hash)
services = data["services"]
services["enabled"] = [] unless services["enabled"].is_a?(Array)
enabled = services["enabled"].select { |v| v.is_a?(String) && !v.strip.empty? }
enabled << service unless enabled.include?(service)
services["enabled"] = enabled
File.write(path, data.to_yaml(line_width: -1))
' "$override_file" "$service_name"
}

remove_service_from_project_config() {
  local repo="$1"
  local project_name="$2"
  local service_name="$3"
  local override_file
  override_file="$(project_override_file "$repo" "$project_name")"

  if [[ ! -f "$override_file" ]]; then
    return 0
  fi

  ruby -ryaml -e '
path = ARGV[0]
service = ARGV[1]
raw = YAML.safe_load(File.read(path), aliases: false)
data = raw.is_a?(Hash) ? raw : {}
services = data["services"].is_a?(Hash) ? data["services"] : nil
if services
  if services["enabled"].is_a?(Array)
    services["enabled"] = services["enabled"].select { |v| v.is_a?(String) && v != service }
  end
  if services["config"].is_a?(Hash)
    services["config"].delete(service)
  end
  services.delete("enabled") if services["enabled"].is_a?(Array) && services["enabled"].empty?
  services.delete("config") if services["config"].is_a?(Hash) && services["config"].empty?
  data.delete("services") if services.empty?
end
File.write(path, data.to_yaml(line_width: -1))
' "$override_file" "$service_name"
}

service_state_file() {
  local project_name="$1"
  local service_name="$2"
  echo "$SERVICE_STATE_ROOT/$project_name/$service_name.state"
}

service_version() {
  local service_name="$1"
  local service_script
  service_script="$(service_script_path "$service_name")"
  bash "$service_script" version
}

service_state_matches() {
  local project_name="$1"
  local service_name="$2"
  local expected_version="$3"
  local expected_hash="$4"
  local state_file
  state_file="$(service_state_file "$project_name" "$service_name")"

  [[ -f "$state_file" ]] || return 1

  local saved_version=""
  local saved_hash=""
  while IFS='=' read -r key value; do
    case "$key" in
    VERSION) saved_version="$value" ;;
    CONFIG_HASH) saved_hash="$value" ;;
    esac
  done <"$state_file"

  [[ "$saved_version" == "$expected_version" && "$saved_hash" == "$expected_hash" ]]
}

write_service_state() {
  local project_name="$1"
  local service_name="$2"
  local version="$3"
  local config_hash="$4"
  local state_file
  state_file="$(service_state_file "$project_name" "$service_name")"

  mkdir -p "$(dirname "$state_file")"
  cat >"$state_file" <<EOF
VERSION=$version
CONFIG_HASH=$config_hash
UPDATED_AT=$(date -u +%Y-%m-%dT%H:%M:%SZ)
EOF
}

ensure_bin_on_path() {
  local bin_dir="$1"
  case ":$PATH:" in
  *":$bin_dir:"*)
    ok "$bin_dir is on PATH"
    ;;
  *)
    warn "$bin_dir is not on PATH"
    info "Add this line to your shell rc file:"
    printf '  export PATH="%s:$PATH"\n' "$bin_dir"
    ;;
  esac
}

confirm_remove() {
  local prompt="$1"
  local response=""
  read -r -p "$prompt [y/N]: " response
  [[ "${response:-N}" =~ ^[Yy]$ ]]
}

confirm_default_yes() {
  local prompt="$1"
  local response=""

  while true; do
    read -r -p "$prompt [Y/n]: " response
    case "${response:-}" in
    "" | y | Y | yes | YES | Yes)
      return 0
      ;;
    n | N | no | NO | No)
      return 1
      ;;
    *)
      info "Please answer y or n."
      ;;
    esac
  done
}

is_interactive_terminal() {
  [[ -t 0 && -t 1 ]]
}

select_requirements_with_checkboxes() {
  local options=("$@")
  local count=${#options[@]}

  CHECKBOX_SELECTED=()
  if [[ "$count" -eq 0 ]]; then
    return 0
  fi

  local selected=()
  local i=0
  for ((i = 0; i < count; i++)); do
    selected+=(1)
  done

  local cursor=0
  local key=""

  while true; do
    printf '\033[H\033[J'
    echo "Select requirements to install"
    echo "Space: toggle  Enter: confirm  A: toggle all  Q: cancel"
    echo

    local selected_count=0
    for ((i = 0; i < count; i++)); do
      local marker="[ ]"
      if [[ "${selected[$i]}" -eq 1 ]]; then
        marker="[x]"
        selected_count=$((selected_count + 1))
      fi

      if [[ "$i" -eq "$cursor" ]]; then
        printf '\033[1;36m> %s %s\033[0m\n' "$marker" "${options[$i]}"
      elif [[ "${selected[$i]}" -eq 1 ]]; then
        printf '\033[1;32m  %s %s\033[0m\n' "$marker" "${options[$i]}"
      else
        printf '  %s %s\n' "$marker" "${options[$i]}"
      fi
    done

    echo
    echo "Selected: $selected_count of $count"

    IFS= read -rsn1 key || true
    if [[ "$key" == $'\x1b' ]]; then
      local rest=""
      IFS= read -rsn2 rest || true
      key+="$rest"
    fi

    case "$key" in
    "")
      CHECKBOX_SELECTED=()
      for ((i = 0; i < count; i++)); do
        if [[ "${selected[$i]}" -eq 1 ]]; then
          CHECKBOX_SELECTED+=("${options[$i]}")
        fi
      done
      return 0
      ;;
    " ")
      if [[ "${selected[$cursor]}" -eq 1 ]]; then
        selected[$cursor]=0
      else
        selected[$cursor]=1
      fi
      ;;
    q | Q)
      return 1
      ;;
    a | A)
      local all_selected=true
      for ((i = 0; i < count; i++)); do
        if [[ "${selected[$i]}" -eq 0 ]]; then
          all_selected=false
          break
        fi
      done
      for ((i = 0; i < count; i++)); do
        if [[ "$all_selected" == true ]]; then
          selected[$i]=0
        else
          selected[$i]=1
        fi
      done
      ;;
    j | $'\x1b[B')
      cursor=$(((cursor + 1) % count))
      ;;
    k | $'\x1b[A')
      cursor=$(((cursor - 1 + count) % count))
      ;;
    esac
  done
}

render_project_template() {
  local project_name="$1"
  local source_root="$2"

  cat <<EOF
name: $project_name
root: "$source_root"

startup_window: app

windows:
  - app:
      root: "$source_root"
      layout: main-vertical
      panes:
        - editor: 'nvim'
        - shell: 'zsh -l'
EOF
}

is_codebase_directory() {
  local dir="$1"

  [[ -d "$dir" ]] || return 1
  [[ -e "$dir/.git" ]] && return 0

  local markers=(
    "package.json"
    "pyproject.toml"
    "requirements.txt"
    "go.mod"
    "Cargo.toml"
    "composer.json"
    "Gemfile"
    "pom.xml"
    "build.gradle"
    "build.gradle.kts"
    "*.sln"
    "*.csproj"
    "Dockerfile"
    "docker-compose.yml"
    "docker-compose.yaml"
  )

  local marker
  for marker in "${markers[@]}"; do
    if compgen -G "$dir/$marker" >/dev/null 2>&1; then
      return 0
    fi
  done

  return 1
}

detect_workspace_repos() {
  local root="$1"
  local children=()
  local child

  shopt -s nullglob
  children=("$root"/*)
  shopt -u nullglob

  for child in "${children[@]}"; do
    [[ -d "$child" ]] || continue
    is_codebase_directory "$child" || continue
    echo "$child"
  done
}

window_name_from_repo_path() {
  local path="$1"
  local name
  name="$(basename "$path")"
  name="${name// /-}"
  name="${name//_/-}"
  echo "$name"
}

render_workspace_project_template() {
  local project_name="$1"
  local source_root="$2"
  shift 2
  local repo_paths=("$@")

  cat <<EOF
name: $project_name
root: "$source_root"

startup_window: $(window_name_from_repo_path "${repo_paths[0]}")

windows:
EOF

  local repo_path
  local repo_name
  local repo_dir_name
  for repo_path in "${repo_paths[@]}"; do
    repo_dir_name="$(basename "$repo_path")"
    repo_name="$(window_name_from_repo_path "$repo_path")"
    cat <<EOF
  - $repo_name:
      root: ./${repo_dir_name}
      layout: main-vertical
      panes:
        - editor: 'nvim'
        - shell: 'zsh -l'

EOF
  done

  cat <<'EOF'
  - twf:
      root: ./.twf
      panes:
        - 'nvim || zsh -l'
EOF
}

scaffold_workflow_repo() {
  local repo="$1"

  mkdir -p "$repo"
}

write_repo_readme() {
  local repo="$1"
  local first_project="$2"

  cat >"$repo/README.md" <<EOF
# Team workflow repository

This repository is managed with \`twf\` and is intended to live outside application repositories.

- Project workflows: \`<project>/project.yml\`
- Project overrides: \`<project>/developer.yml\`

Typical flow:

\`\`\`bash
twf service install --project $first_project
twf validate
twf doctor
twf start $first_project
\`\`\`

You can add more projects later from this same repo:

\`\`\`bash
twf add another-project
\`\`\`
EOF
}

resolve_alias_conflict() {
  local repo="$1"
  local project_name="$2"
  local dry_run="$3"

  local name="$project_name"

  while :; do
    local project_file
    project_file="$(project_template_file "$repo" "$name")"
    local override_file
    override_file="$(project_override_file "$repo" "$name")"
    local tmuxinator_file="$TMUXINATOR_DIR/$name.yml"

    if [[ -e "$project_file" || -e "$override_file" ]]; then
      error "Project files already exist for '$name' in this workflow repo"
      info "Choose a different project name."
      exit 1
    fi

    if [[ ! -e "$tmuxinator_file" ]]; then
      printf '%s|%s\n' "$name" "create"
      return 0
    fi

    if [[ -L "$tmuxinator_file" ]]; then
      local target=""
      target="$(readlink "$tmuxinator_file")"
      if [[ "$target" == "$project_file" ]]; then
        printf '%s|%s\n' "$name" "same"
        return 0
      fi
    elif [[ ! -f "$tmuxinator_file" ]]; then
      error "Refusing to manage non-file alias path: $tmuxinator_file"
      exit 1
    fi

    echo
    warn "tmuxinator alias already exists: $tmuxinator_file"
    if [[ -L "$tmuxinator_file" ]]; then
      info "Current alias target: $(readlink "$tmuxinator_file")"
    fi
    echo "Choose one:"
    echo "  [r] rename project"
    echo "  [p] replace alias"
    local choice=""
    read -r -p "Your choice [r/p]: " choice

    case "${choice:-}" in
    r | R)
      local renamed=""
      read -r -p "Enter new project name: " renamed
      if [[ -z "$renamed" ]]; then
        error "Project name cannot be empty"
        continue
      fi
      validate_project_name "$renamed"
      name="$renamed"
      ;;
    p | P)
      if [[ "$dry_run" == true ]]; then
        printf '%s|%s\n' "$name" "replace"
        return 0
      fi
      if confirm_remove "Replace existing alias '$tmuxinator_file'?"; then
        printf '%s|%s\n' "$name" "replace"
        return 0
      fi
      error "Alias replacement cancelled"
      exit 1
      ;;
    *)
      error "Invalid choice"
      ;;
    esac
  done
}

link_project_alias() {
  local repo="$1"
  local project_name="$2"
  local mode="$3"

  local source_file
  source_file="$(project_template_file "$repo" "$project_name")"
  local tmuxinator_file="$TMUXINATOR_DIR/$project_name.yml"

  mkdir -p "$TMUXINATOR_DIR"

  case "$mode" in
  create)
    ln -s "$source_file" "$tmuxinator_file"
    ok "Created tmuxinator alias: $tmuxinator_file -> $source_file"
    ;;
  replace)
    rm -f "$tmuxinator_file"
    ln -s "$source_file" "$tmuxinator_file"
    ok "Replaced tmuxinator alias: $tmuxinator_file -> $source_file"
    ;;
  same)
    ok "tmuxinator alias already points to project file: $tmuxinator_file"
    ;;
  *)
    error "Unknown alias mode: $mode"
    exit 1
    ;;
  esac
}

list_projects_in_repo() {
  local repo="$1"
  local dirs=()
  local d
  shopt -s nullglob
  dirs=("$repo"/*)
  shopt -u nullglob

  for d in "${dirs[@]}"; do
    [[ -d "$d" ]] || continue
    [[ -f "$d/project.yml" ]] || continue
    basename "$d"
  done
}

ensure_local_workflow_link() {
  local project_name="$1"
  local project_dir="$2"
  local repo_dir="$3"
  local quiet="${4:-false}"
  local local_dir="$repo_dir/.twf"
  local project_link="$local_dir/project.yml"
  local developer_link="$local_dir/developer.yml"
  local source_project_file="$project_dir/project.yml"
  local source_developer_file="$project_dir/developer.yml"

  mkdir -p "$local_dir"
  ln -sfn "$source_project_file" "$project_link"
  ln -sfn "$source_developer_file" "$developer_link"
  if [[ "$quiet" != true ]]; then
    ok "Created local workflow links in: $local_dir"
  fi

  if [[ -L "$local_dir/workflow" || -d "$local_dir/workflow" ]]; then
    rm -rf "$local_dir/workflow"
  fi
  if [[ -d "$local_dir/workflows" ]]; then
    rm -rf "$local_dir/workflows"
  fi

  local gitignore_file="$repo_dir/.gitignore"
  if [[ -f "$gitignore_file" ]]; then
    if ! grep -qF ".twf/" "$gitignore_file"; then
      printf '\n.twf/\n' >>"$gitignore_file"
      ok "Updated gitignore: $gitignore_file"
    fi
  fi
}

cmd_add() {
  local dry_run=false
  local project_name=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
    --dry-run)
      dry_run=true
      shift
      ;;
    -h | --help)
      cat <<'EOF'
Usage: twf add [project-name] [--dry-run]

- Creates a project workflow in the configured team workflow root.
- If project-name is omitted, defaults to current folder name.
EOF
      return 0
      ;;
    *)
      if [[ -z "$project_name" ]]; then
        project_name="$1"
        shift
      else
        error "Unexpected argument: $1"
        exit 1
      fi
      ;;
    esac
  done

  local workflow_repo=""
  local scaffold_repo=false
  local source_root
  source_root="$(cd "$PWD" && pwd)"
  local add_mode="single"
  local workspace_repos=()

  if ! is_codebase_directory "$source_root"; then
    local candidate=""
    while IFS= read -r candidate; do
      [[ -n "$candidate" ]] || continue
      workspace_repos+=("$candidate")
    done < <(detect_workspace_repos "$source_root")

    if [[ ${#workspace_repos[@]} -ge 2 ]]; then
      add_mode="workspace"
    fi
  fi

  if [[ "$add_mode" == "workspace" && ${#workspace_repos[@]} -eq 0 ]]; then
    local candidate=""
    while IFS= read -r candidate; do
      [[ -n "$candidate" ]] || continue
      workspace_repos+=("$candidate")
    done < <(detect_workspace_repos "$source_root")
  fi

  if [[ "$add_mode" == "workspace" && ${#workspace_repos[@]} -lt 2 ]]; then
    warn "Workspace mode selected, but fewer than 2 child codebases detected; continuing as single project"
    add_mode="single"
  fi

  if [[ "$add_mode" == "workspace" && -t 0 && "$dry_run" != true ]]; then
    info "Detected multi-repo workspace with ${#workspace_repos[@]} repositories"
    if ! confirm_remove "Create one workspace workflow for this directory?"; then
      info "Continuing with single-project add mode"
      add_mode="single"
    fi
  fi

  workflow_repo="$(ensure_workflow_root_for_add "$dry_run")"
  if [[ ! -f "$workflow_repo/README.md" ]]; then
    scaffold_repo=true
  fi
  mkdir -p "$workflow_repo"

  if [[ -z "$project_name" ]]; then
    local default_name
    default_name="$(basename "$source_root")"
    project_name="$default_name"

    if [[ -t 0 ]]; then
      local entered_name=""
      read -r -p "Project name [$default_name]: " entered_name
      project_name="${entered_name:-$default_name}"
    fi
  fi

  validate_project_name "$project_name"

  local resolution
  resolution="$(resolve_alias_conflict "$workflow_repo" "$project_name" "$dry_run")"
  local final_name="${resolution%%|*}"
  local alias_mode="${resolution#*|}"

  local project_file=""
  local project_root_dir
  project_root_dir="$(project_dir "$workflow_repo" "$final_name")"
  local override_file="$project_root_dir/developer.yml"
  project_file="$project_root_dir/project.yml"
  local suggested_services=()
  local suggested_service=""
  local seen_services=","
  if [[ "$add_mode" == "workspace" ]]; then
    local repo_path
    for repo_path in "${workspace_repos[@]}"; do
      while IFS= read -r suggested_service; do
        [[ -n "$suggested_service" ]] || continue
        if [[ "$seen_services" != *",$suggested_service,"* ]]; then
          suggested_services+=("$suggested_service")
          seen_services+="$suggested_service,"
        fi
      done < <(detect_suggested_services "$repo_path")
    done
  else
    while IFS= read -r suggested_service; do
      [[ -n "$suggested_service" ]] || continue
      if [[ "$seen_services" != *",$suggested_service,"* ]]; then
        suggested_services+=("$suggested_service")
        seen_services+="$suggested_service,"
      fi
    done < <(detect_suggested_services "$source_root")
  fi

  if [[ "$dry_run" == true ]]; then
    info "Dry run: no files were written"
    if [[ "$scaffold_repo" == true ]]; then
      echo "Would create workflow repo in: $workflow_repo"
      echo "  README.md"
    fi
    echo "Would create project directory: $project_root_dir"
    echo "Would create project files:"
    echo "  $project_file"
    echo "  $override_file"
    if [[ "$add_mode" == "workspace" ]]; then
      echo "Mode: workspace"
      echo "Would include repositories:"
      local repo_path
      for repo_path in "${workspace_repos[@]}"; do
        echo "  - $(basename "$repo_path")"
      done
    fi
    if [[ ${#suggested_services[@]} -gt 0 ]]; then
      echo "Would auto-enable suggested services: ${suggested_services[*]}"
    fi
    if [[ "$add_mode" == "single" ]]; then
      echo "Mode: minimal project content"
    fi

    case "$alias_mode" in
    create)
      echo "Would create tmuxinator alias: $TMUXINATOR_DIR/$final_name.yml"
      ;;
    replace)
      echo "Would replace tmuxinator alias: $TMUXINATOR_DIR/$final_name.yml"
      ;;
    same)
      echo "tmuxinator alias already points to this project"
      ;;
    esac
    return 0
  fi

  if [[ "$scaffold_repo" == true ]]; then
    scaffold_workflow_repo "$workflow_repo"
    write_repo_readme "$workflow_repo" "$final_name"
    ok "Created workflow repository"
  fi

  mkdir -p "$project_root_dir"
  if [[ "$add_mode" == "workspace" ]]; then
    render_workspace_project_template "$final_name" "$source_root" "${workspace_repos[@]}" >"$project_file"
  else
    render_project_template "$final_name" "$source_root" >"$project_file"
  fi

  {
    cat <<'EOF'
services:
  enabled:
EOF
    if [[ ${#suggested_services[@]} -eq 0 ]]; then
      echo "    []"
    else
      for suggested_service in "${suggested_services[@]}"; do
        echo "    - $suggested_service"
      done
    fi
    cat <<'EOF'
  config: {}
EOF
  } >"$override_file"

  link_project_alias "$workflow_repo" "$final_name" "$alias_mode"
  ensure_local_workflow_link "$final_name" "$project_root_dir" "$source_root"

  ok "Created workflow template: $project_file"
  ok "Created developer override: $override_file"
  if [[ ${#suggested_services[@]} -gt 0 ]]; then
    info "Auto-enabled suggested services: ${suggested_services[*]}"
  fi

  if is_interactive_terminal; then
    if confirm_default_yes "Run environment setup now?"; then
      cmd_install --project "$final_name"
    else
      info "Skipped environment setup"
      info "Run: twf install"
    fi
  else
    info "Run: twf install"
  fi
}

cmd_remove() {
  local assume_yes=false
  local project_name=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
    --yes)
      assume_yes=true
      shift
      ;;
    -h | --help)
      cat <<'EOF'
Usage: twf remove <project-name> [--yes]

Removes the tmuxinator alias for a project, then optionally removes
local override/template files when running inside a workflow repo.
EOF
      return 0
      ;;
    *)
      if [[ -z "$project_name" ]]; then
        project_name="$1"
        shift
      else
        error "Unexpected argument: $1"
        exit 1
      fi
      ;;
    esac
  done

  if [[ -z "$project_name" ]]; then
    error "Missing project name"
    info "Usage: twf remove <project-name> [--yes]"
    exit 1
  fi

  validate_project_name "$project_name"

  local repo
  repo="$(require_workflow_repo)"

  local tmuxinator_file="$TMUXINATOR_DIR/$project_name.yml"
  if [[ ! -e "$tmuxinator_file" ]]; then
    warn "Project alias not found: $tmuxinator_file"
  fi

  if [[ -e "$tmuxinator_file" ]] && ([[ -L "$tmuxinator_file" ]] || [[ -f "$tmuxinator_file" ]]); then
    rm -f "$tmuxinator_file"
    ok "Removed tmuxinator alias: $tmuxinator_file"
  elif [[ -e "$tmuxinator_file" ]]; then
    error "Refusing to remove non-file path: $tmuxinator_file"
    exit 1
  fi

  local project_path
  project_path="$(project_dir "$repo" "$project_name")"
  if [[ -d "$project_path" ]]; then
    if [[ "$assume_yes" == true ]] || confirm_remove "Remove project directory '$project_path'?"; then
      rm -rf "$project_path"
      ok "Removed project directory: $project_path"
    else
      info "Kept project directory: $project_path"
    fi
  else
    info "Project directory not found: $project_path"
  fi
}

load_enabled_services_for_project() {
  local repo="$1"
  local project_name="$2"
  local service=""

  LOADED_PROJECT_SERVICES=()
  while IFS= read -r service; do
    [[ -n "$service" ]] || continue
    LOADED_PROJECT_SERVICES+=("$service")
  done < <(enabled_services_for_project "$repo" "$project_name")
}

build_service_state_context() {
  local repo="$1"
  local project_name="$2"
  local service_name="$3"

  SERVICE_CTX_SCRIPT="$(service_script_path "$service_name")"
  SERVICE_CTX_VERSION="$(service_version "$service_name")"
  SERVICE_CTX_CONFIG_JSON="$(service_config_json_for_project "$repo" "$project_name" "$service_name")"
  SERVICE_CTX_CONFIG_HASH="$(hash_text "$SERVICE_CTX_CONFIG_JSON")"
}

run_service_install_for_project() {
  local repo="$1"
  local project_name="$2"
  local assume_yes="$3"
  local service=""

  ensure_project_exists "$repo" "$project_name"
  load_enabled_services_for_project "$repo" "$project_name"

  if [[ ${#LOADED_PROJECT_SERVICES[@]} -eq 0 ]]; then
    info "No services configured for project '$project_name'."
    return 0
  fi

  for service in "${LOADED_PROJECT_SERVICES[@]}"; do
    require_service "$service"
    build_service_state_context "$repo" "$project_name" "$service"

    if service_state_matches "$project_name" "$service" "$SERVICE_CTX_VERSION" "$SERVICE_CTX_CONFIG_HASH"; then
      ok "Service '$service' is already installed for project '$project_name'"
      continue
    fi

    info "Installing service '$service' for project '$project_name'"
    if ! TWF_SERVICE_CONFIG_JSON="$SERVICE_CTX_CONFIG_JSON" TWF_SERVICE_ASSUME_YES="$assume_yes" bash "$SERVICE_CTX_SCRIPT" install; then
      error "Service install failed: $service"
      exit 1
    fi

    if ! TWF_SERVICE_CONFIG_JSON="$SERVICE_CTX_CONFIG_JSON" bash "$SERVICE_CTX_SCRIPT" check; then
      error "Service check failed after install: $service"
      exit 1
    fi

    write_service_state "$project_name" "$service" "$SERVICE_CTX_VERSION" "$SERVICE_CTX_CONFIG_HASH"
    ok "Service ready: $service"
  done
}

report_service_readiness_for_start() {
  local repo="$1"
  local project_name="$2"
  local service=""

  START_MISSING_SERVICES=()
  START_TIMEOUT_SERVICES=()
  START_FAILED_SERVICES=()
  load_enabled_services_for_project "$repo" "$project_name"

  if [[ ${#LOADED_PROJECT_SERVICES[@]} -eq 0 ]]; then
    echo "  - (no services configured)"
    return 0
  fi

  for service in "${LOADED_PROJECT_SERVICES[@]}"; do
    require_service "$service"
    build_service_state_context "$repo" "$project_name" "$service"

    local state_ready=false
    if service_state_matches "$project_name" "$service" "$SERVICE_CTX_VERSION" "$SERVICE_CTX_CONFIG_HASH"; then
      state_ready=true
    fi

    local check_rc=0
    set +e
    run_service_check_with_timeout "$SERVICE_CTX_SCRIPT" "$SERVICE_CTX_CONFIG_JSON" "$SERVICE_CHECK_TIMEOUT_SEC"
    check_rc=$?
    set -e

    if [[ "$check_rc" -eq 0 ]]; then
      if [[ "$state_ready" == true ]]; then
        printf '✔ %s -> ready\n' "$service"
      else
        printf '⚠ %s -> not installed\n' "$service"
        START_MISSING_SERVICES+=("$service")
      fi
      continue
    fi

    if [[ "$check_rc" -eq 124 ]]; then
      printf '⚠ %s -> check timed out (%.1fs)\n' "$service" "$SERVICE_CHECK_TIMEOUT_SEC"
      START_TIMEOUT_SERVICES+=("$service")
      continue
    fi

    if [[ "$state_ready" == true ]]; then
      printf '⚠ %s -> check failed\n' "$service"
      START_FAILED_SERVICES+=("$service")
    else
      printf '⚠ %s -> not installed\n' "$service"
      START_MISSING_SERVICES+=("$service")
    fi
  done
}

collect_install_candidates_for_project() {
  INSTALL_CANDIDATES=()
  local seen=","
  local service=""

  for service in "${START_MISSING_SERVICES[@]-}" "${START_TIMEOUT_SERVICES[@]-}" "${START_FAILED_SERVICES[@]-}"; do
    [[ -n "$service" ]] || continue
    if [[ "$seen" != *",$service,"* ]]; then
      INSTALL_CANDIDATES+=("$service")
      seen+="$service,"
    fi
  done
}

service_requirement_label() {
  local service="$1"
  case "$service" in
  node)
    echo "node (required >= v${TWF_NODE_REQUIRED_MAJOR:-20})"
    ;;
  *)
    echo "$service"
    ;;
  esac
}

install_selected_services_for_project() {
  local repo="$1"
  local project_name="$2"
  local assume_yes="$3"
  shift 3

  local selected_services=("$@")
  local service=""
  local failures=()

  if [[ ${#selected_services[@]} -eq 0 ]]; then
    warn "No machine requirements were selected for installation"
    return 0
  fi

  local idx=0
  local total=${#selected_services[@]}
  for service in "${selected_services[@]}"; do
    idx=$((idx + 1))
    require_service "$service"
    build_service_state_context "$repo" "$project_name" "$service"
    local service_label
    service_label="$(service_requirement_label "$service")"

    echo "[install] ($idx/$total) $service_label"
    if ! TWF_SERVICE_CONFIG_JSON="$SERVICE_CTX_CONFIG_JSON" TWF_SERVICE_ASSUME_YES="$assume_yes" bash "$SERVICE_CTX_SCRIPT" install; then
      error "INSTALL-101 Failed to install machine requirement: $service_label"
      failures+=("$service")
      continue
    fi

    if ! TWF_SERVICE_CONFIG_JSON="$SERVICE_CTX_CONFIG_JSON" bash "$SERVICE_CTX_SCRIPT" check; then
      error "INSTALL-102 Requirement check failed after install: $service"
      failures+=("$service")
      continue
    fi

    write_service_state "$project_name" "$service" "$SERVICE_CTX_VERSION" "$SERVICE_CTX_CONFIG_HASH"
    ok "Requirement ready: $service"
  done

  if [[ ${#failures[@]} -gt 0 ]]; then
    warn "Machine readiness incomplete. Failed requirements: ${failures[*]}"
    return 1
  fi

  return 0
}

project_root_for_project() {
  local repo="$1"
  local project_name="$2"
  local config_source_file
  local config_override_file
  local rendered_config_file

  config_source_file="$(project_template_file "$repo" "$project_name")"
  config_override_file="$(project_override_file "$repo" "$project_name")"
  rendered_config_file="$(mktemp "${TMPDIR:-/tmp}/twf-install-${project_name}-XXXXXX")"

  if ! render_project_config_for_start "$config_source_file" "$config_override_file" "$rendered_config_file"; then
    rm -f "$rendered_config_file"
    echo ""
    return 1
  fi

  local root
  root="$(read_rendered_config_root "$rendered_config_file")"
  rm -f "$rendered_config_file"
  echo "$root"
}

collect_project_dependency_commands() {
  local project_root="$1"
  PROJECT_DEP_COMMANDS=()
  PROJECT_DEP_LABELS=()

  if [[ -f "$project_root/package.json" ]]; then
    PROJECT_DEP_COMMANDS+=("npm install")
    PROJECT_DEP_LABELS+=("npm install")
  fi

  if [[ -f "$project_root/requirements.txt" ]]; then
    PROJECT_DEP_COMMANDS+=("pip3 install -r requirements.txt")
    PROJECT_DEP_LABELS+=("pip3 install -r requirements.txt")
  fi

  if [[ -f "$project_root/Gemfile" ]]; then
    PROJECT_DEP_COMMANDS+=("bundle install")
    PROJECT_DEP_LABELS+=("bundle install")
  fi

  if [[ -f "$project_root/go.mod" ]]; then
    PROJECT_DEP_COMMANDS+=("go mod download")
    PROJECT_DEP_LABELS+=("go mod download")
  fi
}

run_project_dependency_commands() {
  local project_root="$1"
  local idx=0
  local total=${#PROJECT_DEP_COMMANDS[@]}

  if [[ "$total" -eq 0 ]]; then
    info "No project dependency installers detected"
    return 0
  fi

  echo "[install] Running project dependency installers"
  local command=""
  local label=""
  for ((idx = 0; idx < total; idx++)); do
    command="${PROJECT_DEP_COMMANDS[$idx]}"
    label="${PROJECT_DEP_LABELS[$idx]}"
    echo "[install] ($((idx + 1))/$total) $label"
    if ! (cd "$project_root" && eval "$command"); then
      error "INSTALL-201 Project dependency install failed: $label"
      return 1
    fi
  done

  ok "Project dependencies installed"
  return 0
}

parse_service_project_args() {
  local usage="$1"
  shift

  PARSED_SERVICE_NAME=""
  PARSED_PROJECT_NAME=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
    --project)
      [[ $# -ge 2 ]] || {
        error "--project requires a project name"
        exit 1
      }
      PARSED_PROJECT_NAME="$2"
      shift 2
      ;;
    *)
      if [[ -z "$PARSED_SERVICE_NAME" ]]; then
        PARSED_SERVICE_NAME="$1"
        shift
      else
        error "Unexpected argument: $1"
        exit 1
      fi
      ;;
    esac
  done

  [[ -n "$PARSED_SERVICE_NAME" ]] || {
    error "Missing service name"
    info "$usage"
    exit 1
  }
  if [[ -z "$PARSED_PROJECT_NAME" ]]; then
    PARSED_PROJECT_NAME="$(infer_start_project_from_context)"
    if [[ -n "$PARSED_PROJECT_NAME" ]]; then
      info "No --project provided; inferred '$PARSED_PROJECT_NAME'"
    fi
  fi

  [[ -n "$PARSED_PROJECT_NAME" ]] || {
    error "Missing project context"
    info "$usage"
    info "Tip: run from a linked project repo or pass --project <name>"
    exit 1
  }
}

parse_service_scope_args() {
  local usage="$1"
  local allow_yes="$2"
  shift 2

  PARSED_PROJECT_NAME=""
  PARSED_GLOBAL=false
  PARSED_ASSUME_YES=false

  while [[ $# -gt 0 ]]; do
    case "$1" in
    --project)
      [[ $# -ge 2 ]] || {
        error "--project requires a project name"
        exit 1
      }
      PARSED_PROJECT_NAME="$2"
      shift 2
      ;;
    --global)
      PARSED_GLOBAL=true
      shift
      ;;
    --yes)
      if [[ "$allow_yes" == true ]]; then
        PARSED_ASSUME_YES=true
        shift
      else
        error "Unexpected argument: --yes"
        exit 1
      fi
      ;;
    *)
      error "Unexpected argument: $1"
      info "$usage"
      exit 1
      ;;
    esac
  done

  if [[ -n "$PARSED_PROJECT_NAME" && "$PARSED_GLOBAL" == true ]]; then
    error "Use either --project or --global, not both"
    exit 1
  fi

  if [[ -z "$PARSED_PROJECT_NAME" && "$PARSED_GLOBAL" != true ]]; then
    PARSED_PROJECT_NAME="$(infer_start_project_from_context)"
    if [[ -n "$PARSED_PROJECT_NAME" ]]; then
      info "No --project provided; inferred '$PARSED_PROJECT_NAME'"
    fi
  fi
}

cmd_service_add() {
  parse_service_project_args "Usage: twf service add <service> [--project <project>]" "$@"
  validate_project_name "$PARSED_PROJECT_NAME"
  require_service "$PARSED_SERVICE_NAME"

  local repo
  repo="$(require_workflow_repo)"
  ensure_project_exists "$repo" "$PARSED_PROJECT_NAME"

  add_service_to_project_config "$repo" "$PARSED_PROJECT_NAME" "$PARSED_SERVICE_NAME"
  ok "Added service '$PARSED_SERVICE_NAME' to project '$PARSED_PROJECT_NAME'"
  local inferred_project
  inferred_project="$(infer_start_project_from_context)"
  if [[ "$inferred_project" == "$PARSED_PROJECT_NAME" ]]; then
    info "Run: twf service install"
  else
    info "Run: twf service install --project $PARSED_PROJECT_NAME"
  fi
}

cmd_service_remove() {
  parse_service_project_args "Usage: twf service remove <service> [--project <project>]" "$@"
  validate_project_name "$PARSED_PROJECT_NAME"

  local repo
  repo="$(require_workflow_repo)"
  ensure_project_exists "$repo" "$PARSED_PROJECT_NAME"

  remove_service_from_project_config "$repo" "$PARSED_PROJECT_NAME" "$PARSED_SERVICE_NAME"
  ok "Removed service '$PARSED_SERVICE_NAME' from project '$PARSED_PROJECT_NAME'"
}

cmd_service_list() {
  parse_service_scope_args "Usage: twf service list [--project <project> | --global]" false "$@"

  echo "Available services:"
  local available=()
  local p=""
  while IFS= read -r p; do
    [[ -n "$p" ]] || continue
    available+=("$p")
    echo "  - $p"
  done < <(list_available_services)
  if [[ ${#available[@]} -eq 0 ]]; then
    echo "  (none)"
  fi

  if [[ -z "$PARSED_PROJECT_NAME" && "$PARSED_GLOBAL" != true ]]; then
    return 0
  fi

  local repo
  repo="$(require_workflow_repo)"

  if [[ -n "$PARSED_PROJECT_NAME" ]]; then
    validate_project_name "$PARSED_PROJECT_NAME"
    ensure_project_exists "$repo" "$PARSED_PROJECT_NAME"
    echo
    echo "Configured services for '$PARSED_PROJECT_NAME':"
    local any=false
    while IFS= read -r p; do
      [[ -n "$p" ]] || continue
      any=true
      echo "  - $p"
    done < <(enabled_services_for_project "$repo" "$PARSED_PROJECT_NAME")
    [[ "$any" == true ]] || echo "  (none)"
    return 0
  fi

  echo
  echo "Configured services by project:"
  local proj=""
  while IFS= read -r proj; do
    [[ -n "$proj" ]] || continue
    echo "- $proj"
    local any=false
    while IFS= read -r p; do
      [[ -n "$p" ]] || continue
      any=true
      echo "    - $p"
    done < <(enabled_services_for_project "$repo" "$proj")
    [[ "$any" == true ]] || echo "    (none)"
  done < <(list_projects_in_repo "$repo")
}

cmd_service_install() {
  parse_service_scope_args "Usage: twf service install [--project <project>] [--yes] | --global [--yes]" true "$@"

  if [[ -z "$PARSED_PROJECT_NAME" && "$PARSED_GLOBAL" != true ]]; then
    error "Missing scope: use --project <name>, --global, or run from a linked project repo"
    exit 1
  fi

  local repo
  repo="$(require_workflow_repo)"

  if [[ -n "$PARSED_PROJECT_NAME" ]]; then
    validate_project_name "$PARSED_PROJECT_NAME"
    run_service_install_for_project "$repo" "$PARSED_PROJECT_NAME" "$PARSED_ASSUME_YES"
    return 0
  fi

  local proj=""
  while IFS= read -r proj; do
    [[ -n "$proj" ]] || continue
    run_service_install_for_project "$repo" "$proj" "$PARSED_ASSUME_YES"
  done < <(list_projects_in_repo "$repo")
}

cmd_service_help() {
  cat <<'EOF'
Usage: twf service <command> [options]

Commands:
  add <service> [--project <project>]
  remove <service> [--project <project>]
  list [--project <project> | --global]
  install [--project <project>] [--yes]
  install --global [--yes]
EOF
}

cmd_service() {
  local subcommand="${1:-}"
  shift || true

  case "$subcommand" in
  add)
    cmd_service_add "$@"
    ;;
  remove)
    cmd_service_remove "$@"
    ;;
  list)
    cmd_service_list "$@"
    ;;
  install)
    cmd_service_install "$@"
    ;;
  help | -h | --help | "")
    cmd_service_help
    ;;
  *)
    error "Unknown service subcommand: $subcommand"
    info "Run: twf service --help"
    exit 1
    ;;
  esac
}

