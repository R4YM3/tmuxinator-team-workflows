cmd_doctor() {
  local project_name=""
  local global_mode=false
  local fix_mode=false
  local assume_yes=false

  while [[ $# -gt 0 ]]; do
    case "$1" in
    --project)
      [[ $# -ge 2 ]] || {
        error "--project requires a project name"
        exit 1
      }
      project_name="$2"
      shift 2
      ;;
    --global)
      global_mode=true
      shift
      ;;
    --fix)
      fix_mode=true
      shift
      ;;
    --yes)
      assume_yes=true
      shift
      ;;
    -h | --help)
      cat <<'EOF'
Usage: twf doctor [--project <project> | --global] [--fix] [--yes]

Diagnoses runtime and service readiness.
Use --fix to run safe automatic service installs.
EOF
      return 0
      ;;
    *)
      error "Unexpected argument: $1"
      exit 1
      ;;
    esac
  done

  if [[ -n "$project_name" && "$global_mode" == true ]]; then
    error "Use either --project or --global, not both"
    exit 1
  fi

  local workflow_repo
  workflow_repo="$(detect_workflow_repo)"

  if [[ -z "$project_name" && "$global_mode" != true ]]; then
    project_name="$(infer_start_project_from_context)"
    if [[ -n "$project_name" ]]; then
      info "No --project provided; inferred '$project_name'"
    fi
  fi

  echo "[twf doctor] Running diagnostics"
  echo

  local tmux_ok=false
  local tmuxinator_ok=false
  local ruby_ok=false

  command -v tmux >/dev/null 2>&1 && tmux_ok=true
  command -v tmuxinator >/dev/null 2>&1 && tmuxinator_ok=true
  command -v ruby >/dev/null 2>&1 && ruby_ok=true

  echo "[twf doctor] Runtime"
  [[ "$tmux_ok" == true ]] && echo "✔ tmux -> installed" || echo "⚠ tmux -> missing"
  [[ "$tmuxinator_ok" == true ]] && echo "✔ tmuxinator -> installed" || echo "⚠ tmuxinator -> missing"
  [[ "$ruby_ok" == true ]] && echo "✔ ruby -> installed" || echo "⚠ ruby -> missing"
  echo

  local projects=()
  local proj=""

  if [[ -z "$workflow_repo" ]]; then
    warn "No team workflow root configured; skipping project diagnostics"
    return 0
  fi

  if [[ "$global_mode" == true ]]; then
    while IFS= read -r proj; do
      [[ -n "$proj" ]] || continue
      projects+=("$proj")
    done < <(list_projects_in_repo "$workflow_repo")
  elif [[ -n "$project_name" ]]; then
    validate_project_name "$project_name"
    projects+=("$project_name")
  else
    error "No project context found"
    info "Run from a linked project repo, or pass --project <name> or --global"
    exit 1
  fi

  local fix_candidates=()
  local any_issue=false
  local project

  echo "[twf doctor] Projects"
  for project in "${projects[@]}"; do
    ensure_project_exists "$workflow_repo" "$project"
    echo "- $project"

    load_enabled_services_for_project "$workflow_repo" "$project"
    if [[ ${#LOADED_PROJECT_SERVICES[@]} -eq 0 ]]; then
      echo "  - (no services configured)"
      echo
      continue
    fi

    local service
    local project_needs_fix=false
    for service in "${LOADED_PROJECT_SERVICES[@]}"; do
      require_service "$service"
      build_service_state_context "$workflow_repo" "$project" "$service"

      local check_rc=0
      set +e
      run_service_check_with_timeout "$SERVICE_CTX_SCRIPT" "$SERVICE_CTX_CONFIG_JSON" "$SERVICE_CHECK_TIMEOUT_SEC"
      check_rc=$?
      set -e

      if [[ "$check_rc" -eq 0 ]]; then
        echo "  ✔ $service -> ready"
      elif [[ "$check_rc" -eq 124 ]]; then
        any_issue=true
        project_needs_fix=true
        echo "  ⚠ $service -> check timed out (${SERVICE_CHECK_TIMEOUT_SEC}s)"
      else
        any_issue=true
        project_needs_fix=true
        echo "  ⚠ $service -> missing or not ready"
      fi
    done

    if [[ "$project_needs_fix" == true ]]; then
      fix_candidates+=("$project")
    fi

    echo
  done

  if [[ "$any_issue" == true ]]; then
    echo "[twf doctor] Fix suggestions"
    local seen=""
    local p
    for p in "${fix_candidates[@]}"; do
      if [[ ",${seen}," != *",$p,"* ]]; then
        echo "- twf service install --project $p"
        seen="${seen},$p"
      fi
    done
    echo "- twf doctor --project <project>"
  else
    echo "[twf doctor] ✔ All checked services are ready"
  fi

  if [[ "$fix_mode" == true && ${#fix_candidates[@]} -gt 0 ]]; then
    if [[ "$assume_yes" != true ]]; then
      if ! confirm_remove "Run safe service installs for suggested projects?"; then
        info "Skipped automatic fixes"
        return 0
      fi
    fi

    local seen=""
    local p
    for p in "${fix_candidates[@]}"; do
      if [[ ",${seen}," == *",$p,"* ]]; then
        continue
      fi
      seen="${seen},$p"
      info "Applying fixes for project '$p'"
      run_service_install_for_project "$workflow_repo" "$p" "$assume_yes"
    done
    ok "Doctor fix run completed"
  fi
}

cmd_install() {
  local project_name=""
  local assume_yes=false

  while [[ $# -gt 0 ]]; do
    case "$1" in
    --project)
      [[ $# -ge 2 ]] || {
        error "--project requires a project name"
        exit 1
      }
      project_name="$2"
      shift 2
      ;;
    --yes)
      assume_yes=true
      shift
      ;;
    -h | --help)
      cat <<'EOF'
Usage: twf install [--project <project>] [--yes]

Installs machine readiness requirements and project dependencies.
EOF
      return 0
      ;;
    *)
      error "Unexpected argument: $1"
      info "Usage: twf install [--project <project>] [--yes]"
      exit 1
      ;;
    esac
  done

  if [[ -z "$project_name" ]]; then
    project_name="$(infer_start_project_from_context)"
    if [[ -n "$project_name" ]]; then
      info "No --project provided; inferred '$project_name'"
    fi
  fi

  if [[ -z "$project_name" ]]; then
    error "Missing project name"
    info "Usage: twf install [--project <project>] [--yes]"
    info "Tip: run from a linked project repo or pass --project <name>"
    exit 1
  fi

  validate_project_name "$project_name"

  local workflow_repo
  workflow_repo="$(require_workflow_repo)"
  ensure_project_exists "$workflow_repo" "$project_name"

  echo "[plan] Install scope: machine readiness + project dependencies"
  report_service_readiness_for_start "$workflow_repo" "$project_name"
  collect_install_candidates_for_project

  local selected_services=()
  if [[ ${#INSTALL_CANDIDATES[@]} -eq 0 ]]; then
    ok "Machine readiness already satisfied"
  else
    local formatted_missing=()
    local formatted_candidates=()
    local service=""

    for service in "${START_MISSING_SERVICES[@]-}"; do
      [[ -n "$service" ]] || continue
      formatted_missing+=("$(service_requirement_label "$service")")
    done
    for service in "${INSTALL_CANDIDATES[@]}"; do
      [[ -n "$service" ]] || continue
      formatted_candidates+=("$(service_requirement_label "$service")")
    done

    if [[ ${#START_MISSING_SERVICES[@]-0} -gt 0 ]]; then
      echo "[check] Missing machine requirements: ${formatted_missing[*]}"
    fi
    if [[ ${#START_TIMEOUT_SERVICES[@]-0} -gt 0 || ${#START_FAILED_SERVICES[@]-0} -gt 0 ]]; then
      echo "[check] Requirements needing verification: ${formatted_candidates[*]}"
    fi

    if [[ "$assume_yes" == true ]]; then
      selected_services=("${INSTALL_CANDIDATES[@]}")
      info "Non-interactive mode enabled (--yes); installing selected requirements"
    elif ! is_interactive_terminal; then
      selected_services=("${INSTALL_CANDIDATES[@]}")
      info "No interactive terminal detected; installing selected requirements"
    else
      if confirm_default_yes "Install suggested requirements now?"; then
        selected_services=("${INSTALL_CANDIDATES[@]}")
      else
        if select_requirements_with_checkboxes "${INSTALL_CANDIDATES[@]}"; then
          selected_services=("${CHECKBOX_SELECTED[@]}")
        else
          warn "Installation canceled by user"
          selected_services=()
        fi
      fi
    fi

    install_selected_services_for_project "$workflow_repo" "$project_name" "$assume_yes" "${selected_services[@]}" || true
  fi

  report_service_readiness_for_start "$workflow_repo" "$project_name"
  if [[ ${#START_MISSING_SERVICES[@]-0} -gt 0 || ${#START_TIMEOUT_SERVICES[@]-0} -gt 0 || ${#START_FAILED_SERVICES[@]-0} -gt 0 ]]; then
    warn "Machine readiness is still incomplete; project runtime may be degraded"
  fi

  local project_root
  project_root="$(project_root_for_project "$workflow_repo" "$project_name")"
  if [[ -z "$project_root" || ! -d "$project_root" ]]; then
    error "INSTALL-301 Could not resolve project root from workflow config"
    return 1
  fi

  collect_project_dependency_commands "$project_root"

  local install_project_dependencies=false
  if [[ ${#PROJECT_DEP_COMMANDS[@]} -eq 0 ]]; then
    info "No project dependency installers detected"
  elif [[ "$assume_yes" == true ]]; then
    install_project_dependencies=true
  elif ! is_interactive_terminal; then
    install_project_dependencies=true
  elif confirm_default_yes "Install project dependencies now?"; then
    install_project_dependencies=true
  fi

  if [[ "$install_project_dependencies" == true ]]; then
    run_project_dependency_commands "$project_root"
  else
    warn "Project dependency install skipped"
    info "Run: twf install --project $project_name"
  fi

  ok "Install flow completed for '$project_name'"
}

cmd_update() {
  if ! command -v git >/dev/null 2>&1; then
    error "git is required for twf update"
    exit 1
  fi

  if ! git -C "$RUNTIME_DIR" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    error "twf update requires a git checkout at: $RUNTIME_DIR"
    exit 1
  fi

  info "Updating twf runtime repo at $RUNTIME_DIR"
  git -C "$RUNTIME_DIR" pull --ff-only

  local bin_dir="${TWF_BIN_DIR:-$DEFAULT_TWF_BIN_DIR}"
  mkdir -p "$bin_dir"
  ln -sfn "$RUNTIME_DIR/twf" "$bin_dir/twf"
  ok "Refreshed CLI symlink: $bin_dir/twf"
  ensure_bin_on_path "$bin_dir"
  ok "Update complete"
}

cmd_list() {
  local repo
  repo="$(read_configured_workflow_root)"
  if [[ -z "$repo" || ! -d "$repo" ]]; then
    info "No team workflow root configured."
    info "Run: twf add <project-name>"
    echo
  else
    echo "Team workflows ($repo):"
    local found=false
    local project_name=""
    while IFS= read -r project_name; do
      [[ -n "$project_name" ]] || continue
      found=true
      echo "  - $project_name"
    done < <(list_projects_in_repo "$repo")
    [[ "$found" == true ]] || echo "  (none)"
    echo
  fi

  echo "Installed tmuxinator workflows ($TMUXINATOR_DIR):"
  if [[ -d "$TMUXINATOR_DIR" ]]; then
    local installed=()
    local item
    shopt -s nullglob
    installed=("$TMUXINATOR_DIR"/*.yml)
    shopt -u nullglob

    if [[ ${#installed[@]} -eq 0 ]]; then
      echo "  (none)"
    else
      for item in "${installed[@]}"; do
        echo "  - $(basename "${item%.yml}")"
      done
    fi
  else
    echo "  (tmuxinator dir not found)"
  fi
}

cmd_status() {
  local repo
  repo="$(read_configured_workflow_root)"

  echo "Running project sessions:"
  if command -v tmux >/dev/null 2>&1; then
    local sessions
    sessions="$(tmux ls 2>/dev/null || true)"
    if [[ -z "$sessions" ]]; then
      echo "  (none)"
    else
      while IFS= read -r line; do
        [[ -n "$line" ]] || continue
        echo "  - ${line%%:*}"
      done <<<"$sessions"
    fi
  else
    echo "  (tmux not installed)"
  fi

  if [[ -z "$repo" || ! -d "$repo" ]]; then
    echo
    info "No team workflow root configured yet"
    info "Run: twf add <project-name>"
    return 0
  fi

  echo
  echo "Project service health:"
  local proj=""
  local found=false
  while IFS= read -r proj; do
    [[ -n "$proj" ]] || continue
    found=true
    local running="stopped"
    if command -v tmux >/dev/null 2>&1 && tmux has-session -t "$proj" 2>/dev/null; then
      running="running"
    fi
    echo "- $proj ($running)"

    local svc=""
    local any=false
    while IFS= read -r svc; do
      [[ -n "$svc" ]] || continue
      any=true
      require_service "$svc"
      build_service_state_context "$repo" "$proj" "$svc"
      if service_state_matches "$proj" "$svc" "$SERVICE_CTX_VERSION" "$SERVICE_CTX_CONFIG_HASH"; then
        echo "  - $svc: ready"
      else
        echo "  - $svc: needs install"
      fi
    done < <(enabled_services_for_project "$repo" "$proj")
    [[ "$any" == true ]] || echo "  - (no services configured)"
  done < <(list_projects_in_repo "$repo")

  [[ "$found" == true ]] || echo "  (no projects found)"
}

cmd_demo() {
  local target_dir="${1:-$HOME/code/twf-demo}"
  target_dir="$(expand_path "$target_dir")"

  if [[ -e "$target_dir" ]]; then
    error "Demo target already exists: $target_dir"
    info "Pass a custom path: twf demo /path/to/new-folder"
    exit 1
  fi

  if ! command -v git >/dev/null 2>&1; then
    error "git is required for twf demo"
    exit 1
  fi

  mkdir -p "$target_dir"
  info "Creating demo workspace at $target_dir"

  git clone --depth 1 "https://github.com/vercel/next-learn.git" "$target_dir/web" >/dev/null 2>&1 || {
    error "Failed to clone Next.js demo repository"
    exit 1
  }

  mkdir -p "$target_dir/api"
  cat >"$target_dir/api/package.json" <<'EOF'
{
  "name": "twf-demo-api",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node server.js"
  },
  "dependencies": {
    "express": "^4.19.2"
  }
}
EOF
  cat >"$target_dir/api/server.js" <<'EOF'
import express from "express"

const app = express()
const port = process.env.PORT || 4000

app.get("/health", (_req, res) => {
  res.json({ status: "ok" })
})

app.listen(port, () => {
  console.log(`Demo API listening on http://localhost:${port}`)
})
EOF

  local old_pwd
  old_pwd="$PWD"
  cd "$target_dir"
  cmd_add twf-demo
  local workflow_repo
  workflow_repo="$(require_workflow_repo)"
  local demo_project_file
  demo_project_file="$(project_template_file "$workflow_repo" "twf-demo")"
  local demo_override_file
  demo_override_file="$(project_override_file "$workflow_repo" "twf-demo")"

  cat >"$demo_project_file" <<EOF
name: twf-demo
root: "$target_dir"

startup_window: web

windows:
  - web:
      root: ./web
      layout: main-vertical
      panes:
        - editor: 'nvim'
        - server: 'npm run dev || zsh -l'

  - api:
      root: ./api
      layout: main-vertical
      panes:
        - editor: 'nvim'
        - server: 'npm install && npm run dev || zsh -l'

  - twf:
      root: ./.twf
      panes:
        - 'nvim || zsh -l'
EOF

  cat >"$demo_override_file" <<'EOF'
services:
  enabled:
    - web
    - api
  config: {}
EOF

  cd "$old_pwd"

  ok "Demo project created"
  info "Try it now:"
  echo "  cd \"$target_dir\""
  echo "  twf service install --project twf-demo"
  echo "  twf start twf-demo"
}

sanitize_tmux_env() {
  if [[ -n "${TMUX:-}" ]]; then
    if ! tmux display-message -p '#{client_tty}' >/dev/null 2>&1; then
      unset TMUX
    fi
  fi
}

start_requested_no_attach() {
  local arg
  for arg in "$@"; do
    case "$arg" in
    --no-attach | --skip-attach)
      return 0
      ;;
    esac
  done
  return 1
}

render_project_config_for_start() {
  local source_file="$1"
  local override_file="$2"
  local rendered_file="$3"

  ruby -rerb -ryaml -e '
def load_yaml_with_erb(path)
  source = File.read(path)
  rendered = ERB.new(source, trim_mode: "-").result(binding)
  data = YAML.safe_load(rendered, aliases: true)
  data.is_a?(Hash) ? data : {}
end

def deep_merge_hash(base, override)
  out = base.dup
  override.each do |k, v|
    if out[k].is_a?(Hash) && v.is_a?(Hash)
      out[k] = deep_merge_hash(out[k], v)
    else
      out[k] = v
    end
  end
  out
end

project_file = ARGV[0]
override_file = ARGV[1]

project_data = load_yaml_with_erb(project_file)
override_data = File.exist?(override_file) ? load_yaml_with_erb(override_file) : {}
override_data.delete("services")

merged = deep_merge_hash(project_data, override_data)
puts merged.to_yaml(line_width: -1)
' "$source_file" "$override_file" >"$rendered_file"
}

read_rendered_config_root() {
  local config_file="$1"
  ruby -ryaml -e 'data = YAML.safe_load(File.read(ARGV[0]), aliases: true); value = data.is_a?(Hash) ? data["root"] : nil; puts(value.is_a?(String) ? value : "")' "$config_file" 2>/dev/null || true
}

run_service_check_with_timeout() {
  local service_script="$1"
  local service_config_json="$2"
  local timeout_sec="$3"

  TWF_SERVICE_CONFIG_JSON="$service_config_json" python3 - "$service_script" "$timeout_sec" <<'PY'
import os
import subprocess
import sys

script = sys.argv[1]
timeout = float(sys.argv[2])
env = os.environ.copy()

try:
    completed = subprocess.run([script, "check"], env=env, timeout=timeout)
    sys.exit(completed.returncode)
except subprocess.TimeoutExpired:
    sys.exit(124)
PY
}

infer_project_from_local_link() {
  local local_link="$PWD/.twf/project.yml"
  [[ -e "$local_link" ]] || {
    echo ""
    return 0
  }

  local resolved
  resolved="$(python3 - "$local_link" <<'PY'
import os
import sys
print(os.path.realpath(sys.argv[1]))
PY
  )"

  if [[ "$resolved" == */project.yml ]]; then
    basename "$(dirname "$resolved")"
    return 0
  fi

  echo ""
}

infer_start_project_from_context() {
  local linked_project
  linked_project="$(infer_project_from_local_link)"
  if [[ -n "$linked_project" ]]; then
    echo "$linked_project"
    return 0
  fi

  local cwd_name
  cwd_name="$(basename "$PWD")"

  local repo
  repo="$(read_configured_workflow_root)"
  if [[ -z "$repo" ]]; then
    echo ""
    return 0
  fi

  if [[ -f "$(project_template_file "$repo" "$cwd_name")" ]]; then
    echo "$cwd_name"
    return 0
  fi

  local only=""
  local count=0
  local name=""
  while IFS= read -r name; do
    [[ -n "$name" ]] || continue
    count=$((count + 1))
    only="$name"
  done < <(list_projects_in_repo "$repo")

  if [[ "$count" -eq 1 ]]; then
    echo "$only"
    return 0
  fi

  echo ""
}

cmd_start() {
  local project_name=""
  local strict_mode=false
  local start_args=()

  if [[ $# -eq 0 || "${1:-}" == -* ]]; then
    if [[ "${1:-}" == "--project" ]]; then
      error "Invalid option for twf start: --project"
      info "Usage: twf start <project-name> [tmuxinator args...] [--strict]"
      info "Tip: use 'twf start test-repo' or run from that repo and use 'twf start'"
      exit 1
    fi

    project_name="$(infer_start_project_from_context)"
    if [[ -z "$project_name" ]]; then
      error "Missing project name and could not infer one from current directory"
      info "Usage: twf start <project-name> [tmuxinator args...] [--strict]"
      info "Tip: run from your project repo and use 'twf start', or pass project explicitly"
      exit 1
    fi

    info "No project name provided; inferred '$project_name'"
  else
    project_name="$1"
    shift
  fi

  local arg
  for arg in "$@"; do
    case "$arg" in
    --strict)
      strict_mode=true
      ;;
    *)
      start_args+=("$arg")
      ;;
    esac
  done

  local workflow_repo=""
  local config_source_file=""
  local config_override_file=""
  local rendered_config_file=""
  local tmuxinator_status=0
  local had_session_before=false

  echo "[twf] Project: $project_name"

  if tmux has-session -t "$project_name" 2>/dev/null; then
    had_session_before=true
  fi

  if ! command -v tmuxinator >/dev/null 2>&1; then
    error "tmuxinator is not installed or not on PATH"
    exit 1
  fi

  workflow_repo="$(detect_workflow_repo)"
  if [[ -z "$workflow_repo" ]]; then
    error "No team workflow root is configured"
    info "Run: twf add $project_name"
    exit 1
  fi

  config_source_file="$(project_template_file "$workflow_repo" "$project_name")"
  if [[ ! -f "$config_source_file" ]]; then
    error "Project template not found for '$project_name': $config_source_file"
    info "Add the project first with: twf add $project_name"
    exit 1
  fi

  echo "[twf] Loading services..."
  echo "[twf] Applying developer overrides..."
  echo "[twf] Checking dependencies..."
  report_service_readiness_for_start "$workflow_repo" "$project_name"

  if [[ ${#START_MISSING_SERVICES[@]-0} -gt 0 || ${#START_TIMEOUT_SERVICES[@]-0} -gt 0 || ${#START_FAILED_SERVICES[@]-0} -gt 0 ]]; then
    echo
    local inferred_project
    inferred_project="$(infer_start_project_from_context)"
    if [[ ${#START_MISSING_SERVICES[@]-0} -gt 0 ]]; then
      if [[ "$inferred_project" == "$project_name" ]]; then
        echo "[twf] Run: twf install"
      else
        echo "[twf] Run: twf install --project $project_name"
      fi
    fi
    if [[ ${#START_TIMEOUT_SERVICES[@]-0} -gt 0 || ${#START_FAILED_SERVICES[@]-0} -gt 0 ]]; then
      if [[ "$inferred_project" == "$project_name" ]]; then
        echo "[twf] Run: twf doctor"
      else
        echo "[twf] Run: twf doctor --project $project_name"
      fi
    fi
    if [[ "$strict_mode" == true ]]; then
      error "Missing required services for '$project_name' (strict mode enabled)"
      return 1
    fi
    warn "RUNTIME-401 Project may not work as expected until missing requirements are installed"
  fi

  config_override_file="$(project_override_file "$workflow_repo" "$project_name")"
  rendered_config_file="$(mktemp "${TMPDIR:-/tmp}/twf-${project_name}-XXXXXX")"

  if ! render_project_config_for_start "$config_source_file" "$config_override_file" "$rendered_config_file"; then
    rm -f "$rendered_config_file"
    error "Failed to render workflow template for '$project_name'"
    return 1
  fi

  local rendered_root
  rendered_root="$(read_rendered_config_root "$rendered_config_file")"
  if [[ -n "$rendered_root" && -d "$rendered_root" ]]; then
    ensure_local_workflow_link "$project_name" "$(project_dir "$workflow_repo" "$project_name")" "$rendered_root" true
  fi

  sanitize_tmux_env
  echo "[twf] Starting workflow..."
  set +e
  (
    cd "$workflow_repo"
    if [[ ${#start_args[@]} -gt 0 ]]; then
      tmuxinator start -p "$rendered_config_file" "${start_args[@]}"
    else
      tmuxinator start -p "$rendered_config_file"
    fi
  )
  tmuxinator_status=$?
  set -e
  rm -f "$rendered_config_file"
  if [[ "$tmuxinator_status" -ne 0 ]] && [[ "$had_session_before" == false ]] && tmux has-session -t "$project_name" 2>/dev/null; then
    if [[ ${#start_args[@]} -gt 0 ]] && start_requested_no_attach "${start_args[@]}"; then
      return 0
    fi
    warn "Workflow session '$project_name' started, but auto-attach failed"
    info "Attach manually: tmux attach-session -t $project_name"
    return 0
  fi
  if [[ "$tmuxinator_status" -eq 0 ]]; then
    echo "✔ Session started"
  fi
  return "$tmuxinator_status"
}

cmd_stop() {
  local project_name="${1:-}"

  if [[ -z "$project_name" || "$project_name" == -* ]]; then
    project_name="$(infer_start_project_from_context)"
    if [[ -z "$project_name" ]]; then
      error "Missing project name"
      info "Usage: twf stop <project-name>"
      exit 1
    fi
    info "No project name provided; inferred '$project_name'"
  fi

  if ! command -v tmux >/dev/null 2>&1; then
    error "tmux is not installed or not on PATH"
    exit 1
  fi

  if tmux has-session -t "$project_name" 2>/dev/null; then
    tmux kill-session -t "$project_name"
    ok "Stopped tmux session: $project_name"
  else
    info "No running tmux session found: $project_name"
  fi
}

cmd_uninstall() {
  local assume_yes=false
  local arg

  for arg in "$@"; do
    case "$arg" in
    --yes)
      assume_yes=true
      ;;
    -h | --help)
      cat <<'EOF'
Usage: twf uninstall [--yes]

Removes global twf CLI installation (symlink and install root).
This does not remove tmuxinator project aliases.
EOF
      return 0
      ;;
    *)
      error "Unknown option for uninstall: $arg"
      info "Usage: twf uninstall [--yes]"
      exit 1
      ;;
    esac
  done

  local bin_dir="${TWF_BIN_DIR:-$DEFAULT_TWF_BIN_DIR}"
  local install_root="${TWF_INSTALL_ROOT:-$DEFAULT_TWF_HOME}"
  local symlink_path="$bin_dir/twf"

  if [[ -L "$symlink_path" || -f "$symlink_path" ]]; then
    rm -f "$symlink_path"
    ok "Removed CLI link: $symlink_path"
  else
    info "CLI link not found: $symlink_path"
  fi

  if [[ ! -d "$install_root" ]]; then
    info "Install root not found: $install_root"
    return 0
  fi

  local can_remove_root=false
  if [[ -f "$install_root/twf" && -f "$install_root/scripts/bootstrap.sh" ]]; then
    can_remove_root=true
  fi

  if [[ "$can_remove_root" != true ]]; then
    warn "Install root does not look like a twf install: $install_root"
    warn "Skipping removal for safety"
    return 0
  fi

  local remove_root=false
  if [[ "$assume_yes" == true ]]; then
    remove_root=true
  else
    if confirm_remove "Remove install root '$install_root'?"; then
      remove_root=true
    fi
  fi

  if [[ "$remove_root" == true ]]; then
    rm -rf "$install_root"
    ok "Removed install root: $install_root"
  else
    info "Kept install root: $install_root"
  fi
}

main() {
  local command="${1:-help}"
  shift || true

  case "$command" in
  help | -h | --help)
    cmd_help "$@"
    ;;
  version | -v | --version)
    version
    ;;
  add)
    cmd_add "$@"
    ;;
  remove)
    cmd_remove "$@"
    ;;
  service)
    cmd_service "$@"
    ;;
  demo)
    cmd_demo "$@"
    ;;
  status)
    cmd_status "$@"
    ;;
  validate)
    cmd_validate "$@"
    ;;
  doctor)
    cmd_doctor "$@"
    ;;
  update)
    cmd_update "$@"
    ;;
  install)
    cmd_install "$@"
    ;;
  list)
    cmd_list "$@"
    ;;
  start)
    cmd_start "$@"
    ;;
  stop)
    cmd_stop "$@"
    ;;
  uninstall)
    cmd_uninstall "$@"
    ;;
  *)
    error "Unknown command: $command"
    local suggestion
    suggestion="$(closest_command "$command")"
    if [[ -n "$suggestion" ]]; then
      info "Did you mean: twf $suggestion"
    fi
    usage_quick
    exit 1
    ;;
  esac
}

main "$@"
