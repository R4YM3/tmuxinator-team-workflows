#!/usr/bin/env bash
set -euo pipefail

SCRIPT_PATH="${BASH_SOURCE[0]}"
while [[ -L "$SCRIPT_PATH" ]]; do
  SCRIPT_DIR="$(cd -P "$(dirname "$SCRIPT_PATH")" && pwd)"
  SCRIPT_PATH="$(readlink "$SCRIPT_PATH")"
  [[ "$SCRIPT_PATH" == /* ]] || SCRIPT_PATH="$SCRIPT_DIR/$SCRIPT_PATH"
done

RUNTIME_DIR="$(cd -P "$(dirname "$SCRIPT_PATH")" && pwd)"
DEFAULT_OO_HOME="${HOME}/.local/share/oo"
DEFAULT_OO_BIN_DIR="${HOME}/.local/bin"
TMUXINATOR_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/tmuxinator"
OO_CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/oo"
OO_CONFIG_FILE="$OO_CONFIG_DIR/config.yml"
SERVICES_DIR="$RUNTIME_DIR/services"
SERVICE_STATE_ROOT="${XDG_DATA_HOME:-$HOME/.local/share}/oo/state/services"
SERVICE_CHECK_TIMEOUT_SEC="${OO_SERVICE_CHECK_TIMEOUT_SEC:-4.0}"

START_MISSING_SERVICES=()
START_TIMEOUT_SERVICES=()
START_FAILED_SERVICES=()
INSTALL_CANDIDATES=()
CHECKBOX_SELECTED=()
PROJECT_DEP_COMMANDS=()
PROJECT_DEP_LABELS=()
INSTALL_WARNING_LINES=()
INSTALL_CHANGED_LINES=()

ok() { printf "\033[1;32m[ok]\033[0m %s\n" "$1"; }
info() { printf "\033[1;34m[info]\033[0m %s\n" "$1"; }
warn() { printf "\033[1;33m[warn]\033[0m %s\n" "$1"; }
error() { printf "\033[1;31m[error]\033[0m %s\n" "$1" >&2; }

error_block() {
  local code="$1"
  local title="$2"
  local reason="$3"
  shift 3

  local context_line=""
  if [[ "${1:-}" == "--context" ]]; then
    context_line="${2:-}"
    shift 2
  fi

  echo "✖ $title ($code)"
  echo
  echo "Reason"
  echo "  $reason"
  if [[ -n "$context_line" ]]; then
    echo
    echo "Context"
    echo "  $context_line"
  fi
  echo
  echo "What you can do"
  local step
  for step in "$@"; do
    echo "  • $step"
  done
}

install_failure_block_with_details() {
  local code="$1"
  local reason="$2"
  local details="$3"
  shift 3

  echo "✖ Install failed ($code)"
  echo
  echo "Reason"
  echo "  $reason"
  if [[ -n "$details" ]]; then
    echo
    echo "Details"
    while IFS= read -r line; do
      [[ -n "$line" ]] || continue
      echo "  $line"
    done <<<"$details"
  fi
  echo
  echo "What you can do"
  local step
  for step in "$@"; do
    echo "  • $step"
  done
}

usage() {
  cat <<'EOF'
Usage: oo <command> [options]

Commands:
  add [workflow-name] [--dry-run] [--no-install]
                               Create a workflow
  remove <workflow-name> [--yes]
                               Remove workflow and alias
  service <command> [...]       Manage reusable services
  demo [target-dir]             Scaffold a working demo workflow
  status                       Show running workflows and service health
  validate                     Validate workflow files
  doctor                       Run environment diagnostics
  install [--workflow <name>] [--yes] [--plan] [--no-workflow-deps] [--verbose]
                               Install machine readiness and workflow dependencies
  update                       Pull latest oo runtime repo
  list                         List workflows and installed aliases
  start <workflow> [args...]    Start a workflow (supports --strict)
  stop <workflow>               Stop a running workflow
  uninstall [--yes]            Remove global oo CLI installation
  version                      Print oo version
  help                         Show this help

Examples:
  oo add my-workflow
  oo add my-workflow --dry-run
  oo add
  oo remove my-workflow
  oo service add node
  oo service install
  oo service add redis --workflow other-workflow
  oo demo
  oo status
  oo validate
  oo doctor
  oo install
  oo install --yes
  oo update
  oo start my-workflow
  oo stop my-workflow
EOF
}

usage_quick() {
  cat <<'EOF'
Usage: oo <command> [options]

Common commands:
  oo add [workflow-name]          Create a workflow
  oo service add <service>       Add service to current workflow
  oo service install             Install services for current workflow
  oo start [workflow]             Start workflow
  oo stop [workflow]              Stop workflow
  oo status                      Show running workflows and health
  oo doctor                      Diagnose issues and show fixes
  oo install                     Install environment setup for workflow

Help:
  oo help                        Show this quick help
  oo help --all                  Show full command reference
  oo help <command>              Show help for a command

Examples:
  oo add
  oo service add web
  oo service install
  oo install
  oo start
EOF
}

closest_command() {
  local needle="$1"
  local commands=(add remove service demo status validate doctor install update list start stop uninstall version help)

  if command -v python3 >/dev/null 2>&1; then
    python3 - "$needle" "${commands[@]}" <<'PY'
import difflib
import sys

needle = sys.argv[1]
commands = sys.argv[2:]
matches = difflib.get_close_matches(needle, commands, n=1, cutoff=0.5)
print(matches[0] if matches else "")
PY
    return 0
  fi

  local cmd

  for cmd in "${commands[@]}"; do
    if [[ "$cmd" == "$needle"* || "$needle" == "$cmd"* ]]; then
      echo "$cmd"
      return 0
    fi
  done

  for cmd in "${commands[@]}"; do
    if [[ "$cmd" == *"$needle"* || "$needle" == *"$cmd"* ]]; then
      echo "$cmd"
      return 0
    fi
  done

  echo ""
}

cmd_help() {
  local topic="${1:-}"

  if [[ -z "$topic" ]]; then
    usage_quick
    return 0
  fi

  case "$topic" in
  --all)
    usage
    ;;
  add | remove | service | doctor | install | uninstall)
    "$0" "$topic" --help
    ;;
  start)
    cat <<'EOF'
Usage: oo start <workflow-name> [tmuxinator args...] [--strict]

Starts a workflow session.
If no workflow is provided, oo tries to infer it from current context.
EOF
    ;;
  stop)
    cat <<'EOF'
Usage: oo stop <workflow-name>

Stops a running workflow session.
If no workflow is provided, oo tries to infer it from current context.
EOF
    ;;
  demo)
    cat <<'EOF'
Usage: oo demo [target-dir]

Scaffolds a demo workspace with web + api services.
EOF
    ;;
  status)
    cat <<'EOF'
Usage: oo status

Shows running workflow sessions and service readiness.
EOF
    ;;
  list)
    cat <<'EOF'
Usage: oo list

Lists team workflows and installed tmuxinator aliases.
EOF
    ;;
  validate)
    cat <<'EOF'
Usage: oo validate

Validates workflow files in the configured team workflow root.
EOF
    ;;
  update)
    cat <<'EOF'
Usage: oo update

Pulls latest oo runtime and refreshes the oo CLI symlink.
EOF
    ;;
  install)
    cat <<'EOF'
Usage: oo install [--workflow <workflow>] [--yes]

Installs machine readiness requirements and workflow dependencies.
If no workflow is provided, oo tries to infer it from current context.
EOF
    ;;
  version)
    version
    ;;
  help)
    usage_quick
    ;;
  *)
    error "Unknown help topic: $topic"
    local suggestion
    suggestion="$(closest_command "$topic")"
    if [[ -n "$suggestion" ]]; then
      info "Did you mean: oo help $suggestion"
    fi
    ;;
  esac
}

version() {
  if command -v git >/dev/null 2>&1 && git -C "$RUNTIME_DIR" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    git -C "$RUNTIME_DIR" describe --tags --always --dirty 2>/dev/null || true
    return 0
  fi

  echo "0.1.0"
}

validate_project_name() {
  local project_name="$1"
  if [[ ! "$project_name" =~ ^[a-z0-9][a-z0-9-]*$ ]]; then
    error "Invalid workflow name: '$project_name'"
    info "Use lowercase letters, numbers, and dashes only (must start with letter or number)."
    exit 1
  fi
}

slugify_workflow_name() {
  local raw_name="$1"
  local slug
  slug="$(printf '%s' "$raw_name" | tr '[:upper:]' '[:lower:]' | sed -E 's/[^a-z0-9]+/-/g; s/^-+//; s/-+$//; s/-+/-/g')"
  if [[ -z "$slug" ]]; then
    slug="workflow"
  fi
  echo "$slug"
}

expand_path() {
  local path="$1"
  if [[ "$path" == ~* ]]; then
    path="${path/#\~/$HOME}"
  fi

  if [[ "$path" != /* ]]; then
    path="$(cd "$PWD" && pwd)/$path"
  fi

  echo "$path"
}

read_configured_workflow_root() {
  if [[ -n "${TEAM_WORKFLOWS_ROOT:-}" ]]; then
    expand_path "$TEAM_WORKFLOWS_ROOT"
    return 0
  fi

  if [[ ! -f "$OO_CONFIG_FILE" ]]; then
    echo ""
    return 0
  fi

  local configured
  configured="$(ruby -ryaml -e 'path = ARGV[0]; raw = YAML.safe_load(File.read(path), aliases: false); data = raw.is_a?(Hash) ? raw : {}; value = data["team_workflows_root"]; puts(value.is_a?(String) ? value : "")' "$OO_CONFIG_FILE" 2>/dev/null || true)"
  if [[ -z "$configured" ]]; then
    echo ""
    return 0
  fi

  expand_path "$configured"
}

save_configured_workflow_root() {
  local root="$1"
  if [[ "$root" == "$RUNTIME_DIR" ]]; then
    error "team workflow root cannot be the oo runtime repository"
    info "Choose a separate directory, e.g. ../team-workflows"
    exit 1
  fi
  mkdir -p "$OO_CONFIG_DIR"
  cat >"$OO_CONFIG_FILE" <<EOF
team_workflows_root: "$root"
EOF
}

default_workflow_root_for_dir() {
  local base="$1"
  echo "$(cd "$base/.." && pwd)/team-workflows"
}

ensure_workflow_root_for_add() {
  local dry_run="${1:-false}"
  local configured
  configured="$(read_configured_workflow_root)"
  if [[ -n "$configured" ]]; then
    if [[ "$configured" == "$RUNTIME_DIR" ]]; then
      error "Configured team workflow root points to oo runtime repository"
      info "Run oo add from your workflow and choose a separate workflow root"
      exit 1
    fi
    echo "$configured"
    return 0
  fi

  local suggested
  suggested="$(default_workflow_root_for_dir "$PWD")"

  if [[ "$dry_run" == true ]]; then
    echo "$suggested"
    return 0
  fi

  if [[ ! -t 0 ]]; then
    mkdir -p "$suggested"
    save_configured_workflow_root "$suggested"
    echo "$suggested"
    return 0
  fi

  echo "No team workflow root configured yet."
  echo "Where should workflows be stored?"
  read -r -p "Path [$suggested]: " configured
  configured="${configured:-$suggested}"
  configured="$(expand_path "$configured")"

  mkdir -p "$configured"
  save_configured_workflow_root "$configured"
  ok "Configured team workflow root: $configured"
  echo "$configured"
}

detect_workflow_repo() {
  local configured
  configured="$(read_configured_workflow_root)"
  if [[ -n "$configured" && -d "$configured" ]]; then
    echo "$configured"
    return 0
  fi

  local linked_project
  linked_project="$(infer_project_from_local_link)"
  if [[ -n "$linked_project" ]]; then
    local local_link="$PWD/.oo/workflow.yaml"
    if [[ ! -e "$local_link" ]]; then
      local_link="$PWD/.oo/workflow.yml"
    fi
    local resolved
    resolved="$(python3 - "$local_link" <<'PY'
import os
import sys
print(os.path.realpath(sys.argv[1]))
PY
    )"
    local repo
    repo="$(dirname "$(dirname "$resolved")")"
    if [[ -d "$repo" ]]; then
      echo "$repo"
      return 0
    fi
  fi

  echo ""
}

require_workflow_repo() {
  local repo
  repo="$(detect_workflow_repo)"
  if [[ -z "$repo" ]]; then
    error "No team workflow root is configured"
    info "Run: oo add <workflow-name>"
    exit 1
  fi
  echo "$repo"
}

service_script_path() {
  local service_name="$1"
  echo "$SERVICES_DIR/$service_name.sh"
}

service_exists() {
  local service_name="$1"
  [[ -f "$(service_script_path "$service_name")" ]]
}

require_service() {
  local service_name="$1"
  if ! service_exists "$service_name"; then
    error "Unknown service: $service_name"
    info "Run 'oo service list' to see available services."
    exit 1
  fi
}

list_available_services() {
  if [[ ! -d "$SERVICES_DIR" ]]; then
    return 0
  fi

  local files=()
  local file
  shopt -s nullglob
  files=("$SERVICES_DIR"/*.sh)
  shopt -u nullglob

  for file in "${files[@]}"; do
    basename "${file%.sh}"
  done
}

hash_text() {
  local value="$1"
  if command -v shasum >/dev/null 2>&1; then
    printf '%s' "$value" | shasum -a 256 | awk '{print $1}'
  elif command -v openssl >/dev/null 2>&1; then
    printf '%s' "$value" | openssl dgst -sha256 | awk '{print $NF}'
  else
    printf '%s' "$value" | cksum | awk '{print $1}'
  fi
}

detect_suggested_services() {
  local source_root="$1"
  local suggestions=()

  has_path_match() {
    local base="$1"
    shift
    local pattern
    for pattern in "$@"; do
      if compgen -G "$base/$pattern" >/dev/null 2>&1; then
        return 0
      fi
    done
    return 1
  }

  if has_path_match "$source_root" \
    "package.json" \
    "pnpm-lock.yaml" \
    "yarn.lock" \
    "npm-shrinkwrap.json" \
    "bun.lockb" \
    "bun.lock" \
    "bunfig.toml" \
    "nx.json" \
    "turbo.json" \
    "lerna.json"; then
    suggestions+=("node")
  fi

  if has_path_match "$source_root" \
    "docker-compose.yml" \
    "docker-compose.yaml" \
    "compose.yml" \
    "compose.yaml" \
    "Dockerfile" \
    "Dockerfile.*" \
    ".devcontainer/devcontainer.json"; then
    suggestions+=("containers")
  fi

  if has_path_match "$source_root" \
    "requirements.txt" \
    "requirements-*.txt" \
    "pyproject.toml" \
    "Pipfile" \
    "poetry.lock" \
    "setup.py" \
    "setup.cfg"; then
    suggestions+=("python")
  fi

  if has_path_match "$source_root" \
    "*.sln" \
    "*.csproj" \
    "global.json"; then
    suggestions+=("dotnet")
  fi

  if has_path_match "$source_root" \
    "redis.conf" \
    "redis/*.conf"; then
    suggestions+=("redis")
  fi

  if has_path_match "$source_root" \
    "pom.xml" \
    "build.gradle" \
    "build.gradle.kts" \
    "settings.gradle" \
    "settings.gradle.kts" \
    "gradlew" \
    "mvnw"; then
    suggestions+=("java")
  fi

  if has_path_match "$source_root" \
    "go.mod" \
    "go.sum" \
    "go.work"; then
    suggestions+=("go")
  fi

  if has_path_match "$source_root" \
    "Gemfile" \
    "Gemfile.lock" \
    ".ruby-version" \
    "Rakefile"; then
    suggestions+=("ruby")
  fi

  if has_path_match "$source_root" \
    "composer.json" \
    "composer.lock" \
    "phpunit.xml" \
    "phpunit.xml.dist"; then
    suggestions+=("php")
  fi

  if has_path_match "$source_root" \
    "Cargo.toml" \
    "Cargo.lock" \
    "rust-toolchain.toml"; then
    suggestions+=("rust")
  fi

  if has_path_match "$source_root" \
    "postgresql.conf" \
    "postgres.conf" \
    "pg_hba.conf"; then
    suggestions+=("postgres")
  fi

  if has_path_match "$source_root" \
    "CMakeLists.txt" \
    "meson.build" \
    "Makefile" \
    "*.c" \
    "*.h"; then
    suggestions+=("c")
  fi

  if has_path_match "$source_root" \
    "CMakeLists.txt" \
    "meson.build" \
    "Makefile" \
    "*.cpp" \
    "*.cc" \
    "*.cxx" \
    "*.hpp" \
    "*.hh" \
    "*.hxx"; then
    suggestions+=("cpp")
  fi

  local seen=","
  local service
  for service in "${suggestions[@]}"; do
    if [[ "$seen" != *",$service,"* ]]; then
      echo "$service"
      seen+="$service,"
    fi
  done
}

project_dir() {
  local repo="$1"
  local project_name="$2"
  echo "$repo/$project_name"
}

project_template_file() {
  local repo="$1"
  local project_name="$2"
  echo "$(project_dir "$repo" "$project_name")/workflow.yaml"
}

project_template_file_legacy_yml() {
  local repo="$1"
  local project_name="$2"
  echo "$(project_dir "$repo" "$project_name")/workflow.yml"
}

resolve_project_template_file() {
  local repo="$1"
  local project_name="$2"
  local yaml_file
  local yml_file
  yaml_file="$(project_template_file "$repo" "$project_name")"
  yml_file="$(project_template_file_legacy_yml "$repo" "$project_name")"

  if [[ -f "$yaml_file" ]]; then
    echo "$yaml_file"
    return 0
  fi

  if [[ -f "$yml_file" ]]; then
    echo "$yml_file"
    return 0
  fi

  echo "$yaml_file"
}

project_override_file() {
  local repo="$1"
  local project_name="$2"
  echo "$(project_dir "$repo" "$project_name")/override.yaml"
}

project_override_file_legacy_yml() {
  local repo="$1"
  local project_name="$2"
  echo "$(project_dir "$repo" "$project_name")/override.yml"
}

resolve_project_override_file() {
  local repo="$1"
  local project_name="$2"
  local yaml_file
  local yml_file
  yaml_file="$(project_override_file "$repo" "$project_name")"
  yml_file="$(project_override_file_legacy_yml "$repo" "$project_name")"

  if [[ -f "$yaml_file" ]]; then
    echo "$yaml_file"
    return 0
  fi

  if [[ -f "$yml_file" ]]; then
    echo "$yml_file"
    return 0
  fi

  echo "$yaml_file"
}

ensure_project_exists() {
  local repo="$1"
  local project_name="$2"
  local template_file
  template_file="$(resolve_project_template_file "$repo" "$project_name")"

  if [[ ! -f "$template_file" ]]; then
    error "Workflow template not found: $template_file"
    info "Add the workflow first: oo add $project_name"
    exit 1
  fi
}

enabled_services_for_project() {
  local repo="$1"
  local project_name="$2"
  local override_file
  override_file="$(resolve_project_override_file "$repo" "$project_name")"

  ruby -ryaml -e '
path = ARGV[0]
if !File.exist?(path)
  exit 0
end
raw = YAML.safe_load(File.read(path), aliases: false)
data = raw.is_a?(Hash) ? raw : {}
services = data["services"].is_a?(Hash) ? data["services"] : {}
enabled = services["enabled"].is_a?(Array) ? services["enabled"] : []
enabled.select { |v| v.is_a?(String) && !v.strip.empty? }.each { |v| puts v }
' "$override_file"
}

service_config_json_for_project() {
  local repo="$1"
  local project_name="$2"
  local service_name="$3"
  local override_file
  override_file="$(resolve_project_override_file "$repo" "$project_name")"

  ruby -ryaml -rjson -e '
path = ARGV[0]
service = ARGV[1]
if !File.exist?(path)
  puts "{}"
  exit 0
end
raw = YAML.safe_load(File.read(path), aliases: false)
data = raw.is_a?(Hash) ? raw : {}
services = data["services"].is_a?(Hash) ? data["services"] : {}
config = services["config"].is_a?(Hash) ? services["config"] : {}
value = config[service]
value = {} unless value.is_a?(Hash)
puts JSON.generate(value)
' "$override_file" "$service_name"
}

add_service_to_project_config() {
  local repo="$1"
  local project_name="$2"
  local service_name="$3"
  local override_file
  override_file="$(project_override_file "$repo" "$project_name")"
  local resolved_override
  resolved_override="$(resolve_project_override_file "$repo" "$project_name")"

  if [[ "$resolved_override" != "$override_file" && -f "$resolved_override" && ! -f "$override_file" ]]; then
    cp "$resolved_override" "$override_file"
  fi

  mkdir -p "$(dirname "$override_file")"
  [[ -f "$override_file" ]] || printf '{}\n' >"$override_file"

  ruby -ryaml -e '
path = ARGV[0]
service = ARGV[1]
raw = YAML.safe_load(File.read(path), aliases: false)
data = raw.is_a?(Hash) ? raw : {}
data["services"] = {} unless data["services"].is_a?(Hash)
services = data["services"]
services["enabled"] = [] unless services["enabled"].is_a?(Array)
enabled = services["enabled"].select { |v| v.is_a?(String) && !v.strip.empty? }
enabled << service unless enabled.include?(service)
services["enabled"] = enabled
File.write(path, data.to_yaml(line_width: -1))
' "$override_file" "$service_name"
}

remove_service_from_project_config() {
  local repo="$1"
  local project_name="$2"
  local service_name="$3"
  local override_file
  override_file="$(project_override_file "$repo" "$project_name")"
  local resolved_override
  resolved_override="$(resolve_project_override_file "$repo" "$project_name")"

  if [[ "$resolved_override" != "$override_file" && -f "$resolved_override" && ! -f "$override_file" ]]; then
    cp "$resolved_override" "$override_file"
  fi

  if [[ ! -f "$override_file" ]]; then
    return 0
  fi

  ruby -ryaml -e '
path = ARGV[0]
service = ARGV[1]
raw = YAML.safe_load(File.read(path), aliases: false)
data = raw.is_a?(Hash) ? raw : {}
services = data["services"].is_a?(Hash) ? data["services"] : nil
if services
  if services["enabled"].is_a?(Array)
    services["enabled"] = services["enabled"].select { |v| v.is_a?(String) && v != service }
  end
  if services["config"].is_a?(Hash)
    services["config"].delete(service)
  end
  services.delete("enabled") if services["enabled"].is_a?(Array) && services["enabled"].empty?
  services.delete("config") if services["config"].is_a?(Hash) && services["config"].empty?
  data.delete("services") if services.empty?
end
File.write(path, data.to_yaml(line_width: -1))
' "$override_file" "$service_name"
}

service_state_file() {
  local project_name="$1"
  local service_name="$2"
  echo "$SERVICE_STATE_ROOT/$project_name/$service_name.state"
}

service_version() {
  local service_name="$1"
  local service_script
  service_script="$(service_script_path "$service_name")"
  bash "$service_script" version
}

service_state_matches() {
  local project_name="$1"
  local service_name="$2"
  local expected_version="$3"
  local expected_hash="$4"
  local state_file
  state_file="$(service_state_file "$project_name" "$service_name")"

  [[ -f "$state_file" ]] || return 1

  local saved_version=""
  local saved_hash=""
  while IFS='=' read -r key value; do
    case "$key" in
    VERSION) saved_version="$value" ;;
    CONFIG_HASH) saved_hash="$value" ;;
    esac
  done <"$state_file"

  [[ "$saved_version" == "$expected_version" && "$saved_hash" == "$expected_hash" ]]
}

write_service_state() {
  local project_name="$1"
  local service_name="$2"
  local version="$3"
  local config_hash="$4"
  local state_file
  state_file="$(service_state_file "$project_name" "$service_name")"

  mkdir -p "$(dirname "$state_file")"
  cat >"$state_file" <<EOF
VERSION=$version
CONFIG_HASH=$config_hash
UPDATED_AT=$(date -u +%Y-%m-%dT%H:%M:%SZ)
EOF
}

ensure_bin_on_path() {
  local bin_dir="$1"
  case ":$PATH:" in
  *":$bin_dir:"*)
    ok "$bin_dir is on PATH"
    ;;
  *)
    warn "$bin_dir is not on PATH"
    info "Add this line to your shell rc file:"
    printf '  export PATH="%s:$PATH"\n' "$bin_dir"
    ;;
  esac
}

confirm_remove() {
  local prompt="$1"
  local response=""
  read -r -p "$prompt [y/N]: " response
  [[ "${response:-N}" =~ ^[Yy]$ ]]
}

confirm_default_yes() {
  local prompt="$1"
  local response=""

  while true; do
    read -r -p "$prompt [Y/n]: " response
    case "${response:-}" in
    "" | y | Y | yes | YES | Yes)
      return 0
      ;;
    n | N | no | NO | No)
      return 1
      ;;
    *)
      info "Please answer y or n."
      ;;
    esac
  done
}

is_interactive_terminal() {
  [[ -t 0 && -t 1 ]]
}

select_requirements_with_checkboxes() {
  local options=("$@")
  local count=${#options[@]}

  CHECKBOX_SELECTED=()
  if [[ "$count" -eq 0 ]]; then
    return 0
  fi

  local selected=()
  local i=0
  for ((i = 0; i < count; i++)); do
    selected+=(1)
  done

  local cursor=0
  local key=""

  while true; do
    printf '\033[H\033[J'
    echo "Select requirements to install"
    echo "Space: toggle  Enter: confirm  A: toggle all  Q: cancel"
    echo

    local selected_count=0
    for ((i = 0; i < count; i++)); do
      local marker="[ ]"
      if [[ "${selected[$i]}" -eq 1 ]]; then
        marker="[x]"
        selected_count=$((selected_count + 1))
      fi

      if [[ "$i" -eq "$cursor" ]]; then
        printf '\033[1;36m> %s %s\033[0m\n' "$marker" "${options[$i]}"
      elif [[ "${selected[$i]}" -eq 1 ]]; then
        printf '\033[1;32m  %s %s\033[0m\n' "$marker" "${options[$i]}"
      else
        printf '  %s %s\n' "$marker" "${options[$i]}"
      fi
    done

    echo
    echo "Selected: $selected_count of $count"

    IFS= read -rsn1 key || true
    if [[ "$key" == $'\x1b' ]]; then
      local rest=""
      IFS= read -rsn2 rest || true
      key+="$rest"
    fi

    case "$key" in
    "")
      CHECKBOX_SELECTED=()
      for ((i = 0; i < count; i++)); do
        if [[ "${selected[$i]}" -eq 1 ]]; then
          CHECKBOX_SELECTED+=("${options[$i]}")
        fi
      done
      return 0
      ;;
    " ")
      if [[ "${selected[$cursor]}" -eq 1 ]]; then
        selected[$cursor]=0
      else
        selected[$cursor]=1
      fi
      ;;
    q | Q)
      return 1
      ;;
    a | A)
      local all_selected=true
      for ((i = 0; i < count; i++)); do
        if [[ "${selected[$i]}" -eq 0 ]]; then
          all_selected=false
          break
        fi
      done
      for ((i = 0; i < count; i++)); do
        if [[ "$all_selected" == true ]]; then
          selected[$i]=0
        else
          selected[$i]=1
        fi
      done
      ;;
    j | $'\x1b[B')
      cursor=$(((cursor + 1) % count))
      ;;
    k | $'\x1b[A')
      cursor=$(((cursor - 1 + count) % count))
      ;;
    esac
  done
}

render_project_template() {
  local project_name="$1"
  local source_root="$2"

  cat <<EOF
name: $project_name
root: "$source_root"

startup_window: app

windows:
  - app:
      root: "$source_root"
      layout: main-vertical
      panes:
        - editor: 'nvim'
        - shell: 'zsh -l'
EOF
}

is_codebase_directory() {
  local dir="$1"

  [[ -d "$dir" ]] || return 1
  [[ -e "$dir/.git" ]] && return 0

  local markers=(
    "package.json"
    "pyproject.toml"
    "requirements.txt"
    "go.mod"
    "Cargo.toml"
    "composer.json"
    "Gemfile"
    "pom.xml"
    "build.gradle"
    "build.gradle.kts"
    "*.sln"
    "*.csproj"
    "Dockerfile"
    "docker-compose.yml"
    "docker-compose.yaml"
  )

  local marker
  for marker in "${markers[@]}"; do
    if compgen -G "$dir/$marker" >/dev/null 2>&1; then
      return 0
    fi
  done

  return 1
}

detect_workspace_repos() {
  local root="$1"
  local children=()
  local child

  shopt -s nullglob
  children=("$root"/*)
  shopt -u nullglob

  for child in "${children[@]}"; do
    [[ -d "$child" ]] || continue
    is_codebase_directory "$child" || continue
    echo "$child"
  done
}

window_name_from_repo_path() {
  local path="$1"
  local name
  name="$(basename "$path")"
  name="${name// /-}"
  name="${name//_/-}"
  echo "$name"
}

render_workspace_project_template() {
  local project_name="$1"
  local source_root="$2"
  shift 2
  local repo_paths=("$@")

  cat <<EOF
name: $project_name
root: "$source_root"

startup_window: $(window_name_from_repo_path "${repo_paths[0]}")

windows:
EOF

  local repo_path
  local repo_name
  local repo_dir_name
  for repo_path in "${repo_paths[@]}"; do
    repo_dir_name="$(basename "$repo_path")"
    repo_name="$(window_name_from_repo_path "$repo_path")"
    cat <<EOF
  - $repo_name:
      root: ./${repo_dir_name}
      layout: main-vertical
      panes:
        - editor: 'nvim'
        - shell: 'zsh -l'

EOF
  done

  cat <<'EOF'
  - oo:
      root: ./.oo
      panes:
        - 'nvim || zsh -l'
EOF
}

scaffold_workflow_repo() {
  local repo="$1"

  mkdir -p "$repo"
}

write_repo_readme() {
  local repo="$1"
  local first_project="$2"

  cat >"$repo/README.md" <<EOF
# Team workflow repository

This repository is managed with \`oo\` and is intended to live outside application repositories.

- Workflow workflows: \`<workflow>/workflow.yaml\`
- Workflow overrides: \`<workflow>/override.yaml\`

Typical flow:

\`\`\`bash
oo service install --workflow $first_project
oo validate
oo doctor
oo start $first_project
\`\`\`

You can add more workflows later from this same repo:

\`\`\`bash
oo add another-workflow
\`\`\`
EOF
}

resolve_alias_conflict() {
  local repo="$1"
  local project_name="$2"
  local dry_run="$3"

  local name="$project_name"

  while :; do
    local project_file
    project_file="$(project_template_file "$repo" "$name")"
    local override_file
    override_file="$(project_override_file "$repo" "$name")"
    local tmuxinator_file="$TMUXINATOR_DIR/$name.yml"

    if [[ -e "$project_file" || -e "$override_file" ]]; then
      error "Workflow files already exist for '$name' in this workflow repo"
      info "Choose a different workflow name."
      exit 1
    fi

    if [[ ! -e "$tmuxinator_file" ]]; then
      printf '%s|%s\n' "$name" "create"
      return 0
    fi

    if [[ -L "$tmuxinator_file" ]]; then
      local target=""
      target="$(readlink "$tmuxinator_file")"
      if [[ "$target" == "$project_file" ]]; then
        printf '%s|%s\n' "$name" "same"
        return 0
      fi
    elif [[ ! -f "$tmuxinator_file" ]]; then
      error "Refusing to manage non-file alias path: $tmuxinator_file"
      exit 1
    fi

    echo
    warn "tmuxinator alias already exists: $tmuxinator_file"
    if [[ -L "$tmuxinator_file" ]]; then
      info "Current alias target: $(readlink "$tmuxinator_file")"
    fi
    echo "Choose one:"
    echo "  [r] rename workflow"
    echo "  [p] replace alias"
    local choice=""
    read -r -p "Your choice [r/p]: " choice

    case "${choice:-}" in
    r | R)
      local renamed=""
      read -r -p "Enter new workflow name: " renamed
      if [[ -z "$renamed" ]]; then
        error "Workflow name cannot be empty"
        continue
      fi
      local renamed_slug
      renamed_slug="$(slugify_workflow_name "$renamed")"
      if [[ "$renamed_slug" != "$renamed" ]]; then
        info "Using workflow name: '$renamed_slug'"
      fi
      renamed="$renamed_slug"
      validate_project_name "$renamed"
      name="$renamed"
      ;;
    p | P)
      if [[ "$dry_run" == true ]]; then
        printf '%s|%s\n' "$name" "replace"
        return 0
      fi
      if confirm_remove "Replace existing alias '$tmuxinator_file'?"; then
        printf '%s|%s\n' "$name" "replace"
        return 0
      fi
      error "Alias replacement cancelled"
      exit 1
      ;;
    *)
      error "Invalid choice"
      ;;
    esac
  done
}

link_project_alias() {
  local repo="$1"
  local project_name="$2"
  local mode="$3"

  local source_file
  source_file="$(project_template_file "$repo" "$project_name")"
  local tmuxinator_file="$TMUXINATOR_DIR/$project_name.yml"

  mkdir -p "$TMUXINATOR_DIR"

  case "$mode" in
  create)
    ln -s "$source_file" "$tmuxinator_file"
    ok "Created tmuxinator alias: $tmuxinator_file -> $source_file"
    ;;
  replace)
    rm -f "$tmuxinator_file"
    ln -s "$source_file" "$tmuxinator_file"
    ok "Replaced tmuxinator alias: $tmuxinator_file -> $source_file"
    ;;
  same)
    ok "tmuxinator alias already points to workflow file: $tmuxinator_file"
    ;;
  *)
    error "Unknown alias mode: $mode"
    exit 1
    ;;
  esac
}

list_projects_in_repo() {
  local repo="$1"
  local dirs=()
  local d
  shopt -s nullglob
  dirs=("$repo"/*)
  shopt -u nullglob

  for d in "${dirs[@]}"; do
    [[ -d "$d" ]] || continue
    [[ -f "$d/workflow.yaml" || -f "$d/workflow.yml" ]] || continue
    basename "$d"
  done
}

ensure_local_workflow_link() {
  local project_name="$1"
  local project_dir="$2"
  local repo_dir="$3"
  local quiet="${4:-false}"
  local local_dir="$repo_dir/.oo"
  local project_link="$local_dir/workflow.yaml"
  local override_link="$local_dir/override.yaml"
  local source_project_file
  local source_override_file
  source_project_file="$(resolve_project_template_file "$(dirname "$project_dir")" "$project_name")"
  source_override_file="$(resolve_project_override_file "$(dirname "$project_dir")" "$project_name")"

  mkdir -p "$local_dir"
  ln -sfn "$source_project_file" "$project_link"
  ln -sfn "$source_override_file" "$override_link"
  if [[ "$quiet" != true ]]; then
    ok "Created local workflow links in: $local_dir"
  fi

  if [[ -L "$local_dir/workflow" || -d "$local_dir/workflow" ]]; then
    rm -rf "$local_dir/workflow"
  fi
  if [[ -d "$local_dir/workflows" ]]; then
    rm -rf "$local_dir/workflows"
  fi
  local gitignore_file="$repo_dir/.gitignore"
  if [[ -f "$gitignore_file" ]]; then
    if ! grep -qF ".oo/" "$gitignore_file"; then
      printf '\n.oo/\n' >>"$gitignore_file"
      ok "Updated gitignore: $gitignore_file"
    fi
  fi
}

cmd_add() {
  local dry_run=false
  local no_install=false
  local project_name=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
    --dry-run)
      dry_run=true
      shift
      ;;
    --no-install)
      no_install=true
      shift
      ;;
    -h | --help)
      cat <<'EOF'
Usage: oo add [workflow-name] [--dry-run] [--no-install]

- Creates a workflow in the configured team workflow root.
- If workflow-name is omitted, defaults to current folder name.
EOF
      return 0
      ;;
    *)
      if [[ -z "$project_name" ]]; then
        project_name="$1"
        shift
      else
        error "Unexpected argument: $1"
        exit 1
      fi
      ;;
    esac
  done

  local workflow_repo=""
  local scaffold_repo=false
  local source_root
  source_root="$(cd "$PWD" && pwd)"
  local add_mode="single"
  local workspace_repos=()

  if ! is_codebase_directory "$source_root"; then
    local candidate=""
    while IFS= read -r candidate; do
      [[ -n "$candidate" ]] || continue
      workspace_repos+=("$candidate")
    done < <(detect_workspace_repos "$source_root")

    if [[ ${#workspace_repos[@]} -ge 2 ]]; then
      add_mode="workspace"
    fi
  fi

  if [[ "$add_mode" == "workspace" && ${#workspace_repos[@]} -eq 0 ]]; then
    local candidate=""
    while IFS= read -r candidate; do
      [[ -n "$candidate" ]] || continue
      workspace_repos+=("$candidate")
    done < <(detect_workspace_repos "$source_root")
  fi

  if [[ "$add_mode" == "workspace" && ${#workspace_repos[@]} -lt 2 ]]; then
    warn "Workspace mode selected, but fewer than 2 child codebases detected; continuing as single workflow"
    add_mode="single"
  fi

  if [[ "$add_mode" == "workspace" && -t 0 && "$dry_run" != true ]]; then
    info "Detected multi-repo workspace with ${#workspace_repos[@]} repositories"
    if ! confirm_remove "Create one workspace workflow for this directory?"; then
      info "Continuing with single-workflow add mode"
      add_mode="single"
    fi
  fi

  workflow_repo="$(ensure_workflow_root_for_add "$dry_run")"
  if [[ ! -f "$workflow_repo/README.md" ]]; then
    scaffold_repo=true
  fi
  mkdir -p "$workflow_repo"

  if [[ -z "$project_name" ]]; then
    local default_name
    default_name="$(slugify_workflow_name "$(basename "$source_root")")"
    project_name="$default_name"

    if [[ -t 0 ]]; then
      local entered_name=""
      read -r -p "Workflow name [$default_name]: " entered_name
      project_name="${entered_name:-$default_name}"
    fi
  fi

  local project_name_slug
  project_name_slug="$(slugify_workflow_name "$project_name")"
  if [[ "$project_name_slug" != "$project_name" ]]; then
    info "Using workflow name: '$project_name_slug'"
  fi
  project_name="$project_name_slug"

  validate_project_name "$project_name"

  local resolution
  resolution="$(resolve_alias_conflict "$workflow_repo" "$project_name" "$dry_run")"
  local final_name="${resolution%%|*}"
  local alias_mode="${resolution#*|}"

  local project_file=""
  local project_root_dir
  project_root_dir="$(project_dir "$workflow_repo" "$final_name")"
  local override_file="$project_root_dir/override.yaml"
  project_file="$project_root_dir/workflow.yaml"
  local suggested_services=()
  local suggested_service=""
  local seen_services=","
  if [[ "$add_mode" == "workspace" ]]; then
    local repo_path
    for repo_path in "${workspace_repos[@]}"; do
      while IFS= read -r suggested_service; do
        [[ -n "$suggested_service" ]] || continue
        if [[ "$seen_services" != *",$suggested_service,"* ]]; then
          suggested_services+=("$suggested_service")
          seen_services+="$suggested_service,"
        fi
      done < <(detect_suggested_services "$repo_path")
    done
  else
    while IFS= read -r suggested_service; do
      [[ -n "$suggested_service" ]] || continue
      if [[ "$seen_services" != *",$suggested_service,"* ]]; then
        suggested_services+=("$suggested_service")
        seen_services+="$suggested_service,"
      fi
    done < <(detect_suggested_services "$source_root")
  fi

  if [[ "$dry_run" == true ]]; then
    info "Dry run: no files were written"
    if [[ "$scaffold_repo" == true ]]; then
      echo "Would create workflow repo in: $workflow_repo"
      echo "  README.md"
    fi
    echo "Would create workflow directory: $project_root_dir"
    echo "Would create workflow files:"
    echo "  $project_file"
    echo "  $override_file"
    if [[ "$add_mode" == "workspace" ]]; then
      echo "Mode: workspace"
      echo "Would include repositories:"
      local repo_path
      for repo_path in "${workspace_repos[@]}"; do
        echo "  - $(basename "$repo_path")"
      done
    fi
    if [[ ${#suggested_services[@]} -gt 0 ]]; then
      echo "Would auto-enable suggested services: ${suggested_services[*]}"
    fi
    if [[ "$add_mode" == "single" ]]; then
      echo "Mode: minimal workflow content"
    fi

    case "$alias_mode" in
    create)
      echo "Would create tmuxinator alias: $TMUXINATOR_DIR/$final_name.yml"
      ;;
    replace)
      echo "Would replace tmuxinator alias: $TMUXINATOR_DIR/$final_name.yml"
      ;;
    same)
      echo "tmuxinator alias already points to this workflow"
      ;;
    esac
    return 0
  fi

  if [[ "$scaffold_repo" == true ]]; then
    scaffold_workflow_repo "$workflow_repo"
    write_repo_readme "$workflow_repo" "$final_name"
    ok "Created workflow repository"
  fi

  mkdir -p "$project_root_dir"
  if [[ "$add_mode" == "workspace" ]]; then
    render_workspace_project_template "$final_name" "$source_root" "${workspace_repos[@]}" >"$project_file"
  else
    render_project_template "$final_name" "$source_root" >"$project_file"
  fi

  {
    cat <<'EOF'
services:
  enabled:
EOF
    if [[ ${#suggested_services[@]} -eq 0 ]]; then
      echo "    []"
    else
      for suggested_service in "${suggested_services[@]}"; do
        echo "    - $suggested_service"
      done
    fi
    cat <<'EOF'
  config: {}
EOF
  } >"$override_file"

  link_project_alias "$workflow_repo" "$final_name" "$alias_mode"
  ensure_local_workflow_link "$final_name" "$project_root_dir" "$source_root"

  ok "Created workflow template: $project_file"
  ok "Created override file: $override_file"
  if [[ ${#suggested_services[@]} -gt 0 ]]; then
    info "Auto-enabled suggested services: ${suggested_services[*]}"
  fi

  if [[ "$no_install" == true ]]; then
    info "Run: oo install"
    echo
    echo "Next:"
    echo "  Start your environment → oo install"
    return 0
  fi

  if ! is_interactive_terminal; then
    info "Run: oo install"
    return 0
  fi

  cmd_install --workflow "$final_name" --yes
}

cmd_remove() {
  local assume_yes=false
  local project_name=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
    --yes)
      assume_yes=true
      shift
      ;;
    -h | --help)
      cat <<'EOF'
Usage: oo remove <workflow-name> [--yes]

Removes the tmuxinator alias for a workflow, then optionally removes
local override/template files when running inside a workflow repo.
EOF
      return 0
      ;;
    *)
      if [[ -z "$project_name" ]]; then
        project_name="$1"
        shift
      else
        error "Unexpected argument: $1"
        exit 1
      fi
      ;;
    esac
  done

  if [[ -z "$project_name" ]]; then
    error "Missing workflow name"
    info "Usage: oo remove <workflow-name> [--yes]"
    exit 1
  fi

  validate_project_name "$project_name"

  local repo
  repo="$(require_workflow_repo)"

  local tmuxinator_file="$TMUXINATOR_DIR/$project_name.yml"
  if [[ ! -e "$tmuxinator_file" ]]; then
    warn "Workflow alias not found: $tmuxinator_file"
  fi

  if [[ -e "$tmuxinator_file" ]] && ([[ -L "$tmuxinator_file" ]] || [[ -f "$tmuxinator_file" ]]); then
    rm -f "$tmuxinator_file"
    ok "Removed tmuxinator alias: $tmuxinator_file"
  elif [[ -e "$tmuxinator_file" ]]; then
    error "Refusing to remove non-file path: $tmuxinator_file"
    exit 1
  fi

  local project_path
  project_path="$(project_dir "$repo" "$project_name")"
  if [[ -d "$project_path" ]]; then
    if [[ "$assume_yes" == true ]] || confirm_remove "Remove workflow directory '$project_path'?"; then
      rm -rf "$project_path"
      ok "Removed workflow directory: $project_path"
    else
      info "Kept workflow directory: $project_path"
    fi
  else
    info "Workflow directory not found: $project_path"
  fi
}

load_enabled_services_for_project() {
  local repo="$1"
  local project_name="$2"
  local service=""

  LOADED_PROJECT_SERVICES=()
  while IFS= read -r service; do
    [[ -n "$service" ]] || continue
    LOADED_PROJECT_SERVICES+=("$service")
  done < <(enabled_services_for_project "$repo" "$project_name")
}

build_service_state_context() {
  local repo="$1"
  local project_name="$2"
  local service_name="$3"

  SERVICE_CTX_SCRIPT="$(service_script_path "$service_name")"
  SERVICE_CTX_VERSION="$(service_version "$service_name")"
  SERVICE_CTX_CONFIG_JSON="$(service_config_json_for_project "$repo" "$project_name" "$service_name")"
  SERVICE_CTX_CONFIG_HASH="$(hash_text "$SERVICE_CTX_CONFIG_JSON")"
}

run_service_install_for_project() {
  local repo="$1"
  local project_name="$2"
  local assume_yes="$3"
  local service=""

  ensure_project_exists "$repo" "$project_name"
  load_enabled_services_for_project "$repo" "$project_name"

  if [[ ${#LOADED_PROJECT_SERVICES[@]} -eq 0 ]]; then
    info "No services configured for workflow '$project_name'."
    return 0
  fi

  for service in "${LOADED_PROJECT_SERVICES[@]}"; do
    require_service "$service"
    build_service_state_context "$repo" "$project_name" "$service"

    if service_state_matches "$project_name" "$service" "$SERVICE_CTX_VERSION" "$SERVICE_CTX_CONFIG_HASH"; then
      ok "Service '$service' is already installed for workflow '$project_name'"
      continue
    fi

    info "Installing service '$service' for workflow '$project_name'"
    if ! OO_SERVICE_CONFIG_JSON="$SERVICE_CTX_CONFIG_JSON" OO_SERVICE_ASSUME_YES="$assume_yes" bash "$SERVICE_CTX_SCRIPT" install; then
      error "Service install failed: $service"
      exit 1
    fi

    if ! OO_SERVICE_CONFIG_JSON="$SERVICE_CTX_CONFIG_JSON" bash "$SERVICE_CTX_SCRIPT" check; then
      error "Service check failed after install: $service"
      exit 1
    fi

    write_service_state "$project_name" "$service" "$SERVICE_CTX_VERSION" "$SERVICE_CTX_CONFIG_HASH"
    ok "Service ready: $service"
  done
}

report_service_readiness_for_start() {
  local repo="$1"
  local project_name="$2"
  local adopt_detected="${3:-false}"
  local print_output="${4:-true}"
  local service=""

  START_MISSING_SERVICES=()
  START_TIMEOUT_SERVICES=()
  START_FAILED_SERVICES=()
  load_enabled_services_for_project "$repo" "$project_name"

  if [[ ${#LOADED_PROJECT_SERVICES[@]} -eq 0 ]]; then
    if [[ "$print_output" == true ]]; then
      echo "  - (no services configured)"
    fi
    return 0
  fi

  for service in "${LOADED_PROJECT_SERVICES[@]}"; do
    require_service "$service"
    build_service_state_context "$repo" "$project_name" "$service"

    local state_ready=false
    if service_state_matches "$project_name" "$service" "$SERVICE_CTX_VERSION" "$SERVICE_CTX_CONFIG_HASH"; then
      state_ready=true
    fi

    local check_rc=0
    set +e
    run_service_check_with_timeout "$SERVICE_CTX_SCRIPT" "$SERVICE_CTX_CONFIG_JSON" "$SERVICE_CHECK_TIMEOUT_SEC"
    check_rc=$?
    set -e

    if [[ "$check_rc" -eq 0 ]]; then
      local detail
      detail="$(service_ready_detail "$service")"
      if [[ "$state_ready" == true ]]; then
        if [[ -n "$detail" ]]; then
          [[ "$print_output" == true ]] && printf '✔ %s -> ready %s\n' "$service" "$detail"
        else
          [[ "$print_output" == true ]] && printf '✔ %s -> ready\n' "$service"
        fi
      elif [[ "$adopt_detected" == true ]]; then
        write_service_state "$project_name" "$service" "$SERVICE_CTX_VERSION" "$SERVICE_CTX_CONFIG_HASH"
        if [[ -n "$detail" ]]; then
          [[ "$print_output" == true ]] && printf '✔ %s -> ready %s\n' "$service" "$detail"
        else
          [[ "$print_output" == true ]] && printf '✔ %s -> ready (detected on machine)\n' "$service"
        fi
      else
        [[ "$print_output" == true ]] && printf '⚠ %s -> detected but not managed by oo\n' "$service"
        START_MISSING_SERVICES+=("$service")
      fi
      continue
    fi

    if [[ "$check_rc" -eq 124 ]]; then
      [[ "$print_output" == true ]] && printf '⚠ %s -> check timed out (%.1fs)\n' "$service" "$SERVICE_CHECK_TIMEOUT_SEC"
      START_TIMEOUT_SERVICES+=("$service")
      continue
    fi

    if [[ "$state_ready" == true ]]; then
      [[ "$print_output" == true ]] && printf '⚠ %s -> check failed\n' "$service"
      START_FAILED_SERVICES+=("$service")
    else
      [[ "$print_output" == true ]] && printf '⚠ %s -> not installed\n' "$service"
      START_MISSING_SERVICES+=("$service")
    fi
  done
}

collect_install_candidates_for_project() {
  INSTALL_CANDIDATES=()
  local seen=","
  local service=""

  for service in "${START_MISSING_SERVICES[@]-}" "${START_TIMEOUT_SERVICES[@]-}" "${START_FAILED_SERVICES[@]-}"; do
    [[ -n "$service" ]] || continue
    if [[ "$seen" != *",$service,"* ]]; then
      INSTALL_CANDIDATES+=("$service")
      seen+="$service,"
    fi
  done
}

service_requirement_label() {
  local service="$1"
  case "$service" in
  node)
    echo "node (required >= v${OO_NODE_REQUIRED_MAJOR:-20})"
    ;;
  *)
    echo "$service"
    ;;
  esac
}

service_ready_detail() {
  local service="$1"
  case "$service" in
  node)
    local required_major="${OO_NODE_REQUIRED_MAJOR:-20}"
    local node_version=""
    node_version="$(node --version 2>/dev/null || true)"
    if [[ -n "$node_version" ]]; then
      echo "($node_version, required >= v$required_major)"
    else
      echo "(required >= v$required_major)"
    fi
    ;;
  *)
    echo ""
    ;;
  esac
}

service_display_name() {
  local service="$1"
  case "$service" in
  node)
    echo "Node.js"
    ;;
  api)
    echo "API"
    ;;
  web)
    echo "Web"
    ;;
  *)
    echo "$service"
    ;;
  esac
}

join_by_comma() {
  local first=true
  local item
  for item in "$@"; do
    [[ -n "$item" ]] || continue
    if [[ "$first" == true ]]; then
      printf '%s' "$item"
      first=false
    else
      printf ', %s' "$item"
    fi
  done
}

install_selected_services_for_project() {
  local repo="$1"
  local project_name="$2"
  local assume_yes="$3"
  shift 3

  local selected_services=("$@")
  local service=""
  local failures=()

  if [[ ${#selected_services[@]} -eq 0 ]]; then
    warn "No machine requirements were selected for installation"
    return 0
  fi

  local idx=0
  local total=${#selected_services[@]}
  for service in "${selected_services[@]}"; do
    idx=$((idx + 1))
    require_service "$service"
    build_service_state_context "$repo" "$project_name" "$service"
    local service_label
    service_label="$(service_requirement_label "$service")"

    echo "  ... $service_label"
    if ! OO_SERVICE_CONFIG_JSON="$SERVICE_CTX_CONFIG_JSON" OO_SERVICE_ASSUME_YES="$assume_yes" bash "$SERVICE_CTX_SCRIPT" install; then
      error_block "INS-001" "Install failed" "$service_label install failed" "Run again with --verbose" "Run: oo doctor"
      failures+=("$service")
      continue
    fi

    if ! OO_SERVICE_CONFIG_JSON="$SERVICE_CTX_CONFIG_JSON" bash "$SERVICE_CTX_SCRIPT" check >/dev/null 2>&1; then
      error_block "INS-002" "Install failed" "$service_label check failed after install" "Run again with --verbose" "Run: oo doctor"
      failures+=("$service")
      continue
    fi

    write_service_state "$project_name" "$service" "$SERVICE_CTX_VERSION" "$SERVICE_CTX_CONFIG_HASH"
    ok "Requirement ready: $service"
  done

  if [[ ${#failures[@]} -gt 0 ]]; then
    warn "Machine readiness incomplete. Failed requirements: ${failures[*]}"
    return 1
  fi

  return 0
}

project_root_for_project() {
  local repo="$1"
  local project_name="$2"
  local config_source_file
  local config_override_file
  local rendered_config_file

  config_source_file="$(project_template_file "$repo" "$project_name")"
  config_override_file="$(project_override_file "$repo" "$project_name")"
  rendered_config_file="$(mktemp "${TMPDIR:-/tmp}/oo-install-${project_name}-XXXXXX")"

  if ! render_project_config_for_start "$config_source_file" "$config_override_file" "$rendered_config_file"; then
    rm -f "$rendered_config_file"
    echo ""
    return 1
  fi

  local root
  root="$(read_rendered_config_root "$rendered_config_file")"
  rm -f "$rendered_config_file"
  echo "$root"
}

collect_project_dependency_commands() {
  local project_root="$1"
  PROJECT_DEP_COMMANDS=()
  PROJECT_DEP_LABELS=()

  if [[ -f "$project_root/package.json" ]]; then
    PROJECT_DEP_COMMANDS+=("npm install")
    PROJECT_DEP_LABELS+=("npm install")
  fi

  if [[ -f "$project_root/requirements.txt" ]]; then
    PROJECT_DEP_COMMANDS+=("pip3 install -r requirements.txt")
    PROJECT_DEP_LABELS+=("pip3 install -r requirements.txt")
  fi

  if [[ -f "$project_root/Gemfile" ]]; then
    PROJECT_DEP_COMMANDS+=("bundle install")
    PROJECT_DEP_LABELS+=("bundle install")
  fi

  if [[ -f "$project_root/go.mod" ]]; then
    PROJECT_DEP_COMMANDS+=("go mod download")
    PROJECT_DEP_LABELS+=("go mod download")
  fi
}

summarize_npm_install_warnings() {
  local log_file="$1"

  python3 - "$log_file" <<'PY'
import re
import sys

path = sys.argv[1]
text = open(path, 'r', errors='replace').read()
lines = text.splitlines()

deprecations = sum(1 for line in lines if re.search(r'\bdeprecated\b', line, re.I))
config_warn = any(re.search(r'npm\s+warn\s+.*config|npm\s+warn\s+config', line, re.I) for line in lines)

vuln_line = None
vuln_total = None
severity = {}
for line in lines:
    m = re.search(r'(\d+) vulnerabilities?\s*\(([^)]*)\)', line, re.I)
    if m:
        vuln_total = int(m.group(1))
        vuln_line = m.group(2).strip()
        for part in vuln_line.split(','):
            part = part.strip()
            mm = re.match(r'(\d+)\s+(low|moderate|high|critical)', part, re.I)
            if mm:
                severity[mm.group(2).lower()] = int(mm.group(1))

if config_warn:
    print('WARN|npm config contains deprecated or invalid settings')
if deprecations > 0:
    print(f'WARN|Deprecated packages detected ({deprecations})')
if vuln_total is not None:
    sev_order = ['low', 'moderate', 'high', 'critical']
    details = ', '.join(f"{severity[k]} {k}" for k in sev_order if k in severity)
    if details:
        print(f'WARN|{vuln_total} vulnerabilities reported ({details})')
    else:
        print(f'WARN|{vuln_total} vulnerabilities reported')
PY
}

run_project_dependency_commands() {
  local project_root="$1"
  local verbose_mode="${2:-false}"
  local idx=0
  local total=${#PROJECT_DEP_COMMANDS[@]}

  INSTALL_WARNING_LINES=()
  INSTALL_CHANGED_LINES=()

  if [[ "$total" -eq 0 ]]; then
    info "No dependency installers detected"
    return 0
  fi

  echo "Dependencies"
  local command=""
  local label=""
  for ((idx = 0; idx < total; idx++)); do
    command="${PROJECT_DEP_COMMANDS[$idx]}"
    label="${PROJECT_DEP_LABELS[$idx]}"
    echo "  ... $label"

    local cmd_log
    cmd_log="$(mktemp "${TMPDIR:-/tmp}/oo-deps-${idx}-XXXXXX.log")"
    local cmd_status=0
    set +e
    (cd "$project_root" && eval "$command") >"$cmd_log" 2>&1
    cmd_status=$?
    set -e

    if [[ "$verbose_mode" == true ]]; then
      cat "$cmd_log"
    fi

    if [[ "$cmd_status" -ne 0 ]]; then
      local details=""
      if [[ "$verbose_mode" != true ]]; then
        details="$(python3 - "$cmd_log" <<'PY'
import sys
from pathlib import Path
lines = Path(sys.argv[1]).read_text(errors='replace').splitlines()
for line in lines[-12:]:
    print(line)
PY
)"
      fi
      rm -f "$cmd_log"
      install_failure_block_with_details "INS-101" "$label exited with code $cmd_status." "$details" "Retry with details: oo install --verbose" "Check dependency scripts and lockfiles"
      return 1
    fi

    if [[ "$label" == "npm install" ]]; then
      while IFS= read -r summary_line; do
        [[ "$summary_line" == WARN\|* ]] || continue
        INSTALL_WARNING_LINES+=("${summary_line#WARN|}")
      done < <(summarize_npm_install_warnings "$cmd_log")
      INSTALL_CHANGED_LINES+=("Installed npm dependencies")
    else
      INSTALL_CHANGED_LINES+=("Installed dependencies via $label")
    fi

    rm -f "$cmd_log"
    echo "  ✓ done"
  done

  if [[ "$verbose_mode" != true && ${#INSTALL_WARNING_LINES[@]} -gt 0 ]]; then
    echo
    echo "Warnings"
    local warning
    for warning in "${INSTALL_WARNING_LINES[@]}"; do
      echo "  ! $warning"
    done
    echo
    echo "What you can do"
    echo "  • Review: npm audit"
    echo "  • Safe fixes: npm audit fix"
  fi

  return 0
}

parse_service_project_args() {
  local usage="$1"
  shift

  PARSED_SERVICE_NAME=""
  PARSED_PROJECT_NAME=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
    --workflow)
      [[ $# -ge 2 ]] || {
        error "--workflow requires a workflow name"
        exit 1
      }
      PARSED_PROJECT_NAME="$2"
      shift 2
      ;;
    *)
      if [[ -z "$PARSED_SERVICE_NAME" ]]; then
        PARSED_SERVICE_NAME="$1"
        shift
      else
        error "Unexpected argument: $1"
        exit 1
      fi
      ;;
    esac
  done

  [[ -n "$PARSED_SERVICE_NAME" ]] || {
    error "Missing service name"
    info "$usage"
    exit 1
  }
  if [[ -z "$PARSED_PROJECT_NAME" ]]; then
    PARSED_PROJECT_NAME="$(infer_start_project_from_context)"
    if [[ -n "$PARSED_PROJECT_NAME" ]]; then
      info "No --workflow provided; inferred '$PARSED_PROJECT_NAME'"
    fi
  fi

  [[ -n "$PARSED_PROJECT_NAME" ]] || {
    error "Missing workflow context"
    info "$usage"
    info "Tip: run from a linked workflow repo or pass --workflow <name>"
    exit 1
  }
}

parse_service_scope_args() {
  local usage="$1"
  local allow_yes="$2"
  shift 2

  PARSED_PROJECT_NAME=""
  PARSED_GLOBAL=false
  PARSED_ASSUME_YES=false

  while [[ $# -gt 0 ]]; do
    case "$1" in
    --workflow)
      [[ $# -ge 2 ]] || {
        error "--workflow requires a workflow name"
        exit 1
      }
      PARSED_PROJECT_NAME="$2"
      shift 2
      ;;
    --global)
      PARSED_GLOBAL=true
      shift
      ;;
    --yes)
      if [[ "$allow_yes" == true ]]; then
        PARSED_ASSUME_YES=true
        shift
      else
        error "Unexpected argument: --yes"
        exit 1
      fi
      ;;
    *)
      error "Unexpected argument: $1"
      info "$usage"
      exit 1
      ;;
    esac
  done

  if [[ -n "$PARSED_PROJECT_NAME" && "$PARSED_GLOBAL" == true ]]; then
    error "Use either --workflow or --global, not both"
    exit 1
  fi

  if [[ -z "$PARSED_PROJECT_NAME" && "$PARSED_GLOBAL" != true ]]; then
    PARSED_PROJECT_NAME="$(infer_start_project_from_context)"
    if [[ -n "$PARSED_PROJECT_NAME" ]]; then
      info "No --workflow provided; inferred '$PARSED_PROJECT_NAME'"
    fi
  fi
}

cmd_service_add() {
  parse_service_project_args "Usage: oo service add <service> [--workflow <workflow>]" "$@"
  validate_project_name "$PARSED_PROJECT_NAME"
  require_service "$PARSED_SERVICE_NAME"

  local repo
  repo="$(require_workflow_repo)"
  ensure_project_exists "$repo" "$PARSED_PROJECT_NAME"

  add_service_to_project_config "$repo" "$PARSED_PROJECT_NAME" "$PARSED_SERVICE_NAME"
  ok "Added service '$PARSED_SERVICE_NAME' to workflow '$PARSED_PROJECT_NAME'"
  local inferred_project
  inferred_project="$(infer_start_project_from_context)"
  if [[ "$inferred_project" == "$PARSED_PROJECT_NAME" ]]; then
    info "Run: oo service install"
  else
    info "Run: oo service install --workflow $PARSED_PROJECT_NAME"
  fi
}

cmd_service_remove() {
  parse_service_project_args "Usage: oo service remove <service> [--workflow <workflow>]" "$@"
  validate_project_name "$PARSED_PROJECT_NAME"

  local repo
  repo="$(require_workflow_repo)"
  ensure_project_exists "$repo" "$PARSED_PROJECT_NAME"

  remove_service_from_project_config "$repo" "$PARSED_PROJECT_NAME" "$PARSED_SERVICE_NAME"
  ok "Removed service '$PARSED_SERVICE_NAME' from workflow '$PARSED_PROJECT_NAME'"
}

cmd_service_list() {
  parse_service_scope_args "Usage: oo service list [--workflow <workflow> | --global]" false "$@"

  echo "Available services:"
  local available=()
  local p=""
  while IFS= read -r p; do
    [[ -n "$p" ]] || continue
    available+=("$p")
    echo "  - $p"
  done < <(list_available_services)
  if [[ ${#available[@]} -eq 0 ]]; then
    echo "  (none)"
  fi

  if [[ -z "$PARSED_PROJECT_NAME" && "$PARSED_GLOBAL" != true ]]; then
    return 0
  fi

  local repo
  repo="$(require_workflow_repo)"

  if [[ -n "$PARSED_PROJECT_NAME" ]]; then
    validate_project_name "$PARSED_PROJECT_NAME"
    ensure_project_exists "$repo" "$PARSED_PROJECT_NAME"
    echo
    echo "Configured services for '$PARSED_PROJECT_NAME':"
    local any=false
    while IFS= read -r p; do
      [[ -n "$p" ]] || continue
      any=true
      echo "  - $p"
    done < <(enabled_services_for_project "$repo" "$PARSED_PROJECT_NAME")
    [[ "$any" == true ]] || echo "  (none)"
    return 0
  fi

  echo
  echo "Configured services by workflow:"
  local proj=""
  while IFS= read -r proj; do
    [[ -n "$proj" ]] || continue
    echo "- $proj"
    local any=false
    while IFS= read -r p; do
      [[ -n "$p" ]] || continue
      any=true
      echo "    - $p"
    done < <(enabled_services_for_project "$repo" "$proj")
    [[ "$any" == true ]] || echo "    (none)"
  done < <(list_projects_in_repo "$repo")
}

cmd_service_install() {
  parse_service_scope_args "Usage: oo service install [--workflow <workflow>] [--yes] | --global [--yes]" true "$@"

  if [[ -z "$PARSED_PROJECT_NAME" && "$PARSED_GLOBAL" != true ]]; then
    error "Missing scope: use --workflow <name>, --global, or run from a linked workflow repo"
    exit 1
  fi

  local repo
  repo="$(require_workflow_repo)"

  if [[ -n "$PARSED_PROJECT_NAME" ]]; then
    validate_project_name "$PARSED_PROJECT_NAME"
    run_service_install_for_project "$repo" "$PARSED_PROJECT_NAME" "$PARSED_ASSUME_YES"
    return 0
  fi

  local proj=""
  while IFS= read -r proj; do
    [[ -n "$proj" ]] || continue
    run_service_install_for_project "$repo" "$proj" "$PARSED_ASSUME_YES"
  done < <(list_projects_in_repo "$repo")
}

cmd_service_help() {
  cat <<'EOF'
Usage: oo service <command> [options]

Commands:
  add <service> [--workflow <workflow>]
  remove <service> [--workflow <workflow>]
  list [--workflow <workflow> | --global]
  install [--workflow <workflow>] [--yes]
  install --global [--yes]
EOF
}

cmd_service() {
  local subcommand="${1:-}"
  shift || true

  case "$subcommand" in
  add)
    cmd_service_add "$@"
    ;;
  remove)
    cmd_service_remove "$@"
    ;;
  list)
    cmd_service_list "$@"
    ;;
  install)
    cmd_service_install "$@"
    ;;
  help | -h | --help | "")
    cmd_service_help
    ;;
  *)
    error "Unknown service subcommand: $subcommand"
    info "Run: oo service --help"
    exit 1
    ;;
  esac
}

cmd_validate() {
  local workflow_repo
  workflow_repo="$(require_workflow_repo)"
  OO_WORKFLOW_REPO="$workflow_repo" bash "$RUNTIME_DIR/scripts/validate-workflows.sh"
}

cmd_doctor() {
  local project_name=""
  local global_mode=false
  local fix_mode=false
  local assume_yes=false
  local verbose_mode=false
  local inferred_project=false

  while [[ $# -gt 0 ]]; do
    case "$1" in
    --workflow)
      [[ $# -ge 2 ]] || {
        error "--workflow requires a workflow name"
        exit 1
      }
      project_name="$2"
      shift 2
      ;;
    --global)
      global_mode=true
      shift
      ;;
    --fix)
      fix_mode=true
      shift
      ;;
    --yes)
      assume_yes=true
      shift
      ;;
    --verbose)
      verbose_mode=true
      shift
      ;;
    -h | --help)
      cat <<'EOF'
Usage: oo doctor [--workflow <workflow> | --global] [--fix] [--yes] [--verbose]

Diagnoses runtime and service readiness.
Use --fix to run safe automatic service installs.
EOF
      return 0
      ;;
    *)
      error "Unexpected argument: $1"
      exit 1
      ;;
    esac
  done

  if [[ -n "$project_name" && "$global_mode" == true ]]; then
    error "Use either --workflow or --global, not both"
    exit 1
  fi

  local workflow_repo
  workflow_repo="$(detect_workflow_repo)"

  if [[ -z "$project_name" && "$global_mode" != true ]]; then
    project_name="$(infer_start_project_from_context)"
    if [[ -n "$project_name" ]]; then
      inferred_project=true
    fi
  fi

  local tmux_ok=false
  local tmuxinator_ok=false
  local ruby_ok=false
  local issue_count=0
  local env_issue_count=0
  local project_issue_count=0
  local env_ok_items=()
  local env_missing_items=()

  command -v tmux >/dev/null 2>&1 && tmux_ok=true
  command -v tmuxinator >/dev/null 2>&1 && tmuxinator_ok=true
  command -v ruby >/dev/null 2>&1 && ruby_ok=true

  [[ "$tmux_ok" == true ]] && env_ok_items+=("tmux") || env_missing_items+=("tmux")
  [[ "$tmuxinator_ok" == true ]] && env_ok_items+=("tmuxinator") || env_missing_items+=("tmuxinator")
  [[ "$ruby_ok" == true ]] && env_ok_items+=("ruby") || env_missing_items+=("ruby")

  env_issue_count=${#env_missing_items[@]}
  issue_count=$((issue_count + env_issue_count))

  echo "◆ Doctor"
  if [[ "$global_mode" == true ]]; then
    echo "  Workflow: all"
  elif [[ -n "$project_name" ]]; then
    if [[ "$inferred_project" == true ]]; then
      echo "  Workflow: $project_name (inferred)"
    else
      echo "  Workflow: $project_name"
    fi
  else
    echo "  Workflow: none"
  fi
  echo

  echo "Environment"
  if [[ "$verbose_mode" != true && ${#env_missing_items[@]} -eq 0 ]]; then
    echo "  ✓ All runtime tools available (tmux, tmuxinator, ruby)"
  else
    [[ "$tmux_ok" == true ]] && echo "  ✓ tmux installed" || echo "  ! tmux not installed"
    [[ "$tmuxinator_ok" == true ]] && echo "  ✓ tmuxinator installed" || echo "  ! tmuxinator not installed"
    [[ "$ruby_ok" == true ]] && echo "  ✓ ruby installed" || echo "  ! ruby not installed"
  fi
  echo

  local workflows=()
  local proj=""
  local workflow_repo
  workflow_repo="$(detect_workflow_repo)"

  if [[ -z "$project_name" && "$global_mode" != true && -z "$workflow_repo" ]]; then
    error "No workflow context found"
    info "Run from a linked workflow repo, or pass --workflow <name> or --global"
    exit 1
  fi

  echo "Workflow"

  if [[ -z "$workflow_repo" ]]; then
    echo "  ! Team workflow root is not configured"
    issue_count=$((issue_count + 1))
    project_issue_count=$((project_issue_count + 1))
  elif [[ "$global_mode" == true ]]; then
    while IFS= read -r proj; do
      [[ -n "$proj" ]] || continue
      workflows+=("$proj")
    done < <(list_projects_in_repo "$workflow_repo")
  elif [[ -n "$project_name" ]]; then
    validate_project_name "$project_name"
    workflows+=("$project_name")
  fi

  local fix_candidates=()
  local workflow

  for workflow in "${workflows[@]}"; do
    ensure_project_exists "$workflow_repo" "$workflow"

    load_enabled_services_for_project "$workflow_repo" "$workflow"
    if [[ ${#LOADED_PROJECT_SERVICES[@]} -eq 0 ]]; then
      if [[ "$global_mode" == true ]]; then
        echo "  ✓ $workflow: no services configured"
      else
        echo "  ✓ No services configured"
      fi
      continue
    fi

    local service
    local project_needs_fix=false
    local project_ready_services=()
    local project_issues=()
    for service in "${LOADED_PROJECT_SERVICES[@]}"; do
      require_service "$service"
      build_service_state_context "$workflow_repo" "$workflow" "$service"

      local check_rc=0
      set +e
      run_service_check_with_timeout "$SERVICE_CTX_SCRIPT" "$SERVICE_CTX_CONFIG_JSON" "$SERVICE_CHECK_TIMEOUT_SEC"
      check_rc=$?
      set -e

      if [[ "$check_rc" -eq 0 ]]; then
        project_ready_services+=("$service")
      elif [[ "$check_rc" -eq 124 ]]; then
        project_needs_fix=true
        project_issues+=("$service timed out")
      else
        project_needs_fix=true
        project_issues+=("$service not ready")
      fi
    done

    if [[ "$project_needs_fix" == true ]]; then
      fix_candidates+=("$workflow")
      project_issue_count=$((project_issue_count + ${#project_issues[@]}))
      issue_count=$((issue_count + ${#project_issues[@]}))
      if [[ "$global_mode" == true ]]; then
        echo "  ! $workflow: ${#project_issues[@]} issue(s)"
      else
        local issue
        for issue in "${project_issues[@]}"; do
          echo "  ! $issue"
        done
      fi
    else
      if [[ "$global_mode" == true ]]; then
        echo "  ✓ $workflow: ready"
      elif [[ "$verbose_mode" == true || ${#project_ready_services[@]} -le 2 ]]; then
        local ready_service
        for ready_service in "${project_ready_services[@]}"; do
          echo "  ✓ $(service_display_name "$ready_service") ready"
        done
      else
        echo "  ✓ All workflow services ready ($(join_by_comma "${project_ready_services[@]}"))"
      fi
    fi
  done

  echo
  local install_cmd="oo install"
  if [[ "$global_mode" == true ]]; then
    install_cmd="oo install --workflow <workflow>"
  elif [[ -n "$project_name" ]]; then
    local inferred
    inferred="$(infer_start_project_from_context)"
    if [[ "$inferred" != "$project_name" ]]; then
      install_cmd="oo install --workflow $project_name"
    fi
  fi

  if [[ "$issue_count" -eq 0 ]]; then
    echo "✓ System healthy"
    echo "  No issues found"
    if [[ "$global_mode" != true ]]; then
      echo
      echo "Next:"
      echo "  oo start"
    fi
  else
    if [[ "$env_issue_count" -gt 0 && "$project_issue_count" -gt 0 ]]; then
      echo "✖ Workflow not ready (DOC-021)"
    else
      echo "! Setup incomplete"
    fi
    echo "  $issue_count issue(s) found"
    echo
    echo "What you can do"
    echo "  • Install environment: $install_cmd"
    echo "  • Re-check: oo doctor"
  fi

  if [[ "$fix_mode" == true && ${#fix_candidates[@]} -gt 0 ]]; then
    if [[ "$assume_yes" != true ]]; then
      if ! confirm_remove "Run safe service installs for suggested workflows?"; then
        info "Skipped automatic fixes"
        return 0
      fi
    fi

    local seen=""
    local p
    for p in "${fix_candidates[@]}"; do
      if [[ ",${seen}," == *",$p,"* ]]; then
        continue
      fi
      seen="${seen},$p"
      info "Applying fixes for workflow '$p'"
      run_service_install_for_project "$workflow_repo" "$p" "$assume_yes"
    done
    ok "Doctor fix run completed"
  fi
}

cmd_install() {
  local project_name=""
  local assume_yes=false
  local plan_only=false
  local skip_project_deps=false
  local verbose_mode=false
  local changed_items=()

  while [[ $# -gt 0 ]]; do
    case "$1" in
    --workflow)
      [[ $# -ge 2 ]] || {
        error "--workflow requires a workflow name"
        exit 1
      }
      project_name="$2"
      shift 2
      ;;
    --yes)
      assume_yes=true
      shift
      ;;
    --plan)
      plan_only=true
      shift
      ;;
    --no-workflow-deps)
      skip_project_deps=true
      shift
      ;;
    --verbose)
      verbose_mode=true
      shift
      ;;
    -h | --help)
      cat <<'EOF'
Usage: oo install [--workflow <workflow>] [--yes] [--plan] [--no-workflow-deps] [--verbose]

Installs machine readiness requirements and workflow dependencies.
EOF
      return 0
      ;;
    *)
      error "Unexpected argument: $1"
      info "Usage: oo install [--workflow <workflow>] [--yes] [--plan] [--no-workflow-deps] [--verbose]"
      exit 1
      ;;
    esac
  done

  if [[ -z "$project_name" ]]; then
    project_name="$(infer_start_project_from_context)"
    if [[ -n "$project_name" ]]; then
      info "No --workflow provided; inferred '$project_name'"
    fi
  fi

  if [[ -z "$project_name" ]]; then
    error "Missing workflow name"
    info "Usage: oo install [--workflow <workflow>] [--yes]"
    info "Tip: run from a linked workflow repo or pass --workflow <name>"
    exit 1
  fi

  validate_project_name "$project_name"

  local workflow_repo
  workflow_repo="$(require_workflow_repo)"
  ensure_project_exists "$workflow_repo" "$project_name"

  echo "◆ Installing $project_name"
  echo
  echo "Environment"

  report_service_readiness_for_start "$workflow_repo" "$project_name" true "$verbose_mode"
  collect_install_candidates_for_project

  local formatted_missing=()
  local formatted_candidates=()
  local service=""
  for service in "${START_MISSING_SERVICES[@]-}"; do
    [[ -n "$service" ]] || continue
    formatted_missing+=("$(service_requirement_label "$service")")
  done
  for service in "${INSTALL_CANDIDATES[@]-}"; do
    [[ -n "$service" ]] || continue
    formatted_candidates+=("$(service_requirement_label "$service")")
  done

  if [[ "$plan_only" == true ]]; then
    echo "Plan"
    if [[ ${#formatted_candidates[@]} -gt 0 ]]; then
      echo "  Will set up: $(join_by_comma "${formatted_candidates[@]}")"
    else
      local ready_services=()
      for service in "${LOADED_PROJECT_SERVICES[@]-}"; do
        ready_services+=("$service")
      done
      if [[ ${#ready_services[@]} -gt 0 ]]; then
        echo "  Environment already OK: $(join_by_comma "${ready_services[@]}")"
      else
        echo "  Environment already OK"
      fi
    fi

    local project_root_plan
    project_root_plan="$(project_root_for_project "$workflow_repo" "$project_name")"
    if [[ -n "$project_root_plan" && -d "$project_root_plan" ]]; then
      collect_project_dependency_commands "$project_root_plan"
      if [[ "$skip_project_deps" == true ]]; then
        echo "  Dependencies: skipped by flag"
      elif [[ ${#PROJECT_DEP_COMMANDS[@]} -gt 0 ]]; then
        echo "  Will run dependencies: $(join_by_comma "${PROJECT_DEP_LABELS[@]}")"
      else
        echo "  Dependencies: none detected"
      fi
    fi
    return 0
  fi

  local selected_services=()
  if [[ ${#INSTALL_CANDIDATES[@]-0} -eq 0 ]]; then
    local ready_services=()
    for service in "${LOADED_PROJECT_SERVICES[@]-}"; do
      ready_services+=("$service")
    done
    if [[ ${#ready_services[@]} -gt 0 ]]; then
      echo "  ✓ All requirements satisfied ($(join_by_comma "${ready_services[@]}"))"
    else
      echo "  ✓ All requirements satisfied"
    fi
  else
    if [[ ${#START_MISSING_SERVICES[@]-0} -gt 0 ]]; then
      echo "  ! Needs setup: $(join_by_comma "${formatted_missing[@]}")"
    fi
    if [[ ${#START_TIMEOUT_SERVICES[@]-0} -gt 0 || ${#START_FAILED_SERVICES[@]-0} -gt 0 ]]; then
      echo "  ! Needs verification: $(join_by_comma "${formatted_candidates[@]}")"
    fi

    selected_services=("${INSTALL_CANDIDATES[@]-}")

    if install_selected_services_for_project "$workflow_repo" "$project_name" "$assume_yes" "${selected_services[@]}"; then
      changed_items+=("Installed environment requirements")
    fi
  fi

  local project_root
  project_root="$(project_root_for_project "$workflow_repo" "$project_name")"
  if [[ -z "$project_root" || ! -d "$project_root" ]]; then
    error_block "INS-021" "Install failed" "Could not resolve workflow root from workflow config" "Run again with --verbose" "Check workflow config files"
    return 1
  fi

  collect_project_dependency_commands "$project_root"

  local install_project_dependencies=false
  if [[ "$skip_project_deps" == true ]]; then
    install_project_dependencies=false
  elif [[ ${#PROJECT_DEP_COMMANDS[@]} -eq 0 ]]; then
    install_project_dependencies=false
  elif [[ "$assume_yes" == true ]]; then
    install_project_dependencies=true
  elif ! is_interactive_terminal; then
    install_project_dependencies=true
  else
    install_project_dependencies=true
  fi

  if [[ "$skip_project_deps" != true ]]; then
    echo
  fi

  if [[ "$install_project_dependencies" == true ]]; then
    if run_project_dependency_commands "$project_root" "$verbose_mode"; then
      if [[ ${#INSTALL_CHANGED_LINES[@]} -gt 0 ]]; then
        local changed_line
        for changed_line in "${INSTALL_CHANGED_LINES[@]}"; do
          changed_items+=("$changed_line")
        done
      fi
    else
      return 1
    fi
  elif [[ "$skip_project_deps" == true ]]; then
    echo "Dependencies"
    echo "  ✓ skipped (--no-workflow-deps)"
  elif [[ ${#PROJECT_DEP_COMMANDS[@]} -eq 0 ]]; then
    echo "Dependencies"
    echo "  ✓ none detected"
  else
    echo "Dependencies"
    echo "  ✓ skipped"
  fi

  echo
  echo "✓ Install complete"
  if [[ ${#changed_items[@]} -eq 0 ]]; then
    echo "  No changes needed"
  else
    echo "  Changed:"
    local changed_item
    for changed_item in "${changed_items[@]}"; do
      echo "  - $changed_item"
    done
  fi
  echo
  echo "Next:"
  echo "  Run your workflow → oo start"
}

cmd_update() {
  local verbose=false

  while [[ $# -gt 0 ]]; do
    case "$1" in
    --verbose)
      verbose=true
      shift
      ;;
    -h | --help)
      cat <<'EOF'
Usage: oo update [--verbose]

Pulls the latest oo runtime and refreshes the oo CLI symlink.
EOF
      return 0
      ;;
    *)
      error "Unexpected argument: $1"
      info "Usage: oo update [--verbose]"
      return 1
      ;;
    esac
  done

  if ! command -v git >/dev/null 2>&1; then
    error "git is required for oo update"
    exit 1
  fi

  if ! git -C "$RUNTIME_DIR" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    error "oo update requires a git checkout at: $RUNTIME_DIR"
    exit 1
  fi

  local before_rev
  before_rev="$(git -C "$RUNTIME_DIR" rev-parse --short HEAD 2>/dev/null || echo "unknown")"

  local display_dir="$RUNTIME_DIR"
  if [[ -n "${HOME:-}" ]]; then
    display_dir="${display_dir/#$HOME/~}"
  fi

  echo "◆ Updating oo"
  echo "  Location: $display_dir"
  echo
  echo "Checking for updates"

  if [[ "$verbose" == true ]]; then
    if ! git -C "$RUNTIME_DIR" pull --ff-only; then
      error "SYS-001 Failed to update runtime repository"
      return 1
    fi
  else
    if ! git -C "$RUNTIME_DIR" pull --ff-only >/dev/null 2>&1; then
      error "SYS-001 Failed to update runtime repository"
      info "Run: oo update --verbose"
      return 1
    fi
  fi

  local after_rev
  after_rev="$(git -C "$RUNTIME_DIR" rev-parse --short HEAD 2>/dev/null || echo "unknown")"

  local bin_dir="${OO_BIN_DIR:-$DEFAULT_OO_BIN_DIR}"
  mkdir -p "$bin_dir"

  local symlink_path="$bin_dir/oo"
  local relinked=false
  local expected_target="$RUNTIME_DIR/oo"
  if [[ ! -L "$symlink_path" ]]; then
    relinked=true
  else
    local current_target=""
    current_target="$(readlink "$symlink_path" || true)"
    if [[ "$current_target" != "$expected_target" ]]; then
      relinked=true
    fi
  fi

  ln -sfn "$RUNTIME_DIR/oo" "$bin_dir/oo"

  if [[ "$before_rev" != "$after_rev" ]]; then
    echo "  ✓ Update available"
    echo "  From: $before_rev"
    echo "  To:   $after_rev"
    echo
    echo "Applying update"
    echo "  ✓ Runtime updated"
    echo "  ✓ CLI is ready"
    echo
    echo "✓ Update complete"
    echo "  Changed:"
    echo "  - Updated oo to $after_rev"
    if [[ "$relinked" == true ]]; then
      echo "  - Refreshed CLI link"
    fi
  else
    echo "  ✓ Already up to date"
    echo "  Revision: $after_rev"
    if [[ "$relinked" == true ]]; then
      echo "  ✓ CLI link refreshed"
    fi
    echo
    echo "✓ No changes needed"
  fi
}

cmd_list() {
  local repo
  repo="$(read_configured_workflow_root)"
  if [[ -z "$repo" || ! -d "$repo" ]]; then
    info "No team workflow root configured."
    info "Run: oo add <workflow-name>"
    echo
  else
    echo "Team workflows ($repo):"
    local found=false
    local project_name=""
    while IFS= read -r project_name; do
      [[ -n "$project_name" ]] || continue
      found=true
      echo "  - $project_name"
    done < <(list_projects_in_repo "$repo")
    [[ "$found" == true ]] || echo "  (none)"
    echo
  fi

  echo "Installed tmuxinator workflows ($TMUXINATOR_DIR):"
  if [[ -d "$TMUXINATOR_DIR" ]]; then
    local installed=()
    local item
    shopt -s nullglob
    installed=("$TMUXINATOR_DIR"/*.yml)
    shopt -u nullglob

    if [[ ${#installed[@]} -eq 0 ]]; then
      echo "  (none)"
    else
      for item in "${installed[@]}"; do
        echo "  - $(basename "${item%.yml}")"
      done
    fi
  else
    echo "  (tmuxinator dir not found)"
  fi
}

cmd_status() {
  local repo
  repo="$(read_configured_workflow_root)"

  echo "Running workflow sessions:"
  if command -v tmux >/dev/null 2>&1; then
    local sessions
    sessions="$(tmux ls 2>/dev/null || true)"
    if [[ -z "$sessions" ]]; then
      echo "  (none)"
    else
      while IFS= read -r line; do
        [[ -n "$line" ]] || continue
        echo "  - ${line%%:*}"
      done <<<"$sessions"
    fi
  else
    echo "  (tmux not installed)"
  fi

  if [[ -z "$repo" || ! -d "$repo" ]]; then
    echo
    info "No team workflow root configured yet"
    info "Run: oo add <workflow-name>"
    return 0
  fi

  echo
  echo "Workflow service health:"
  local proj=""
  local found=false
  while IFS= read -r proj; do
    [[ -n "$proj" ]] || continue
    found=true
    local running="stopped"
    if command -v tmux >/dev/null 2>&1 && tmux has-session -t "$proj" 2>/dev/null; then
      running="running"
    fi
    echo "- $proj ($running)"

    local svc=""
    local any=false
    while IFS= read -r svc; do
      [[ -n "$svc" ]] || continue
      any=true
      require_service "$svc"
      build_service_state_context "$repo" "$proj" "$svc"
      if service_state_matches "$proj" "$svc" "$SERVICE_CTX_VERSION" "$SERVICE_CTX_CONFIG_HASH"; then
        echo "  - $svc: ready"
      else
        echo "  - $svc: needs install"
      fi
    done < <(enabled_services_for_project "$repo" "$proj")
    [[ "$any" == true ]] || echo "  - (no services configured)"
  done < <(list_projects_in_repo "$repo")

  [[ "$found" == true ]] || echo "  (no workflows found)"
}

