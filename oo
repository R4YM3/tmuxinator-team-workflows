validate_source_auth_requirements() {
  local repo="$1"
  local workflow_name="$2"

  local line
  while IFS=$'\t' read -r source_name token_env source_hint; do
    [[ -n "$source_name" ]] || continue
    local token_value
    token_value="$(resolved_env_var_value "$token_env")"
    if [[ -z "$token_value" ]]; then
      error_block "INS-131" "Install blocked" "Missing authentication token for source access." --context "Workflow: $workflow_name | Source: $source_hint | Required env: $token_env" "Export token: export $token_env=..." "Retry: oo install" "Show details: oo install --verbose"
      return 1
    fi
  done < <(auth_entries_for_scope "$repo" "$workflow_name" "sources")

  return 0
}

collect_service_auth_issues() {
  local repo="$1"
  local workflow_name="$2"
  SERVICE_AUTH_ISSUES=()

