}

join_by_comma() {
  local first=true
  local item
  for item in "$@"; do
    [[ -n "$item" ]] || continue
    if [[ "$first" == true ]]; then
      printf '%s' "$item"
      first=false
    else
      printf ', %s' "$item"
    fi
  done
}

load_env_file_values() {
  local workflow_root="$1"
  OO_ENV_FILE_KEYS=()
  OO_ENV_FILE_VALUES=()

  [[ -d "$workflow_root" ]] || return 0

  local env_file
  for env_file in "$workflow_root/.env" "$workflow_root/.env.local"; do
    [[ -f "$env_file" ]] || continue
    while IFS=$'\t' read -r key value; do
      [[ -n "$key" ]] || continue
      local found=false
      local i
      for ((i = 0; i < ${#OO_ENV_FILE_KEYS[@]}; i++)); do
        if [[ "${OO_ENV_FILE_KEYS[$i]}" == "$key" ]]; then
          OO_ENV_FILE_VALUES[$i]="$value"
          found=true
          break
        fi
      done
      if [[ "$found" == false ]]; then
        OO_ENV_FILE_KEYS+=("$key")
        OO_ENV_FILE_VALUES+=("$value")
      fi
    done < <(python3 - "$env_file" <<'PY'
import re
import sys

path = sys.argv[1]
line_re = re.compile(r'^[A-Za-z_][A-Za-z0-9_]*$')

for raw in open(path, 'r', errors='replace').read().splitlines():
    stripped = raw.strip()
    if not stripped or stripped.startswith('#'):
        continue
    if stripped.startswith('export '):
        stripped = stripped[len('export '):].strip()
    if '=' not in stripped:
        continue
    key, value = stripped.split('=', 1)
    key = key.strip()
    value = value.strip()
    if not line_re.match(key):
        continue
    if (value.startswith('"') and value.endswith('"')) or (value.startswith("'") and value.endswith("'")):
        value = value[1:-1]
    print(f"{key}\t{value}")
PY
)
  done
}

resolved_env_var_value() {
  local name="$1"
  if [[ -n "${!name-}" ]]; then
    printf '%s' "${!name}"
    return 0
  fi

  local i
  for ((i = 0; i < ${#OO_ENV_FILE_KEYS[@]}; i++)); do
    if [[ "${OO_ENV_FILE_KEYS[$i]}" == "$name" ]]; then
      printf '%s' "${OO_ENV_FILE_VALUES[$i]}"
      return 0
    fi
  done

  printf ''
}

auth_entries_for_scope() {
  local repo="$1"
  local workflow_name="$2"
  local scope="$3"
  local override_file
  override_file="$(resolve_project_override_file "$repo" "$workflow_name")"

  ruby -ryaml -e '
path = ARGV[0]
scope = ARGV[1]
exit 0 unless File.exist?(path)
raw = YAML.safe_load(File.read(path), aliases: false)
data = raw.is_a?(Hash) ? raw : {}
auth = data["auth"].is_a?(Hash) ? data["auth"] : {}
entries = auth[scope].is_a?(Hash) ? auth[scope] : {}
entries.each do |name, cfg|
  next unless name.is_a?(String)
  cfg = cfg.is_a?(Hash) ? cfg : {}
  token_env = cfg["token_env"]
  next unless token_env.is_a?(String) && !token_env.strip.empty?
  source_hint = cfg["registry"] || cfg["source"] || name
  source_hint = source_hint.is_a?(String) ? source_hint : name
  puts [name, token_env, source_hint].join("\t")
end
' "$override_file" "$scope"
}

