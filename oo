collect_dependency_advisories_for_doctor() {
  local project_name="$1"
  DOCTOR_DEPENDENCY_LINES=()
  DOCTOR_DEPENDENCY_ACTIONS=()
  DOCTOR_DEPENDENCY_HAS_ADVISORIES=false

  local snapshot_file
  snapshot_file="$(dependency_advisory_file "$project_name")"
  [[ -f "$snapshot_file" ]] || return 0

  local line
  while IFS= read -r line; do
    [[ "$line" == ADVISORY=* ]] || continue
    local record="${line#ADVISORY=}"
    local warning
    while IFS= read -r warning; do
      [[ -n "$warning" ]] || continue
      if append_unique_line "$warning" "${DOCTOR_DEPENDENCY_LINES[@]-}"; then
        DOCTOR_DEPENDENCY_LINES+=("$warning")
      fi
    done < <(advisory_record_to_warning_lines "$record")

    local tool=""
    IFS='|' read -r tool _ <<<"$record"
    local action
    while IFS= read -r action; do
      [[ -n "$action" ]] || continue
      if append_unique_line "$action" "${DOCTOR_DEPENDENCY_ACTIONS[@]-}"; then
        DOCTOR_DEPENDENCY_ACTIONS+=("$action")
      fi
    done < <(dependency_actions_for_tool "$tool")
  done <"$snapshot_file"

  if [[ ${#DOCTOR_DEPENDENCY_LINES[@]} -gt 0 ]]; then
    DOCTOR_DEPENDENCY_HAS_ADVISORIES=true
  fi
}

