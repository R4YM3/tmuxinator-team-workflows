#!/usr/bin/env bash
set -euo pipefail

SCRIPT_PATH="${BASH_SOURCE[0]}"
while [[ -L "$SCRIPT_PATH" ]]; do
  SCRIPT_DIR="$(cd -P "$(dirname "$SCRIPT_PATH")" && pwd)"
  SCRIPT_PATH="$(readlink "$SCRIPT_PATH")"
  [[ "$SCRIPT_PATH" == /* ]] || SCRIPT_PATH="$SCRIPT_DIR/$SCRIPT_PATH"
done

RUNTIME_DIR="$(cd -P "$(dirname "$SCRIPT_PATH")" && pwd)"
DEFAULT_OO_HOME="${HOME}/.local/share/oo"
DEFAULT_OO_BIN_DIR="${HOME}/.local/bin"
TMUXINATOR_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/tmuxinator"
OO_CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/oo"
OO_CONFIG_FILE="$OO_CONFIG_DIR/config.yml"
SERVICES_DIR="$RUNTIME_DIR/services"
SERVICE_STATE_ROOT="${XDG_DATA_HOME:-$HOME/.local/share}/oo/state/services"
DEP_ADVISORY_STATE_ROOT="${XDG_DATA_HOME:-$HOME/.local/share}/oo/state/dependencies"
ANALYTICS_STATE_ROOT="${XDG_DATA_HOME:-$HOME/.local/share}/oo/state/analytics"
ANALYTICS_EVENT_LOG="$ANALYTICS_STATE_ROOT/events.jsonl"
SERVICE_CHECK_TIMEOUT_SEC="${OO_SERVICE_CHECK_TIMEOUT_SEC:-4.0}"

START_MISSING_SERVICES=()
START_TIMEOUT_SERVICES=()
START_FAILED_SERVICES=()
INSTALL_CANDIDATES=()
CHECKBOX_SELECTED=()
PROJECT_DEP_COMMANDS=()
PROJECT_DEP_LABELS=()
INSTALL_WARNING_LINES=()
INSTALL_WARNING_ACTION_LINES=()
INSTALL_CHANGED_LINES=()
DEPENDENCY_ADVISORY_RECORDS=()
OO_COMMAND_ENV_OVERRIDES=()
SERVICE_AUTH_ISSUES=()
OO_ENV_FILE_KEYS=()
OO_ENV_FILE_VALUES=()
ANALYTICS_COMMAND=""
ANALYTICS_FLAGS=()
ANALYTICS_START_MS=0
ANALYTICS_DOCTOR_ISSUES=0
ANALYTICS_DOCTOR_DEP_ADVISORIES=0
ANALYTICS_ERROR_CODE=""
ANALYTICS_ERROR_DOMAIN=""

ok() { printf "\033[1;32m[ok]\033[0m %s\n" "$1"; }
info() { printf "\033[1;34m[info]\033[0m %s\n" "$1"; }

set_analytics_error_code() {
  local code="$1"
  if [[ "$code" =~ ^[A-Z]{3}-[0-9]{3}$ ]]; then
    ANALYTICS_ERROR_CODE="$code"
    ANALYTICS_ERROR_DOMAIN="${code%%-*}"
  fi
}

capture_error_code_from_text() {
  local text="$1"
  if [[ "$text" =~ ([A-Z]{3}-[0-9]{3}) ]]; then
    set_analytics_error_code "${BASH_REMATCH[1]}"
  fi
}

warn() {
  capture_error_code_from_text "$1"
  printf "\033[1;33m[warn]\033[0m %s\n" "$1"
}

error() {
  capture_error_code_from_text "$1"
  printf "\033[1;31m[error]\033[0m %s\n" "$1" >&2
}

error_block() {
  local code="$1"
  local title="$2"
  local reason="$3"
  shift 3

  local context_line=""
  if [[ "${1:-}" == "--context" ]]; then
    context_line="${2:-}"
    shift 2
  fi

  set_analytics_error_code "$code"

  echo "✖ $title ($code)"
  echo
  echo "Reason"
  echo "  $reason"
  if [[ -n "$context_line" ]]; then
    echo
    echo "Context"
    echo "  $context_line"
  fi
  echo
  echo "What you can do"
  local step
  for step in "$@"; do
    echo "  • $step"
  done
}

install_failure_block_with_details() {
  local code="$1"
  local reason="$2"
  local details="$3"
  shift 3

  set_analytics_error_code "$code"

  echo "✖ Install failed ($code)"
  echo
  echo "Reason"
  echo "  $reason"
  if [[ -n "$details" ]]; then
    echo
    echo "Details"
    while IFS= read -r line; do
      [[ -n "$line" ]] || continue
      echo "  $line"
    done <<<"$details"
  fi
  echo
  echo "What you can do"
  local step
  for step in "$@"; do
    echo "  • $step"
  done
}

spinner_should_render() {
  local verbose_mode="${1:-false}"
  [[ "$verbose_mode" != true && -t 1 ]]
}

spinner_start() {
  local label="$1"
  local show_percent="${2:-false}"
  local frames=("⠋" "⠙" "⠹" "⠸" "⠼" "⠴" "⠦" "⠧" "⠇" "⠏")
  (
    local i=0
    local percent=0
    local tick=0
    while :; do
      if [[ "$show_percent" == true ]]; then
        if [[ "$percent" -lt 80 ]]; then
          percent=$((percent + 1))
        elif [[ "$percent" -lt 95 ]] && [[ $((tick % 4)) -eq 0 ]]; then
          percent=$((percent + 1))
        fi
        printf "\r  %s %s (%d%%)" "${frames[$((i % ${#frames[@]}))]}" "$label" "$percent"
      else
        printf "\r  %s %s" "${frames[$((i % ${#frames[@]}))]}" "$label"
      fi
      sleep 0.1
      i=$((i + 1))
      tick=$((tick + 1))
    done
  ) &
  SPINNER_PID=$!
  SPINNER_LABEL="$label"
}

spinner_stop() {
  local status="$1"
  local label="${2:-$SPINNER_LABEL}"
  if [[ -n "${SPINNER_PID:-}" ]]; then
    kill "$SPINNER_PID" >/dev/null 2>&1 || true
    wait "$SPINNER_PID" 2>/dev/null || true
    SPINNER_PID=""
  fi

  printf "\r\033[2K"
  if [[ "$status" -eq 0 ]]; then
    if [[ "$label" == Installing\ * ]]; then
      printf "  ✓ Installed %s\n" "${label#Installing }"
    else
      printf "  ✓ %s\n" "$label"
    fi
  else
    printf "  ✖ %s\n" "$label"
  fi
}

run_logged_step() {
  local label="$1"
  local verbose_mode="$2"
  local log_file="$3"
  local show_percent="${4:-false}"
  shift 4

  if [[ "$verbose_mode" == true ]]; then
    echo "  ... $label"
    set +e
    "$@" >"$log_file" 2>&1
    local rc=$?
    set -e
    cat "$log_file"
    return "$rc"
  fi

  if spinner_should_render "$verbose_mode"; then
    spinner_start "$label" "$show_percent"
    set +e
    "$@" >"$log_file" 2>&1
    local rc=$?
    set -e
    spinner_stop "$rc" "$label"
    return "$rc"
  fi

  echo "  ... $label"
  set +e
  "$@" >"$log_file" 2>&1
  local rc=$?
  set -e
  if [[ "$rc" -eq 0 ]]; then
    echo "  ✓ $label"
  else
    echo "  ✖ $label"
  fi
  return "$rc"
}

