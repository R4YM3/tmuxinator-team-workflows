advisory_record_to_warning_lines() {
  local record="$1"
  IFS='|' read -r tool config_warn deprecated_count vuln_total low moderate high critical <<<"$record"

  if [[ "$config_warn" == "1" ]]; then
    if [[ "$tool" == "npm" ]]; then
      echo "npm config contains deprecated or invalid settings"
    else
      echo "$tool configuration contains deprecated or invalid settings"
    fi
  fi

  if [[ "$deprecated_count" =~ ^[0-9]+$ ]] && [[ "$deprecated_count" -gt 0 ]]; then
    if [[ "$tool" == "npm" ]]; then
      echo "Deprecated packages detected ($deprecated_count)"
    else
      echo "$tool deprecated packages detected ($deprecated_count)"
    fi
  fi

  if [[ "$vuln_total" =~ ^[0-9]+$ ]] && [[ "$vuln_total" -gt 0 ]]; then
    local details=""
    [[ "$low" =~ ^[0-9]+$ ]] && [[ "$low" -gt 0 ]] && details+="${low} low, "
    [[ "$moderate" =~ ^[0-9]+$ ]] && [[ "$moderate" -gt 0 ]] && details+="${moderate} moderate, "
    [[ "$high" =~ ^[0-9]+$ ]] && [[ "$high" -gt 0 ]] && details+="${high} high, "
    [[ "$critical" =~ ^[0-9]+$ ]] && [[ "$critical" -gt 0 ]] && details+="${critical} critical, "
    details="${details%, }"

    if [[ "$tool" == "npm" ]]; then
      if [[ -n "$details" ]]; then
        echo "$vuln_total vulnerabilities reported ($details)"
      else
        echo "$vuln_total vulnerabilities reported"
      fi
    else
      if [[ -n "$details" ]]; then
        echo "$tool reported $vuln_total vulnerabilities ($details)"
      else
        echo "$tool reported $vuln_total vulnerabilities"
      fi
    fi
  fi
}

