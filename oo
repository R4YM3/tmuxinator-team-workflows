summarize_npm_install_warnings() {
  local log_file="$1"

  python3 - "$log_file" <<'PY'
import re
import sys

path = sys.argv[1]
text = open(path, 'r', errors='replace').read()
lines = text.splitlines()

deprecations = sum(1 for line in lines if re.search(r'\bdeprecated\b', line, re.I))
config_warn = any(re.search(r'npm\s+warn\s+.*config|npm\s+warn\s+config', line, re.I) for line in lines)

vuln_line = None
vuln_total = None
severity = {}
for line in lines:
    m = re.search(r'(\d+) vulnerabilities?\s*\(([^)]*)\)', line, re.I)
    if m:
        vuln_total = int(m.group(1))
        vuln_line = m.group(2).strip()
        for part in vuln_line.split(','):
            part = part.strip()
            mm = re.match(r'(\d+)\s+(low|moderate|high|critical)', part, re.I)
            if mm:
                severity[mm.group(2).lower()] = int(mm.group(1))

print("ADVISORY|npm|{}|{}|{}|{}|{}|{}|{}".format(
    1 if config_warn else 0,
    deprecations,
    vuln_total if vuln_total is not None else 0,
    severity.get('low', 0),
    severity.get('moderate', 0),
    severity.get('high', 0),
    severity.get('critical', 0),
))
PY
}

summarize_dotnet_restore_warnings() {
  local log_file="$1"

  python3 - "$log_file" <<'PY'
import re
import sys

path = sys.argv[1]
text = open(path, 'r', errors='replace').read()
lines = text.splitlines()

deprecated = sum(1 for line in lines if re.search(r'\bdeprecated\b', line, re.I))

nu190 = {
    'low': sum(1 for line in lines if re.search(r'\bNU1901\b', line, re.I)),
    'moderate': sum(1 for line in lines if re.search(r'\bNU1902\b', line, re.I)),
    'high': sum(1 for line in lines if re.search(r'\bNU1903\b', line, re.I)),
    'critical': sum(1 for line in lines if re.search(r'\bNU1904\b', line, re.I)),
}

severity = dict(nu190)
vuln_total = sum(severity.values())

if vuln_total == 0:
    for line in lines:
        m = re.search(r'(\d+)\s+vulnerabilit(?:y|ies)', line, re.I)
        if m:
            vuln_total = int(m.group(1))
            break

for line in lines:
    m = re.search(r'(\d+)\s+(low|moderate|high|critical)', line, re.I)
    if m:
        level = m.group(2).lower()
        severity[level] = max(severity.get(level, 0), int(m.group(1)))

print("ADVISORY|nuget|0|{}|{}|{}|{}|{}|{}".format(
    deprecated,
    vuln_total,
    severity.get('low', 0),
    severity.get('moderate', 0),
    severity.get('high', 0),
    severity.get('critical', 0),
))
PY
}

summarize_npm_audit_report() {
  local log_file="$1"

  python3 - "$log_file" <<'PY'
import json
import re
import sys

text = open(sys.argv[1], 'r', errors='replace').read()
json_start = text.find('{')
if json_start == -1:
    sys.exit(0)

payload = None
for end in range(len(text), json_start, -1):
    snippet = text[json_start:end]
    try:
      payload = json.loads(snippet)
      break
    except Exception:
      continue

if not isinstance(payload, dict):
    sys.exit(0)

meta = payload.get('metadata') if isinstance(payload.get('metadata'), dict) else {}
vuln = meta.get('vulnerabilities') if isinstance(meta.get('vulnerabilities'), dict) else {}

low = int(vuln.get('low') or 0)
moderate = int(vuln.get('moderate') or 0)
high = int(vuln.get('high') or 0)
critical = int(vuln.get('critical') or 0)
total = int(vuln.get('total') or (low + moderate + high + critical))

print("ADVISORY|npm|0|0|{}|{}|{}|{}|{}".format(total, low, moderate, high, critical))
PY
}

summarize_dotnet_audit_reports() {
  local vuln_log_file="$1"
  local deprecated_log_file="$2"

  python3 - "$vuln_log_file" "$deprecated_log_file" <<'PY'
import re
import sys

vuln_text = open(sys.argv[1], 'r', errors='replace').read()
deprecated_text = open(sys.argv[2], 'r', errors='replace').read()

low = len(re.findall(r'\blow\b', vuln_text, flags=re.I))
moderate = len(re.findall(r'\bmoderate\b', vuln_text, flags=re.I))
high = len(re.findall(r'\bhigh\b', vuln_text, flags=re.I))
critical = len(re.findall(r'\bcritical\b', vuln_text, flags=re.I))

nu190 = {
    'low': len(re.findall(r'\bNU1901\b', vuln_text, flags=re.I)),
    'moderate': len(re.findall(r'\bNU1902\b', vuln_text, flags=re.I)),
    'high': len(re.findall(r'\bNU1903\b', vuln_text, flags=re.I)),
    'critical': len(re.findall(r'\bNU1904\b', vuln_text, flags=re.I)),
}

low = max(low, nu190['low'])
moderate = max(moderate, nu190['moderate'])
high = max(high, nu190['high'])
critical = max(critical, nu190['critical'])

deprecated_count = len(re.findall(r'\bdeprecated\b', deprecated_text, flags=re.I))
vuln_total = low + moderate + high + critical

