  validate_project_name "$PARSED_PROJECT_NAME"

  local repo
  repo="$(require_workflow_repo)"
  ensure_project_exists "$repo" "$PARSED_PROJECT_NAME"

  remove_service_from_project_config "$repo" "$PARSED_PROJECT_NAME" "$PARSED_SERVICE_NAME"
  ok "Removed service '$PARSED_SERVICE_NAME' from workflow '$PARSED_PROJECT_NAME'"
}

cmd_service_list() {
  parse_service_scope_args "Usage: oo service list [--workflow <workflow> | --global]" false "$@"

  echo "Available services:"
  local available=()
  local p=""
  while IFS= read -r p; do
    [[ -n "$p" ]] || continue
    available+=("$p")
    echo "  - $p"
  done < <(list_available_services)
  if [[ ${#available[@]} -eq 0 ]]; then
    echo "  (none)"
  fi

  if [[ -z "$PARSED_PROJECT_NAME" && "$PARSED_GLOBAL" != true ]]; then
    return 0
  fi

  local repo
  repo="$(require_workflow_repo)"

  if [[ -n "$PARSED_PROJECT_NAME" ]]; then
    validate_project_name "$PARSED_PROJECT_NAME"
    ensure_project_exists "$repo" "$PARSED_PROJECT_NAME"
    echo
    echo "Configured services for '$PARSED_PROJECT_NAME':"
    local any=false
    while IFS= read -r p; do
      [[ -n "$p" ]] || continue
      any=true
      echo "  - $p"
    done < <(enabled_services_for_project "$repo" "$PARSED_PROJECT_NAME")
    [[ "$any" == true ]] || echo "  (none)"
    return 0
  fi

  echo
  echo "Configured services by workflow:"
  local proj=""
  while IFS= read -r proj; do
    [[ -n "$proj" ]] || continue
    echo "- $proj"
    local any=false
    while IFS= read -r p; do
      [[ -n "$p" ]] || continue
      any=true
      echo "    - $p"
    done < <(enabled_services_for_project "$repo" "$proj")
    [[ "$any" == true ]] || echo "    (none)"
  done < <(list_projects_in_repo "$repo")
}

cmd_service_install() {
  parse_service_scope_args "Usage: oo service install [--workflow <workflow>] [--yes] | --global [--yes]" true "$@"

  if [[ -z "$PARSED_PROJECT_NAME" && "$PARSED_GLOBAL" != true ]]; then
    error "Missing scope: use --workflow <name>, --global, or run from a linked workflow repo"
    exit 1
  fi

  local repo
  repo="$(require_workflow_repo)"

  if [[ -n "$PARSED_PROJECT_NAME" ]]; then
    validate_project_name "$PARSED_PROJECT_NAME"
    run_service_install_for_project "$repo" "$PARSED_PROJECT_NAME" "$PARSED_ASSUME_YES"
    return 0
  fi

  local proj=""
  while IFS= read -r proj; do
    [[ -n "$proj" ]] || continue
    run_service_install_for_project "$repo" "$proj" "$PARSED_ASSUME_YES"
  done < <(list_projects_in_repo "$repo")
}

cmd_service_help() {
  cat <<'EOF'
Usage: oo service <command> [options]

Commands:
  add <service> [--workflow <workflow>]
  remove <service> [--workflow <workflow>]
  list [--workflow <workflow> | --global]
  install [--workflow <workflow>] [--yes]
  install --global [--yes]
EOF
}

cmd_service() {
  local subcommand="${1:-}"
  shift || true

  case "$subcommand" in
  add)
    cmd_service_add "$@"
    ;;
  remove)
    cmd_service_remove "$@"
    ;;
  list)
    cmd_service_list "$@"
    ;;
  install)
    cmd_service_install "$@"
    ;;
  help | -h | --help | "")
    cmd_service_help
    ;;
  *)
    error "Unknown service subcommand: $subcommand"
    info "Run: oo service --help"
    exit 1
    ;;
  esac
}

cmd_validate() {
  local workflow_repo
  workflow_repo="$(require_workflow_repo)"
  OO_WORKFLOW_REPO="$workflow_repo" bash "$RUNTIME_DIR/scripts/validate-workflows.sh"
}

cmd_doctor() {
  local project_name=""
  local global_mode=false
  local fix_mode=false
  local assume_yes=false
  local verbose_mode=false
  local refresh_deps=false
  local inferred_project=false

  while [[ $# -gt 0 ]]; do
    case "$1" in
    --workflow)
      [[ $# -ge 2 ]] || {
        error "--workflow requires a workflow name"
        exit 1
      }
      project_name="$2"
      shift 2
      ;;
    --global)
      global_mode=true
      shift
      ;;
    --fix)
      fix_mode=true
      shift
      ;;
    --yes)
      assume_yes=true
      shift
      ;;
    --verbose)
      verbose_mode=true
      shift
      ;;
    --refresh-deps)
      refresh_deps=true
      shift
      ;;
    -h | --help)
      cat <<'EOF'
Usage: oo doctor [--workflow <workflow> | --global] [--fix] [--yes] [--verbose] [--refresh-deps]

Diagnoses runtime and service readiness.
Use --fix to run safe automatic service installs.
Use --refresh-deps to refresh dependency advisories before reporting.
EOF
      return 0
      ;;
    *)
      error "Unexpected argument: $1"
      exit 1
      ;;
    esac
  done

  if [[ -n "$project_name" && "$global_mode" == true ]]; then
    error "Use either --workflow or --global, not both"
    exit 1
  fi

  local workflow_repo
  workflow_repo="$(detect_workflow_repo)"

  if [[ -z "$project_name" && "$global_mode" != true ]]; then
    project_name="$(infer_start_project_from_context)"
    if [[ -n "$project_name" ]]; then
      inferred_project=true
    fi
  fi

  local tmux_ok=false
  local tmuxinator_ok=false
  local ruby_ok=false
  local issue_count=0
  local env_issue_count=0
  local project_issue_count=0
  local dependency_advisory_count=0
  local env_ok_items=()
  local env_missing_items=()
  local doctor_dependency_lines=()
  local doctor_dependency_actions=()

  command -v tmux >/dev/null 2>&1 && tmux_ok=true
  command -v tmuxinator >/dev/null 2>&1 && tmuxinator_ok=true
  command -v ruby >/dev/null 2>&1 && ruby_ok=true

  [[ "$tmux_ok" == true ]] && env_ok_items+=("tmux") || env_missing_items+=("tmux")
  [[ "$tmuxinator_ok" == true ]] && env_ok_items+=("tmuxinator") || env_missing_items+=("tmuxinator")
  [[ "$ruby_ok" == true ]] && env_ok_items+=("ruby") || env_missing_items+=("ruby")

  env_issue_count=${#env_missing_items[@]}
  issue_count=$((issue_count + env_issue_count))

  echo "◆ Doctor"
  if [[ "$global_mode" == true ]]; then
    echo "  Workflow: all"
  elif [[ -n "$project_name" ]]; then
    if [[ "$inferred_project" == true ]]; then
      echo "  Workflow: $project_name (inferred)"
    else
      echo "  Workflow: $project_name"
    fi
  else
    echo "  Workflow: none"
  fi
  echo

  echo "Environment"
  if [[ "$verbose_mode" != true && ${#env_missing_items[@]} -eq 0 ]]; then
    echo "  ✓ All runtime tools available (tmux, tmuxinator, ruby)"
  else
    [[ "$tmux_ok" == true ]] && echo "  ✓ tmux installed" || echo "  ! tmux not installed"
    [[ "$tmuxinator_ok" == true ]] && echo "  ✓ tmuxinator installed" || echo "  ! tmuxinator not installed"
    [[ "$ruby_ok" == true ]] && echo "  ✓ ruby installed" || echo "  ! ruby not installed"
  fi
  echo

  if [[ "$refresh_deps" == true ]]; then
    echo "Dependency advisories"
    echo "  ✓ Refresh requested"
    echo
  fi

  local workflows=()
  local proj=""
  local workflow_repo
  workflow_repo="$(detect_workflow_repo)"

  if [[ -z "$project_name" && "$global_mode" != true && -z "$workflow_repo" ]]; then
    error "No workflow context found"
    info "Run from a linked workflow repo, or pass --workflow <name> or --global"
    exit 1
  fi

  echo "Workflow"

  if [[ -z "$workflow_repo" ]]; then
    echo "  ! Team workflow root is not configured"
    issue_count=$((issue_count + 1))
    project_issue_count=$((project_issue_count + 1))
  elif [[ "$global_mode" == true ]]; then
    while IFS= read -r proj; do
      [[ -n "$proj" ]] || continue
      workflows+=("$proj")
    done < <(list_projects_in_repo "$workflow_repo")
  elif [[ -n "$project_name" ]]; then
    validate_project_name "$project_name"
    workflows+=("$project_name")
  fi

  local fix_candidates=()
  local workflow

  for workflow in "${workflows[@]}"; do
    ensure_project_exists "$workflow_repo" "$workflow"

    local workflow_root_for_auth
    workflow_root_for_auth="$(project_root_for_project "$workflow_repo" "$workflow" 2>/dev/null || true)"
    if [[ -n "$workflow_root_for_auth" && -d "$workflow_root_for_auth" ]]; then
      load_env_file_values "$workflow_root_for_auth"
    else
      OO_ENV_FILE_KEYS=()
      OO_ENV_FILE_VALUES=()
    fi

    collect_service_auth_issues "$workflow_repo" "$workflow"

    if [[ "$refresh_deps" == true ]]; then
      refresh_dependency_advisories_for_project "$workflow_repo" "$workflow" "$verbose_mode"
    fi

    collect_dependency_advisories_for_doctor "$workflow"
    if [[ "$DOCTOR_DEPENDENCY_HAS_ADVISORIES" == true ]]; then
      local dep_line
      for dep_line in "${DOCTOR_DEPENDENCY_LINES[@]}"; do
        if [[ "$global_mode" == true ]]; then
          dep_line="$workflow: $dep_line"
        fi
        if append_unique_line "$dep_line" "${doctor_dependency_lines[@]-}"; then
          doctor_dependency_lines+=("$dep_line")
          dependency_advisory_count=$((dependency_advisory_count + 1))
        fi
      done

      local dep_action
      for dep_action in "${DOCTOR_DEPENDENCY_ACTIONS[@]}"; do
        if append_unique_line "$dep_action" "${doctor_dependency_actions[@]-}"; then
          doctor_dependency_actions+=("$dep_action")
        fi
      done
    fi

    load_enabled_services_for_project "$workflow_repo" "$workflow"
    if [[ ${#LOADED_PROJECT_SERVICES[@]} -eq 0 ]]; then
      if [[ "$global_mode" == true ]]; then
        echo "  ✓ $workflow: no services configured"
      else
        echo "  ✓ No services configured"
      fi
      continue
    fi

    local service
    local project_needs_fix=false
    local project_ready_services=()
    local project_issues=()
    for service in "${LOADED_PROJECT_SERVICES[@]}"; do
      require_service "$service"
      build_service_state_context "$workflow_repo" "$workflow" "$service"

      local check_rc=0
      set +e
      run_service_check_with_timeout "$SERVICE_CTX_SCRIPT" "$SERVICE_CTX_CONFIG_JSON" "$SERVICE_CHECK_TIMEOUT_SEC"
      check_rc=$?
      set -e

      if [[ "$check_rc" -eq 0 ]]; then
        project_ready_services+=("$service")
      elif [[ "$check_rc" -eq 124 ]]; then
        project_needs_fix=true
        project_issues+=("$service timed out")
      else
        project_needs_fix=true
        project_issues+=("$service not ready")
      fi
    done

    if [[ "$project_needs_fix" == true ]]; then
      fix_candidates+=("$workflow")
      project_issue_count=$((project_issue_count + ${#project_issues[@]}))
      issue_count=$((issue_count + ${#project_issues[@]}))
      if [[ "$global_mode" == true ]]; then
        echo "  ! $workflow: ${#project_issues[@]} issue(s)"
      else
        local issue
        for issue in "${project_issues[@]}"; do
          echo "  ! $issue"
        done
        local auth_issue
        for auth_issue in "${SERVICE_AUTH_ISSUES[@]}"; do
          echo "  ! auth: $auth_issue"
        done
      fi
      if [[ ${#SERVICE_AUTH_ISSUES[@]} -gt 0 ]]; then
        project_issue_count=$((project_issue_count + ${#SERVICE_AUTH_ISSUES[@]}))
        issue_count=$((issue_count + ${#SERVICE_AUTH_ISSUES[@]}))
      fi
    else
      if [[ ${#SERVICE_AUTH_ISSUES[@]} -gt 0 ]]; then
        fix_candidates+=("$workflow")
        project_issue_count=$((project_issue_count + ${#SERVICE_AUTH_ISSUES[@]}))
        issue_count=$((issue_count + ${#SERVICE_AUTH_ISSUES[@]}))
        if [[ "$global_mode" == true ]]; then
          echo "  ! $workflow: ${#SERVICE_AUTH_ISSUES[@]} auth issue(s)"
        else
          local auth_issue
          for auth_issue in "${SERVICE_AUTH_ISSUES[@]}"; do
            echo "  ! auth: $auth_issue"
          done
        fi
        continue
      fi

      if [[ "$global_mode" == true ]]; then
        echo "  ✓ $workflow: ready"
      elif [[ "$verbose_mode" == true || ${#project_ready_services[@]} -le 2 ]]; then
        local ready_service
        for ready_service in "${project_ready_services[@]}"; do
          echo "  ✓ $(service_display_name "$ready_service") ready"
        done
      else
        echo "  ✓ All workflow services ready ($(join_by_comma "${project_ready_services[@]}"))"
      fi
    fi
  done

  echo
  if [[ "$dependency_advisory_count" -gt 0 ]]; then
    echo "Dependencies"
    local dep_warning
    for dep_warning in "${doctor_dependency_lines[@]}"; do
      echo "  ! $dep_warning"
    done
    echo
    echo "What you can do"
    local dep_action
    for dep_action in "${doctor_dependency_actions[@]}"; do
      case "$dep_action" in
      npm\ audit)
        echo "  • Details: npm audit"
        ;;
      npm\ audit\ fix)
        echo "  • Safe fixes: npm audit fix"
        ;;
      oo\ install)
        echo "  • Refresh advisories: oo install"
        ;;
      *)
        echo "  • $dep_action"
        ;;
      esac
    done
    echo
  fi

  local install_cmd="oo install"
  if [[ "$global_mode" == true ]]; then
    install_cmd="oo install --workflow <workflow>"
  elif [[ -n "$project_name" ]]; then
    local inferred
    inferred="$(infer_start_project_from_context)"
    if [[ "$inferred" != "$project_name" ]]; then
      install_cmd="oo install --workflow $project_name"
    fi
  fi

  ANALYTICS_DOCTOR_ISSUES="$issue_count"
  ANALYTICS_DOCTOR_DEP_ADVISORIES="$dependency_advisory_count"

  if [[ "$issue_count" -eq 0 ]]; then
    echo "✓ System healthy"
    echo "  No issues found"
    if [[ "$global_mode" != true ]]; then
      echo
      echo "Next:"
      echo "  oo start"
    fi
  else
    if [[ "$env_issue_count" -gt 0 && "$project_issue_count" -gt 0 ]]; then
      echo "✖ Workflow not ready (DOC-021)"
    else
      echo "! Setup incomplete"
    fi
    echo "  $issue_count issue(s) found"
    echo
    echo "What you can do"
    echo "  • Install environment: $install_cmd"
    echo "  • Re-check: oo doctor"
  fi

  if [[ "$fix_mode" == true && ${#fix_candidates[@]} -gt 0 ]]; then
    if [[ "$assume_yes" != true ]]; then
      if ! confirm_remove "Run safe service installs for suggested workflows?"; then
        info "Skipped automatic fixes"
        return 0
      fi
    fi

    local seen=""
    local p
    for p in "${fix_candidates[@]}"; do
      if [[ ",${seen}," == *",$p,"* ]]; then
        continue
      fi
      seen="${seen},$p"
      info "Applying fixes for workflow '$p'"
      run_service_install_for_project "$workflow_repo" "$p" "$assume_yes"
    done
    ok "Doctor fix run completed"
  fi
}

cmd_install() {
  local project_name=""
  local assume_yes=false
  local plan_only=false
  local skip_project_deps=false
  local disable_analytics=false
  local verbose_mode=false
  local changed_items=()

  while [[ $# -gt 0 ]]; do
    case "$1" in
    --workflow)
      [[ $# -ge 2 ]] || {
        error "--workflow requires a workflow name"
        exit 1
      }
      project_name="$2"
      shift 2
      ;;
    --yes)
      assume_yes=true
      shift
      ;;
    --plan)
      plan_only=true
      shift
      ;;
    --no-workflow-deps)
      skip_project_deps=true
      shift
      ;;
    --no-analytics)
      disable_analytics=true
      shift
      ;;
    --verbose)
      verbose_mode=true
      shift
      ;;
    -h | --help)
      cat <<'EOF'
Usage: oo install [--workflow <workflow>] [--yes] [--plan] [--no-workflow-deps] [--no-analytics] [--verbose]

Installs machine readiness requirements and workflow dependencies.
EOF
      return 0
      ;;
    *)
      error "Unexpected argument: $1"
      info "Usage: oo install [--workflow <workflow>] [--yes] [--plan] [--no-workflow-deps] [--no-analytics] [--verbose]"
      exit 1
      ;;
    esac
  done

  if [[ "$disable_analytics" == true ]]; then
    write_config_analytics_enabled false
    info "Analytics disabled for future runs"
  fi

  if [[ -z "$project_name" ]]; then
    project_name="$(infer_start_project_from_context)"
    if [[ -n "$project_name" ]]; then
      info "No --workflow provided; inferred '$project_name'"
    fi
  fi

  if [[ -z "$project_name" ]]; then
    error "Missing workflow name"
    info "Usage: oo install [--workflow <workflow>] [--yes]"
    info "Tip: run from a linked workflow repo or pass --workflow <name>"
    exit 1
  fi

  validate_project_name "$project_name"

  local workflow_repo
  workflow_repo="$(require_workflow_repo)"
  ensure_project_exists "$workflow_repo" "$project_name"

  echo "◆ Installing $project_name"
  echo
  echo "Environment"

  report_service_readiness_for_start "$workflow_repo" "$project_name" true "$verbose_mode"
  collect_install_candidates_for_project

  local formatted_missing=()
  local formatted_candidates=()
  local service=""
  for service in "${START_MISSING_SERVICES[@]-}"; do
    [[ -n "$service" ]] || continue
    formatted_missing+=("$(service_requirement_label "$service")")
  done
  for service in "${INSTALL_CANDIDATES[@]-}"; do
    [[ -n "$service" ]] || continue
    formatted_candidates+=("$(service_requirement_label "$service")")
  done

  if [[ "$plan_only" == true ]]; then
    echo "Plan"
    if [[ ${#formatted_candidates[@]} -gt 0 ]]; then
      echo "  Will set up: $(join_by_comma "${formatted_candidates[@]}")"
    else
      local ready_services=()
      for service in "${LOADED_PROJECT_SERVICES[@]-}"; do
        [[ -n "$service" ]] || continue
        ready_services+=("$service")
      done
      if [[ ${#ready_services[@]} -gt 0 ]]; then
        echo "  Environment already OK: $(join_by_comma "${ready_services[@]}")"
      else
        echo "  Environment already OK"
      fi
    fi

    local project_root_plan
    project_root_plan="$(project_root_for_project "$workflow_repo" "$project_name")"
    if [[ -n "$project_root_plan" && -d "$project_root_plan" ]]; then
      collect_project_dependency_commands "$project_root_plan"
      if [[ "$skip_project_deps" == true ]]; then
        echo "  Dependencies: skipped by flag"
      elif [[ ${#PROJECT_DEP_COMMANDS[@]} -gt 0 ]]; then
        echo "  Will run dependencies: $(join_by_comma "${PROJECT_DEP_LABELS[@]}")"
      else
        echo "  Dependencies: none detected"
      fi
    fi
    return 0
  fi

  local selected_services=()
  if [[ ${#INSTALL_CANDIDATES[@]-0} -eq 0 ]]; then
    local ready_services=()
    for service in "${LOADED_PROJECT_SERVICES[@]-}"; do
      [[ -n "$service" ]] || continue
      ready_services+=("$service")
    done
    if [[ ${#ready_services[@]} -gt 0 ]]; then
      echo "  ✓ All requirements satisfied ($(join_by_comma "${ready_services[@]}"))"
    else
      echo "  ✓ All requirements satisfied"
    fi
  else
    if [[ ${#START_MISSING_SERVICES[@]-0} -gt 0 ]]; then
      echo "  ! Needs setup: $(join_by_comma "${formatted_missing[@]}")"
    fi
    if [[ ${#START_TIMEOUT_SERVICES[@]-0} -gt 0 || ${#START_FAILED_SERVICES[@]-0} -gt 0 ]]; then
      echo "  ! Needs verification: $(join_by_comma "${formatted_candidates[@]}")"
    fi

    selected_services=("${INSTALL_CANDIDATES[@]-}")

    if install_selected_services_for_project "$workflow_repo" "$project_name" "$assume_yes" "$verbose_mode" "${selected_services[@]}"; then
      changed_items+=("Installed environment requirements")
    fi
  fi

  local project_root
  project_root="$(project_root_for_project "$workflow_repo" "$project_name")"
  if [[ -z "$project_root" || ! -d "$project_root" ]]; then
    error_block "INS-021" "Install failed" "Could not resolve workflow root from workflow config" "Run again with --verbose" "Check workflow config files"
    return 1
  fi

  load_env_file_values "$project_root"
  build_env_overrides_for_command

  collect_project_dependency_commands "$project_root"

  local install_project_dependencies=false
  if [[ "$skip_project_deps" == true ]]; then
    install_project_dependencies=false
  elif [[ ${#PROJECT_DEP_COMMANDS[@]} -eq 0 ]]; then
    install_project_dependencies=false
  elif [[ "$assume_yes" == true ]]; then
    install_project_dependencies=true
  elif ! is_interactive_terminal; then
    install_project_dependencies=true
  else
    install_project_dependencies=true
  fi

  if [[ "$skip_project_deps" != true ]]; then
    echo
  fi

  if [[ "$install_project_dependencies" == true ]]; then
    if ! validate_source_auth_requirements "$workflow_repo" "$project_name"; then
      return 1
    fi
    if run_project_dependency_commands "$project_root" "$verbose_mode"; then
      write_dependency_advisory_snapshot "$project_name"
      if [[ ${#INSTALL_CHANGED_LINES[@]} -gt 0 ]]; then
        local changed_line
        for changed_line in "${INSTALL_CHANGED_LINES[@]}"; do
          changed_items+=("$changed_line")
        done
      fi
    else
      return 1
    fi
  elif [[ "$skip_project_deps" == true ]]; then
    echo "Dependencies"
    echo "  ✓ skipped (--no-workflow-deps)"
  elif [[ ${#PROJECT_DEP_COMMANDS[@]} -eq 0 ]]; then
    echo "Dependencies"
    echo "  ✓ none detected"
  else
    echo "Dependencies"
    echo "  ✓ skipped"
  fi

  echo
  echo "✓ Install complete"
  if [[ ${#changed_items[@]} -eq 0 ]]; then
    echo "  No changes needed"
  else
    echo "  Changed:"
    local changed_item
    for changed_item in "${changed_items[@]}"; do
      echo "  - $changed_item"
    done
  fi
  echo
  echo "Next:"
  echo "  Run your workflow → oo start"
}

cmd_update() {
  local verbose=false

  while [[ $# -gt 0 ]]; do
    case "$1" in
    --verbose)
      verbose=true
      shift
      ;;
    -h | --help)
      cat <<'EOF'
Usage: oo update [--verbose]

Pulls the latest oo runtime and refreshes the oo CLI symlink.
EOF
      return 0
      ;;
    *)
      error "Unexpected argument: $1"
      info "Usage: oo update [--verbose]"
      return 1
      ;;
    esac
  done

  if ! command -v git >/dev/null 2>&1; then
    error "git is required for oo update"
    exit 1
  fi

  if ! git -C "$RUNTIME_DIR" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    error "oo update requires a git checkout at: $RUNTIME_DIR"
    exit 1
  fi

  local before_rev
  before_rev="$(git -C "$RUNTIME_DIR" rev-parse --short HEAD 2>/dev/null || echo "unknown")"

  local display_dir="$RUNTIME_DIR"
  if [[ -n "${HOME:-}" ]]; then
    display_dir="${display_dir/#$HOME/~}"
  fi

  echo "◆ Updating oo"
  echo "  Location: $display_dir"
  echo
  echo "Updating runtime"
  local update_log
  update_log="$(mktemp "${TMPDIR:-/tmp}/oo-update-XXXXXX")"
  if ! run_logged_step "Checking for updates" "$verbose" "$update_log" true git -C "$RUNTIME_DIR" pull --ff-only; then
    rm -f "$update_log"
    error "SYS-001 Failed to update runtime repository"
    info "Run: oo update --verbose"
    return 1
  fi
  rm -f "$update_log"

  local after_rev
  after_rev="$(git -C "$RUNTIME_DIR" rev-parse --short HEAD 2>/dev/null || echo "unknown")"

  local bin_dir="${OO_BIN_DIR:-$DEFAULT_OO_BIN_DIR}"
  mkdir -p "$bin_dir"

  local symlink_path="$bin_dir/oo"
  local relinked=false
  local expected_target="$RUNTIME_DIR/oo"
  if [[ ! -L "$symlink_path" ]]; then
    relinked=true
  else
    local current_target=""
    current_target="$(readlink "$symlink_path" || true)"
    if [[ "$current_target" != "$expected_target" ]]; then
      relinked=true
    fi
  fi

  ln -sfn "$RUNTIME_DIR/oo" "$bin_dir/oo"

  if [[ "$before_rev" != "$after_rev" ]]; then
    echo "  ✓ Update available"
    echo "  From: $before_rev"
    echo "  To:   $after_rev"
    echo
    echo "Applying update"
    echo "  ✓ Runtime updated"
    echo "  ✓ CLI is ready"
    echo
    echo "✓ Update complete"
    echo "  Changed:"
    echo "  - Updated oo to $after_rev"
    if [[ "$relinked" == true ]]; then
      echo "  - Refreshed CLI link"
    fi
  else
    echo "  ✓ Already up to date"
    echo "  Revision: $after_rev"
    if [[ "$relinked" == true ]]; then
      echo "  ✓ CLI link refreshed"
    fi
    echo
    echo "✓ No changes needed"
  fi
}

cmd_list() {
  local repo
  repo="$(read_configured_workflow_root)"
  if [[ -z "$repo" || ! -d "$repo" ]]; then
    info "No team workflow root configured."
    info "Run: oo add <workflow-name>"
    echo
  else
    echo "Team workflows ($repo):"
    local found=false
    local project_name=""
    while IFS= read -r project_name; do
      [[ -n "$project_name" ]] || continue
      found=true
      echo "  - $project_name"
    done < <(list_projects_in_repo "$repo")
    [[ "$found" == true ]] || echo "  (none)"
    echo
  fi

  echo "Installed tmuxinator workflows ($TMUXINATOR_DIR):"
  if [[ -d "$TMUXINATOR_DIR" ]]; then
    local installed=()
    local item
    shopt -s nullglob
    installed=("$TMUXINATOR_DIR"/*.yml)
    shopt -u nullglob

    if [[ ${#installed[@]} -eq 0 ]]; then
      echo "  (none)"
    else
      for item in "${installed[@]}"; do
        echo "  - $(basename "${item%.yml}")"
      done
    fi
  else
    echo "  (tmuxinator dir not found)"
  fi
}

cmd_status() {
  local repo
  repo="$(read_configured_workflow_root)"

  echo "Running workflow sessions:"
  if command -v tmux >/dev/null 2>&1; then
    local sessions
    sessions="$(tmux ls 2>/dev/null || true)"
    if [[ -z "$sessions" ]]; then
      echo "  (none)"
    else
      while IFS= read -r line; do
        [[ -n "$line" ]] || continue
        echo "  - ${line%%:*}"
      done <<<"$sessions"
    fi
  else
    echo "  (tmux not installed)"
  fi

  if [[ -z "$repo" || ! -d "$repo" ]]; then
    echo
    info "No team workflow root configured yet"
    info "Run: oo add <workflow-name>"
    return 0
  fi

  echo
  echo "Workflow service health:"
  local proj=""
  local found=false
  while IFS= read -r proj; do
    [[ -n "$proj" ]] || continue
    found=true
    local running="stopped"
    if command -v tmux >/dev/null 2>&1 && tmux has-session -t "$proj" 2>/dev/null; then
      running="running"
    fi
    echo "- $proj ($running)"

    local svc=""
    local any=false
    while IFS= read -r svc; do
      [[ -n "$svc" ]] || continue
      any=true
      require_service "$svc"
      build_service_state_context "$repo" "$proj" "$svc"
      if service_state_matches "$proj" "$svc" "$SERVICE_CTX_VERSION" "$SERVICE_CTX_CONFIG_HASH"; then
        echo "  - $svc: ready"
      else
        echo "  - $svc: needs install"
      fi
    done < <(enabled_services_for_project "$repo" "$proj")
    [[ "$any" == true ]] || echo "  - (no services configured)"
  done < <(list_projects_in_repo "$repo")

  [[ "$found" == true ]] || echo "  (no workflows found)"
}

