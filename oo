hash_text() {
  local value="$1"
  if command -v shasum >/dev/null 2>&1; then
    printf '%s' "$value" | shasum -a 256 | awk '{print $1}'
  elif command -v openssl >/dev/null 2>&1; then
    printf '%s' "$value" | openssl dgst -sha256 | awk '{print $NF}'
  else
    printf '%s' "$value" | cksum | awk '{print $1}'
  fi
}

detect_suggested_services() {
  local source_root="$1"
  local suggestions=()

  has_path_match() {
    local base="$1"
    shift
    local pattern
    for pattern in "$@"; do
      if compgen -G "$base/$pattern" >/dev/null 2>&1; then
        return 0
      fi
    done
    return 1
  }

  if has_path_match "$source_root" \
    "package.json" \
    "pnpm-lock.yaml" \
    "yarn.lock" \
    "npm-shrinkwrap.json" \
    "bun.lockb" \
    "bun.lock" \
    "bunfig.toml" \
    "nx.json" \
    "turbo.json" \
    "lerna.json"; then
    suggestions+=("node")
  fi

  if has_path_match "$source_root" \
    "docker-compose.yml" \
    "docker-compose.yaml" \
    "compose.yml" \
    "compose.yaml" \
    "Dockerfile" \
    "Dockerfile.*" \
    ".devcontainer/devcontainer.json"; then
    suggestions+=("containers")
  fi

  if has_path_match "$source_root" \
    "requirements.txt" \
    "requirements-*.txt" \
    "pyproject.toml" \
    "Pipfile" \
    "poetry.lock" \
    "setup.py" \
    "setup.cfg"; then
    suggestions+=("python")
  fi

  if has_path_match "$source_root" \
    "*.sln" \
    "*.csproj" \
    "global.json"; then
    suggestions+=("dotnet")
  fi

  if has_path_match "$source_root" \
    "redis.conf" \
    "redis/*.conf"; then
    suggestions+=("redis")
  fi

  if has_path_match "$source_root" \
    "pom.xml" \
    "build.gradle" \
    "build.gradle.kts" \
    "settings.gradle" \
    "settings.gradle.kts" \
    "gradlew" \
    "mvnw"; then
    suggestions+=("java")
  fi

  if has_path_match "$source_root" \
    "go.mod" \
    "go.sum" \
    "go.work"; then
    suggestions+=("go")
  fi

  if has_path_match "$source_root" \
    "Gemfile" \
    "Gemfile.lock" \
    ".ruby-version" \
    "Rakefile"; then
    suggestions+=("ruby")
  fi

  if has_path_match "$source_root" \
    "composer.json" \
    "composer.lock" \
    "phpunit.xml" \
    "phpunit.xml.dist"; then
    suggestions+=("php")
  fi

  if has_path_match "$source_root" \
    "Cargo.toml" \
    "Cargo.lock" \
    "rust-toolchain.toml"; then
    suggestions+=("rust")
  fi

  if has_path_match "$source_root" \
    "postgresql.conf" \
    "postgres.conf" \
    "pg_hba.conf"; then
    suggestions+=("postgres")
  fi

  if has_path_match "$source_root" \
    "CMakeLists.txt" \
    "meson.build" \
    "Makefile" \
    "*.c" \
    "*.h"; then
    suggestions+=("c")
  fi

  if has_path_match "$source_root" \
    "CMakeLists.txt" \
    "meson.build" \
    "Makefile" \
    "*.cpp" \
    "*.cc" \
    "*.cxx" \
    "*.hpp" \
    "*.hh" \
    "*.hxx"; then
    suggestions+=("cpp")
  fi

  local seen=","
  local service
  for service in "${suggestions[@]}"; do
    if [[ "$seen" != *",$service,"* ]]; then
      echo "$service"
      seen+="$service,"
    fi
  done
}

