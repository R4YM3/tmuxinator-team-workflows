PY
}

refresh_dependency_advisories_for_project() {
  local repo="$1"
  local project_name="$2"
  local verbose_mode="${3:-false}"

  local project_root
  project_root="$(project_root_for_project "$repo" "$project_name" 2>/dev/null || true)"
  [[ -n "$project_root" && -d "$project_root" ]] || return 0

  load_env_file_values "$project_root"
  build_env_overrides_for_command
  collect_project_dependency_commands "$project_root"

  DEPENDENCY_ADVISORY_RECORDS=()

  local label
  for label in "${PROJECT_DEP_LABELS[@]}"; do
    if [[ "$label" == "npm install" ]]; then
      if ! command -v npm >/dev/null 2>&1; then
        continue
      fi

      local npm_audit_log
      npm_audit_log="$(mktemp "${TMPDIR:-/tmp}/oo-doc-npm-audit-XXXXXX")"
      local npm_status=0
      if [[ ${#OO_COMMAND_ENV_OVERRIDES[@]} -gt 0 ]]; then
        set +e
        env "${OO_COMMAND_ENV_OVERRIDES[@]}" bash -c "cd \"$project_root\" && npm audit --json" >"$npm_audit_log" 2>&1
        npm_status=$?
        set -e
      else
        set +e
        bash -c "cd \"$project_root\" && npm audit --json" >"$npm_audit_log" 2>&1
        npm_status=$?
        set -e
      fi

      if [[ "$npm_status" -eq 0 || "$npm_status" -eq 1 ]]; then
        local advisory_line
        while IFS= read -r advisory_line; do
          [[ "$advisory_line" == ADVISORY\|* ]] || continue
          local record="${advisory_line#ADVISORY|}"
          if append_unique_line "$record" "${DEPENDENCY_ADVISORY_RECORDS[@]-}"; then
            DEPENDENCY_ADVISORY_RECORDS+=("$record")
          fi
        done < <(summarize_npm_audit_report "$npm_audit_log")
      elif [[ "$verbose_mode" == true ]]; then
        warn "Skipping npm advisory refresh: npm audit exited with code $npm_status"
      fi
      rm -f "$npm_audit_log"
    elif [[ "$label" == "dotnet restore" ]]; then
      if ! command -v dotnet >/dev/null 2>&1; then
        continue
      fi

      local dotnet_vuln_log
      local dotnet_dep_log
      dotnet_vuln_log="$(mktemp "${TMPDIR:-/tmp}/oo-doc-dotnet-vuln-XXXXXX")"
      dotnet_dep_log="$(mktemp "${TMPDIR:-/tmp}/oo-doc-dotnet-dep-XXXXXX")"

      set +e
      if [[ ${#OO_COMMAND_ENV_OVERRIDES[@]} -gt 0 ]]; then
        env "${OO_COMMAND_ENV_OVERRIDES[@]}" bash -c "cd \"$project_root\" && dotnet list package --vulnerable --include-transitive" >"$dotnet_vuln_log" 2>&1
      else
        bash -c "cd \"$project_root\" && dotnet list package --vulnerable --include-transitive" >"$dotnet_vuln_log" 2>&1
      fi
      local dotnet_vuln_status=$?

      if [[ ${#OO_COMMAND_ENV_OVERRIDES[@]} -gt 0 ]]; then
        env "${OO_COMMAND_ENV_OVERRIDES[@]}" bash -c "cd \"$project_root\" && dotnet list package --deprecated --include-transitive" >"$dotnet_dep_log" 2>&1
      else
        bash -c "cd \"$project_root\" && dotnet list package --deprecated --include-transitive" >"$dotnet_dep_log" 2>&1
      fi
      local dotnet_dep_status=$?
      set -e

      if [[ "$dotnet_vuln_status" -eq 0 || "$dotnet_dep_status" -eq 0 ]]; then
        local advisory_line
        while IFS= read -r advisory_line; do
          [[ "$advisory_line" == ADVISORY\|* ]] || continue
          local record="${advisory_line#ADVISORY|}"
          if append_unique_line "$record" "${DEPENDENCY_ADVISORY_RECORDS[@]-}"; then
            DEPENDENCY_ADVISORY_RECORDS+=("$record")
          fi
        done < <(summarize_dotnet_audit_reports "$dotnet_vuln_log" "$dotnet_dep_log")
      elif [[ "$verbose_mode" == true ]]; then
        warn "Skipping nuget advisory refresh: dotnet list package commands failed"
      fi

      rm -f "$dotnet_vuln_log" "$dotnet_dep_log"
    fi
  done

  write_dependency_advisory_snapshot "$project_name"
}

run_project_dependency_commands() {
  local project_root="$1"
  local verbose_mode="${2:-false}"
  local idx=0
  local total=${#PROJECT_DEP_COMMANDS[@]}

  INSTALL_WARNING_LINES=()
  INSTALL_WARNING_ACTION_LINES=()
  INSTALL_CHANGED_LINES=()
  DEPENDENCY_ADVISORY_RECORDS=()

  if [[ "$total" -eq 0 ]]; then
    info "No dependency installers detected"
    return 0
  fi

  echo "Dependencies"
  local command=""
  local label=""
  local step_label=""
  for ((idx = 0; idx < total; idx++)); do
    command="${PROJECT_DEP_COMMANDS[$idx]}"
    label="${PROJECT_DEP_LABELS[$idx]}"
    step_label="Installing $label"
    if [[ "$label" == "npm install" ]]; then
      step_label="Installing npm dependencies"
    fi

    local cmd_log
    cmd_log="$(mktemp "${TMPDIR:-/tmp}/oo-deps-${idx}-XXXXXX")"
    local cmd_status=0
    local run_status=0
    if [[ ${#OO_COMMAND_ENV_OVERRIDES[@]} -gt 0 ]]; then
      if run_logged_step "$step_label" "$verbose_mode" "$cmd_log" true env "${OO_COMMAND_ENV_OVERRIDES[@]}" bash -c "cd \"$project_root\" && $command"; then
        run_status=0
      else
        run_status=$?
      fi
    else
      if run_logged_step "$step_label" "$verbose_mode" "$cmd_log" true bash -c "cd \"$project_root\" && $command"; then
        run_status=0
      else
        run_status=$?
      fi
    fi
    cmd_status="$run_status"

    if [[ "$cmd_status" -ne 0 ]]; then
      local details=""
      if [[ "$verbose_mode" != true ]]; then
        details="$(python3 - "$cmd_log" <<'PY'
import sys
from pathlib import Path
lines = Path(sys.argv[1]).read_text(errors='replace').splitlines()
for line in lines[-12:]:
    print(line)
PY
)"
      fi
      rm -f "$cmd_log"
      install_failure_block_with_details "INS-101" "$label exited with code $cmd_status." "$details" "Retry with details: oo install --verbose" "Check dependency scripts and lockfiles"
      return 1
    fi

    local summary_line=""
    if [[ "$label" == "npm install" ]]; then
      while IFS= read -r summary_line; do
        [[ "$summary_line" == ADVISORY\|* ]] || continue
        local record="${summary_line#ADVISORY|}"
        local warning
        if append_unique_line "$record" "${DEPENDENCY_ADVISORY_RECORDS[@]-}"; then
          DEPENDENCY_ADVISORY_RECORDS+=("$record")
        fi
        while IFS= read -r warning; do
          [[ -n "$warning" ]] || continue
          if append_unique_line "$warning" "${INSTALL_WARNING_LINES[@]-}"; then
            INSTALL_WARNING_LINES+=("$warning")
          fi
        done < <(advisory_record_to_warning_lines "$record")

        local tool=""
        local action=""
        IFS='|' read -r tool _ <<<"$record"
        while IFS= read -r action; do
          [[ -n "$action" ]] || continue
          if append_unique_line "$action" "${INSTALL_WARNING_ACTION_LINES[@]-}"; then
            INSTALL_WARNING_ACTION_LINES+=("$action")
          fi
        done < <(dependency_actions_for_tool "$tool")
      done < <(summarize_npm_install_warnings "$cmd_log")
      INSTALL_CHANGED_LINES+=("Installed npm dependencies")
    elif [[ "$label" == "dotnet restore" ]]; then
      while IFS= read -r summary_line; do
        [[ "$summary_line" == ADVISORY\|* ]] || continue
        local record="${summary_line#ADVISORY|}"
        local warning
        if append_unique_line "$record" "${DEPENDENCY_ADVISORY_RECORDS[@]-}"; then
          DEPENDENCY_ADVISORY_RECORDS+=("$record")
        fi
        while IFS= read -r warning; do
          [[ -n "$warning" ]] || continue
          if append_unique_line "$warning" "${INSTALL_WARNING_LINES[@]-}"; then
            INSTALL_WARNING_LINES+=("$warning")
          fi
        done < <(advisory_record_to_warning_lines "$record")

        local tool=""
        local action=""
        IFS='|' read -r tool _ <<<"$record"
        while IFS= read -r action; do
          [[ -n "$action" ]] || continue
          if append_unique_line "$action" "${INSTALL_WARNING_ACTION_LINES[@]-}"; then
            INSTALL_WARNING_ACTION_LINES+=("$action")
          fi
        done < <(dependency_actions_for_tool "$tool")
      done < <(summarize_dotnet_restore_warnings "$cmd_log")
      INSTALL_CHANGED_LINES+=("Installed dotnet dependencies")
    else
      INSTALL_CHANGED_LINES+=("Installed dependencies via $label")
    fi

    rm -f "$cmd_log"
  done

  if [[ "$verbose_mode" != true && ${#INSTALL_WARNING_LINES[@]} -gt 0 ]]; then
    echo
    echo "Warnings"
    local warning
    for warning in "${INSTALL_WARNING_LINES[@]}"; do
      echo "  ! $warning"
    done
    echo
    echo "What you can do"
    local action_line
    if [[ ${#INSTALL_WARNING_ACTION_LINES[@]} -gt 0 ]]; then
      for action_line in "${INSTALL_WARNING_ACTION_LINES[@]}"; do
        case "$action_line" in
        npm\ audit)
          echo "  • Review advisories: npm audit"
          ;;
        npm\ audit\ fix)
          echo "  • Safe fixes: npm audit fix"
          ;;
        oo\ install)
          echo "  • Refresh advisories: oo install"
          ;;
        *)
          echo "  • $action_line"
          ;;
        esac
      done
      echo "  • Environment insights: oo doctor"
    else
      echo "  • Environment insights: oo doctor"
    fi
  fi

  return 0
}

parse_service_project_args() {
  local usage="$1"
  shift

  PARSED_SERVICE_NAME=""
  PARSED_PROJECT_NAME=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
    --workflow)
      [[ $# -ge 2 ]] || {
        error "--workflow requires a workflow name"
        exit 1
      }
      PARSED_PROJECT_NAME="$2"
      shift 2
      ;;
    *)
      if [[ -z "$PARSED_SERVICE_NAME" ]]; then
        PARSED_SERVICE_NAME="$1"
        shift
      else
        error "Unexpected argument: $1"
        exit 1
      fi
      ;;
    esac
  done

  [[ -n "$PARSED_SERVICE_NAME" ]] || {
    error "Missing service name"
    info "$usage"
    exit 1
  }
  if [[ -z "$PARSED_PROJECT_NAME" ]]; then
    PARSED_PROJECT_NAME="$(infer_start_project_from_context)"
    if [[ -n "$PARSED_PROJECT_NAME" ]]; then
      info "No --workflow provided; inferred '$PARSED_PROJECT_NAME'"
    fi
  fi

  [[ -n "$PARSED_PROJECT_NAME" ]] || {
    error "Missing workflow context"
    info "$usage"
    info "Tip: run from a linked workflow repo or pass --workflow <name>"
    exit 1
  }
}

parse_service_scope_args() {
  local usage="$1"
  local allow_yes="$2"
  shift 2

  PARSED_PROJECT_NAME=""
  PARSED_GLOBAL=false
  PARSED_ASSUME_YES=false

  while [[ $# -gt 0 ]]; do
    case "$1" in
    --workflow)
      [[ $# -ge 2 ]] || {
        error "--workflow requires a workflow name"
        exit 1
      }
      PARSED_PROJECT_NAME="$2"
      shift 2
      ;;
    --global)
      PARSED_GLOBAL=true
      shift
      ;;
    --yes)
      if [[ "$allow_yes" == true ]]; then
        PARSED_ASSUME_YES=true
        shift
      else
        error "Unexpected argument: --yes"
        exit 1
      fi
      ;;
    *)
      error "Unexpected argument: $1"
      info "$usage"
      exit 1
      ;;
    esac
  done

  if [[ -n "$PARSED_PROJECT_NAME" && "$PARSED_GLOBAL" == true ]]; then
    error "Use either --workflow or --global, not both"
    exit 1
  fi

  if [[ -z "$PARSED_PROJECT_NAME" && "$PARSED_GLOBAL" != true ]]; then
    PARSED_PROJECT_NAME="$(infer_start_project_from_context)"
    if [[ -n "$PARSED_PROJECT_NAME" ]]; then
      info "No --workflow provided; inferred '$PARSED_PROJECT_NAME'"
    fi
  fi
}

cmd_service_add() {
  parse_service_project_args "Usage: oo service add <service> [--workflow <workflow>]" "$@"
  validate_project_name "$PARSED_PROJECT_NAME"
  require_service "$PARSED_SERVICE_NAME"

  local repo
  repo="$(require_workflow_repo)"
  ensure_project_exists "$repo" "$PARSED_PROJECT_NAME"

  add_service_to_project_config "$repo" "$PARSED_PROJECT_NAME" "$PARSED_SERVICE_NAME"
  ok "Added service '$PARSED_SERVICE_NAME' to workflow '$PARSED_PROJECT_NAME'"
  local inferred_project
  inferred_project="$(infer_start_project_from_context)"
  if [[ "$inferred_project" == "$PARSED_PROJECT_NAME" ]]; then
    info "Run: oo service install"
