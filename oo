select_requirements_with_checkboxes() {
  local options=("$@")
  local count=${#options[@]}

  CHECKBOX_SELECTED=()
  if [[ "$count" -eq 0 ]]; then
    return 0
  fi

  local selected=()
  local i=0
  for ((i = 0; i < count; i++)); do
    selected+=(1)
  done

  local cursor=0
  local key=""

  while true; do
    printf '\033[H\033[J'
    echo "Select requirements to install"
    echo "Space: toggle  Enter: confirm  A: toggle all  Q: cancel"
    echo

    local selected_count=0
    for ((i = 0; i < count; i++)); do
      local marker="[ ]"
      if [[ "${selected[$i]}" -eq 1 ]]; then
        marker="[x]"
        selected_count=$((selected_count + 1))
      fi

      if [[ "$i" -eq "$cursor" ]]; then
        printf '\033[1;36m> %s %s\033[0m\n' "$marker" "${options[$i]}"
      elif [[ "${selected[$i]}" -eq 1 ]]; then
        printf '\033[1;32m  %s %s\033[0m\n' "$marker" "${options[$i]}"
      else
        printf '  %s %s\n' "$marker" "${options[$i]}"
      fi
    done

    echo
    echo "Selected: $selected_count of $count"

    IFS= read -rsn1 key || true
    if [[ "$key" == $'\x1b' ]]; then
      local rest=""
      IFS= read -rsn2 rest || true
      key+="$rest"
    fi

    case "$key" in
    "")
      CHECKBOX_SELECTED=()
      for ((i = 0; i < count; i++)); do
        if [[ "${selected[$i]}" -eq 1 ]]; then
          CHECKBOX_SELECTED+=("${options[$i]}")
        fi
      done
      return 0
      ;;
    " ")
      if [[ "${selected[$cursor]}" -eq 1 ]]; then
        selected[$cursor]=0
      else
        selected[$cursor]=1
      fi
      ;;
    q | Q)
      return 1
      ;;
    a | A)
      local all_selected=true
      for ((i = 0; i < count; i++)); do
        if [[ "${selected[$i]}" -eq 0 ]]; then
          all_selected=false
          break
        fi
      done
      for ((i = 0; i < count; i++)); do
        if [[ "$all_selected" == true ]]; then
          selected[$i]=0
        else
          selected[$i]=1
        fi
      done
      ;;
    j | $'\x1b[B')
      cursor=$(((cursor + 1) % count))
      ;;
    k | $'\x1b[A')
      cursor=$(((cursor - 1 + count) % count))
      ;;
    esac
  done
}

