usage_quick() {
  cat <<'EOF'
Usage: oo <command> [options]

Common commands:
  oo add [workflow-name]          Create a workflow
  oo service add <service>       Add service to current workflow
  oo service install             Install services for current workflow
  oo start [workflow]             Start workflow
  oo stop [workflow]              Stop workflow
  oo status                      Show running workflows and health
  oo doctor                      Diagnose issues and show fixes
  oo install                     Install environment setup for workflow

Help:
  oo help                        Show this quick help
  oo help --all                  Show full command reference
  oo help <command>              Show help for a command

Examples:
  oo add
  oo service add web
  oo service install
  oo install
  oo start
EOF
}

closest_command() {
  local needle="$1"
  local commands=(add remove service demo status validate doctor analytics install update list start stop uninstall version help)

  if command -v python3 >/dev/null 2>&1; then
    python3 - "$needle" "${commands[@]}" <<'PY'
import difflib
import sys

needle = sys.argv[1]
commands = sys.argv[2:]
matches = difflib.get_close_matches(needle, commands, n=1, cutoff=0.5)
print(matches[0] if matches else "")
PY
    return 0
  fi

  local cmd

  for cmd in "${commands[@]}"; do
    if [[ "$cmd" == "$needle"* || "$needle" == "$cmd"* ]]; then
      echo "$cmd"
      return 0
    fi
  done

  for cmd in "${commands[@]}"; do
    if [[ "$cmd" == *"$needle"* || "$needle" == *"$cmd"* ]]; then
      echo "$cmd"
      return 0
    fi
  done

  echo ""
}

cmd_help() {
  local topic="${1:-}"

  if [[ -z "$topic" ]]; then
    usage_quick
    return 0
  fi

  case "$topic" in
  --all)
    usage
    ;;
  add | remove | service | doctor | analytics | install | uninstall)
    "$0" "$topic" --help
    ;;
  start)
    cat <<'EOF'
Usage: oo start <workflow-name> [tmuxinator args...] [--strict]

Starts a workflow session.
If no workflow is provided, oo tries to infer it from current context.
EOF
    ;;
  stop)
    cat <<'EOF'
Usage: oo stop <workflow-name>

Stops a running workflow session.
If no workflow is provided, oo tries to infer it from current context.
EOF
    ;;
  demo)
    cat <<'EOF'
Usage: oo demo [target-dir]

Scaffolds a demo workspace with web + api services.
EOF
    ;;
  status)
    cat <<'EOF'
Usage: oo status

Shows running workflow sessions and service readiness.
EOF
    ;;
  list)
    cat <<'EOF'
Usage: oo list

Lists team workflows and installed tmuxinator aliases.
EOF
    ;;
  validate)
    cat <<'EOF'
Usage: oo validate

Validates workflow files in the configured team workflow root.
EOF
    ;;
  update)
    cat <<'EOF'
Usage: oo update

Pulls latest oo runtime and refreshes the oo CLI symlink.
EOF
    ;;
  analytics)
    cat <<'EOF'
Usage: oo analytics <status|enable|disable|report>

Manages local analytics preference.
Default is enabled for interactive usage and disabled for non-interactive usage.
EOF
    ;;
  install)
    cat <<'EOF'
Usage: oo install [--workflow <workflow>] [--yes] [--plan] [--no-workflow-deps] [--no-analytics] [--verbose]

Installs machine readiness requirements and workflow dependencies.
If no workflow is provided, oo tries to infer it from current context.
EOF
    ;;
  version)
    version
    ;;
  help)
    usage_quick
    ;;
  *)
    error "Unknown help topic: $topic"
    local suggestion
    suggestion="$(closest_command "$topic")"
    if [[ -n "$suggestion" ]]; then
      info "Did you mean: oo help $suggestion"
    fi
    ;;
  esac
}

version() {
  if command -v git >/dev/null 2>&1 && git -C "$RUNTIME_DIR" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    git -C "$RUNTIME_DIR" describe --tags --always --dirty 2>/dev/null || true
    return 0
  fi

  echo "0.1.0"
}

validate_project_name() {
  local project_name="$1"
  if [[ ! "$project_name" =~ ^[a-z0-9][a-z0-9-]*$ ]]; then
    error "Invalid workflow name: '$project_name'"
    info "Use lowercase letters, numbers, and dashes only (must start with letter or number)."
    exit 1
  fi
}

slugify_workflow_name() {
  local raw_name="$1"
  local slug
  slug="$(printf '%s' "$raw_name" | tr '[:upper:]' '[:lower:]' | sed -E 's/[^a-z0-9]+/-/g; s/^-+//; s/-+$//; s/-+/-/g')"
  if [[ -z "$slug" ]]; then
    slug="workflow"
  fi
  echo "$slug"
}

expand_path() {
  local path="$1"
  if [[ "$path" == ~* ]]; then
    path="${path/#\~/$HOME}"
  fi

  if [[ "$path" != /* ]]; then
    path="$(cd "$PWD" && pwd)/$path"
  fi

  echo "$path"
}

read_configured_workflow_root() {
  if [[ -n "${TEAM_WORKFLOWS_ROOT:-}" ]]; then
    expand_path "$TEAM_WORKFLOWS_ROOT"
    return 0
  fi

  if [[ ! -f "$OO_CONFIG_FILE" ]]; then
    echo ""
    return 0
  fi

  local configured
  configured="$(ruby -ryaml -e 'path = ARGV[0]; raw = YAML.safe_load(File.read(path), aliases: false); data = raw.is_a?(Hash) ? raw : {}; value = data["team_workflows_root"]; puts(value.is_a?(String) ? value : "")' "$OO_CONFIG_FILE" 2>/dev/null || true)"
  if [[ -z "$configured" ]]; then
    echo ""
    return 0
  fi

  expand_path "$configured"
}

read_configured_analytics_enabled() {
  if [[ ! -f "$OO_CONFIG_FILE" ]]; then
    echo ""
    return 0
  fi

  ruby -ryaml -e 'path = ARGV[0]; raw = YAML.safe_load(File.read(path), aliases: false); data = raw.is_a?(Hash) ? raw : {}; analytics = data["analytics"]; value = analytics.is_a?(Hash) ? analytics["enabled"] : nil; puts(value == true ? "true" : value == false ? "false" : "")' "$OO_CONFIG_FILE" 2>/dev/null || true
}

read_configured_analytics_install_id() {
  if [[ ! -f "$OO_CONFIG_FILE" ]]; then
    echo ""
    return 0
  fi

  ruby -ryaml -e 'path = ARGV[0]; raw = YAML.safe_load(File.read(path), aliases: false); data = raw.is_a?(Hash) ? raw : {}; analytics = data["analytics"]; value = analytics.is_a?(Hash) ? analytics["install_id"] : nil; puts(value.is_a?(String) ? value : "")' "$OO_CONFIG_FILE" 2>/dev/null || true
}

write_config_analytics_enabled() {
  local enabled="$1"
  mkdir -p "$OO_CONFIG_DIR"
  ruby -ryaml -e 'path = ARGV[0]; enabled = ARGV[1] == "true"; raw = File.exist?(path) ? YAML.safe_load(File.read(path), aliases: false) : {}; data = raw.is_a?(Hash) ? raw : {}; analytics = data["analytics"].is_a?(Hash) ? data["analytics"] : {}; analytics["enabled"] = enabled; data["analytics"] = analytics; File.write(path, data.to_yaml(line_width: -1))' "$OO_CONFIG_FILE" "$enabled"
}

write_config_analytics_install_id() {
  local install_id="$1"
  mkdir -p "$OO_CONFIG_DIR"
  ruby -ryaml -e 'path = ARGV[0]; install_id = ARGV[1]; raw = File.exist?(path) ? YAML.safe_load(File.read(path), aliases: false) : {}; data = raw.is_a?(Hash) ? raw : {}; analytics = data["analytics"].is_a?(Hash) ? data["analytics"] : {}; analytics["install_id"] = install_id; data["analytics"] = analytics; File.write(path, data.to_yaml(line_width: -1))' "$OO_CONFIG_FILE" "$install_id"
}

analytics_preference_source() {
  if [[ -n "${OO_ANALYTICS:-}" ]]; then
    echo "env"
    return 0
  fi

  local configured
  configured="$(read_configured_analytics_enabled)"
  if [[ "$configured" == "true" || "$configured" == "false" ]]; then
    echo "config"
    return 0
  fi

  if is_interactive_terminal; then
    echo "default-interactive"
  else
    echo "default-non-interactive"
  fi
}

analytics_enabled() {
  if [[ -n "${OO_ANALYTICS:-}" ]]; then
    case "${OO_ANALYTICS}" in
    1 | true | TRUE | True | yes | YES | Yes | on | ON | On)
      return 0
      ;;
    0 | false | FALSE | False | no | NO | No | off | OFF | Off)
      return 1
      ;;
    esac
  fi

  local configured
  configured="$(read_configured_analytics_enabled)"
  if [[ "$configured" == "true" ]]; then
    return 0
  fi
  if [[ "$configured" == "false" ]]; then
    return 1
  fi

  is_interactive_terminal
}

generate_install_id() {
  if ! command -v python3 >/dev/null 2>&1; then
    date +%s
    return 0
  fi
  python3 - <<'PY'
import uuid
print(str(uuid.uuid4()))
PY
}

ensure_analytics_install_id() {
  local install_id
  install_id="$(read_configured_analytics_install_id)"
  if [[ -n "$install_id" ]]; then
    echo "$install_id"
    return 0
  fi

  local state_install_id_file="$ANALYTICS_STATE_ROOT/install_id"
  if [[ -f "$state_install_id_file" ]]; then
    install_id="$(cat "$state_install_id_file" 2>/dev/null || true)"
    if [[ -n "$install_id" ]]; then
      echo "$install_id"
      return 0
    fi
  fi

  install_id="$(generate_install_id)"
  mkdir -p "$ANALYTICS_STATE_ROOT"
  printf '%s\n' "$install_id" >"$state_install_id_file"
  if command -v ruby >/dev/null 2>&1; then
    write_config_analytics_install_id "$install_id" || true
  fi
  echo "$install_id"
}

epoch_millis() {
  if ! command -v python3 >/dev/null 2>&1; then
    date +%s000
    return 0
  fi
  python3 - <<'PY'
import time
print(int(time.time() * 1000))
PY
}

analytics_begin() {
  ANALYTICS_COMMAND="$1"
  shift || true
  ANALYTICS_FLAGS=()
  local arg
  for arg in "$@"; do
    if [[ "$arg" == --* ]]; then
      ANALYTICS_FLAGS+=("$arg")
    fi
  done
  ANALYTICS_START_MS="$(epoch_millis)"
  ANALYTICS_DOCTOR_ISSUES=0
  ANALYTICS_DOCTOR_DEP_ADVISORIES=0
  ANALYTICS_ERROR_CODE=""
  ANALYTICS_ERROR_DOMAIN=""
}

record_analytics_event() {
  local exit_code="$1"
  analytics_enabled || return 0

  local install_id
  install_id="$(ensure_analytics_install_id)"
  local end_ms
  end_ms="$(epoch_millis)"
  local duration=$((end_ms - ANALYTICS_START_MS))

  mkdir -p "$ANALYTICS_STATE_ROOT"
  if ! command -v python3 >/dev/null 2>&1; then
    return 0
  fi
  set +e
  python3 - "$ANALYTICS_EVENT_LOG" "$install_id" "$ANALYTICS_COMMAND" "$exit_code" "$duration" "$ANALYTICS_DOCTOR_ISSUES" "$ANALYTICS_DOCTOR_DEP_ADVISORIES" "$ANALYTICS_ERROR_CODE" "$ANALYTICS_ERROR_DOMAIN" "${ANALYTICS_FLAGS[@]-}" <<'PY'
import json
import sys
from datetime import datetime, timezone

log_path = sys.argv[1]
install_id = sys.argv[2]
command = sys.argv[3]
exit_code = int(sys.argv[4])
duration_ms = int(sys.argv[5])
doctor_issues = int(sys.argv[6])
doctor_dep_advisories = int(sys.argv[7])
error_code = sys.argv[8]
error_domain = sys.argv[9]
flags = sys.argv[10:]

event = {
    "schema_version": 1,
    "ts": datetime.now(timezone.utc).isoformat(),
    "install_id": install_id,
    "command": command,
    "flags": flags,
    "exit_code": exit_code,
    "success": exit_code == 0,
    "duration_ms": duration_ms,
}

if exit_code != 0 and error_code:
    event["error_code"] = error_code
if exit_code != 0 and error_domain:
    event["error_domain"] = error_domain

if command == "doctor":
    event["doctor_issues"] = doctor_issues
    event["doctor_dependency_advisories"] = doctor_dep_advisories

with open(log_path, "a", encoding="utf-8") as f:
    f.write(json.dumps(event, separators=(",", ":")) + "\n")
PY
  set -e
}

analytics_report() {
  if [[ ! -f "$ANALYTICS_EVENT_LOG" ]]; then
    echo "Analytics report"
    echo "  No analytics events recorded yet"
    return 0
  fi

  if ! command -v python3 >/dev/null 2>&1; then
    echo "Analytics report"
    echo "  Python 3 is required to generate report"
    echo "  Event log: $ANALYTICS_EVENT_LOG"
    return 0
  fi

  python3 - "$ANALYTICS_EVENT_LOG" <<'PY'
import json
import sys
from collections import Counter

path = sys.argv[1]
events = []
with open(path, "r", encoding="utf-8", errors="replace") as f:
    for line in f:
        line = line.strip()
        if not line:
            continue
        try:
            payload = json.loads(line)
        except Exception:
            continue
        if isinstance(payload, dict):
            events.append(payload)

print("Analytics report")
if not events:
    print("  No analytics events recorded yet")
    sys.exit(0)

total = len(events)
success = sum(1 for e in events if e.get("success") is True)
failed = total - success
durations = [int(e.get("duration_ms", 0)) for e in events if isinstance(e.get("duration_ms", 0), int)]
avg_duration = int(sum(durations) / len(durations)) if durations else 0

print(f"  Events: {total}")
print(f"  Success: {success}")
print(f"  Failed: {failed}")
print(f"  Avg duration: {avg_duration}ms")

command_counts = Counter(str(e.get("command", "unknown")) for e in events)
print("")
print("Commands")
for command, count in sorted(command_counts.items(), key=lambda item: (-item[1], item[0])):
    print(f"  - {command}: {count}")

error_counts = Counter(str(e.get("error_code")) for e in events if e.get("error_code"))
if error_counts:
    print("")
    print("Top error codes")
    for code, count in sorted(error_counts.items(), key=lambda item: (-item[1], item[0]))[:5]:
        print(f"  - {code}: {count}")

doctor_events = [e for e in events if e.get("command") == "doctor"]
if doctor_events:
    doctor_issues = sum(int(e.get("doctor_issues", 0)) for e in doctor_events)
    doctor_dep_advisories = sum(int(e.get("doctor_dependency_advisories", 0)) for e in doctor_events)
    print("")
    print("Doctor")
    print(f"  - Runs: {len(doctor_events)}")
    print(f"  - Issues reported: {doctor_issues}")
    print(f"  - Dependency advisories: {doctor_dep_advisories}")
PY
}

analytics_finalize() {
  local exit_code="$1"
  if [[ -n "$ANALYTICS_COMMAND" ]]; then
    record_analytics_event "$exit_code"
  fi
}

save_configured_workflow_root() {
  local root="$1"
  if [[ "$root" == "$RUNTIME_DIR" ]]; then
    error "team workflow root cannot be the oo runtime repository"
    info "Choose a separate directory, e.g. ../team-workflows"
    exit 1
  fi
  mkdir -p "$OO_CONFIG_DIR"
  ruby -ryaml -e 'path = ARGV[0]; root = ARGV[1]; raw = File.exist?(path) ? YAML.safe_load(File.read(path), aliases: false) : {}; data = raw.is_a?(Hash) ? raw : {}; data["team_workflows_root"] = root; File.write(path, data.to_yaml(line_width: -1))' "$OO_CONFIG_FILE" "$root"
}

default_workflow_root_for_dir() {
  local base="$1"
  echo "$(cd "$base/.." && pwd)/team-workflows"
}

ensure_workflow_root_for_add() {
  local dry_run="${1:-false}"
  local configured
  configured="$(read_configured_workflow_root)"
  if [[ -n "$configured" ]]; then
    if [[ "$configured" == "$RUNTIME_DIR" ]]; then
      error "Configured team workflow root points to oo runtime repository"
      info "Run oo add from your workflow and choose a separate workflow root"
      exit 1
    fi
    echo "$configured"
    return 0
  fi

  local suggested
  suggested="$(default_workflow_root_for_dir "$PWD")"

  if [[ "$dry_run" == true ]]; then
    echo "$suggested"
    return 0
  fi

  if [[ ! -t 0 ]]; then
    mkdir -p "$suggested"
    save_configured_workflow_root "$suggested"
    echo "$suggested"
    return 0
  fi

  echo "No team workflow root configured yet."
  echo "Where should workflows be stored?"
  read -r -p "Path [$suggested]: " configured
  configured="${configured:-$suggested}"
  configured="$(expand_path "$configured")"

  mkdir -p "$configured"
  save_configured_workflow_root "$configured"
  ok "Configured team workflow root: $configured"
  echo "$configured"
}

detect_workflow_repo() {
  local configured
  configured="$(read_configured_workflow_root)"
  if [[ -n "$configured" && -d "$configured" ]]; then
    echo "$configured"
    return 0
  fi

  local linked_project
  linked_project="$(infer_project_from_local_link)"
  if [[ -n "$linked_project" ]]; then
    local local_link="$PWD/.oo/workflow.yaml"
    if [[ ! -e "$local_link" ]]; then
      local_link="$PWD/.oo/workflow.yml"
    fi
    local resolved
    resolved="$(python3 - "$local_link" <<'PY'
import os
import sys
print(os.path.realpath(sys.argv[1]))
PY
    )"
    local repo
    repo="$(dirname "$(dirname "$resolved")")"
    if [[ -d "$repo" ]]; then
      echo "$repo"
      return 0
    fi
  fi

  echo ""
}

