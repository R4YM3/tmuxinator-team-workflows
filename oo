sanitize_tmux_env() {
  if [[ -n "${TMUX:-}" ]]; then
    if ! tmux display-message -p '#{client_tty}' >/dev/null 2>&1; then
      unset TMUX
    fi
  fi
}

start_requested_no_attach() {
  local arg
  for arg in "$@"; do
    case "$arg" in
    --no-attach | --skip-attach)
      return 0
      ;;
    esac
  done
  return 1
}

render_project_config_for_start() {
  local source_file="$1"
  local override_file="$2"
  local rendered_file="$3"

  ruby -rerb -ryaml -e '
def load_yaml_with_erb(path)
  source = File.read(path)
  rendered = ERB.new(source, trim_mode: "-").result(binding)
  data = YAML.safe_load(rendered, aliases: true)
  data.is_a?(Hash) ? data : {}
end

def deep_merge_hash(base, override)
  out = base.dup
  override.each do |k, v|
    if out[k].is_a?(Hash) && v.is_a?(Hash)
      out[k] = deep_merge_hash(out[k], v)
    else
      out[k] = v
    end
  end
  out
end

project_file = ARGV[0]
override_file = ARGV[1]

project_data = load_yaml_with_erb(project_file)
override_data = File.exist?(override_file) ? load_yaml_with_erb(override_file) : {}
override_data.delete("services")

merged = deep_merge_hash(project_data, override_data)
puts merged.to_yaml(line_width: -1)
' "$source_file" "$override_file" >"$rendered_file"
}

read_rendered_config_root() {
  local config_file="$1"
  ruby -ryaml -e 'data = YAML.safe_load(File.read(ARGV[0]), aliases: true); value = data.is_a?(Hash) ? data["root"] : nil; puts(value.is_a?(String) ? value : "")' "$config_file" 2>/dev/null || true
}

run_service_check_with_timeout() {
  local service_script="$1"
  local service_config_json="$2"
  local timeout_sec="$3"

  OO_SERVICE_CONFIG_JSON="$service_config_json" python3 - "$service_script" "$timeout_sec" <<'PY'
import os
import subprocess
import sys

script = sys.argv[1]
timeout = float(sys.argv[2])
env = os.environ.copy()

try:
    completed = subprocess.run(
        [script, "check"],
        env=env,
        timeout=timeout,
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
    )
    sys.exit(completed.returncode)
except subprocess.TimeoutExpired:
    sys.exit(124)
PY
}

infer_project_from_local_link() {
  local local_link="$PWD/.oo/workflow.yaml"
  if [[ ! -e "$local_link" ]]; then
    local_link="$PWD/.oo/workflow.yml"
  fi
  [[ -e "$local_link" ]] || {
    echo ""
    return 0
  }

  local resolved
  resolved="$(python3 - "$local_link" <<'PY'
import os
import sys
print(os.path.realpath(sys.argv[1]))
PY
  )"

  if [[ "$resolved" == */workflow.yaml || "$resolved" == */workflow.yml ]]; then
    basename "$(dirname "$resolved")"
    return 0
  fi

  echo ""
}

infer_start_project_from_context() {
  local linked_project
  linked_project="$(infer_project_from_local_link)"
  if [[ -n "$linked_project" ]]; then
    echo "$linked_project"
    return 0
  fi

  local cwd_name
  cwd_name="$(basename "$PWD")"

  local repo
  repo="$(read_configured_workflow_root)"
  if [[ -z "$repo" ]]; then
    echo ""
    return 0
  fi

  if [[ -f "$(resolve_project_template_file "$repo" "$cwd_name")" ]]; then
    echo "$cwd_name"
    return 0
  fi

  local only=""
  local count=0
  local name=""
  while IFS= read -r name; do
    [[ -n "$name" ]] || continue
    count=$((count + 1))
    only="$name"
  done < <(list_projects_in_repo "$repo")

  if [[ "$count" -eq 1 ]]; then
    echo "$only"
    return 0
  fi

  echo ""
}

cmd_start() {
  local project_name=""
  local strict_mode=false
  local start_args=()

  if [[ $# -eq 0 || "${1:-}" == -* ]]; then
    if [[ "${1:-}" == "--workflow" ]]; then
      error "Invalid option for oo start: --workflow"
      info "Usage: oo start <workflow-name> [tmuxinator args...] [--strict]"
      info "Tip: use 'oo start test-repo' or run from that repo and use 'oo start'"
      exit 1
    fi

    project_name="$(infer_start_project_from_context)"
    if [[ -z "$project_name" ]]; then
      error "Missing workflow name and could not infer one from current directory"
      info "Usage: oo start <workflow-name> [tmuxinator args...] [--strict]"
      info "Tip: run from your workflow repo and use 'oo start', or pass workflow explicitly"
      exit 1
    fi

    info "No workflow name provided; inferred '$project_name'"
  else
    project_name="$1"
    shift
  fi

  local arg
  for arg in "$@"; do
    case "$arg" in
    --strict)
      strict_mode=true
      ;;
    *)
      start_args+=("$arg")
      ;;
    esac
  done

  local workflow_repo=""
  local config_source_file=""
  local config_override_file=""
  local rendered_config_file=""
  local tmuxinator_status=0
  local had_session_before=false

  echo "[oo] Workflow: $project_name"

  if tmux has-session -t "$project_name" 2>/dev/null; then
    had_session_before=true
  fi

  if ! command -v tmuxinator >/dev/null 2>&1; then
    error "tmuxinator is not installed or not on PATH"
    exit 1
  fi

  workflow_repo="$(detect_workflow_repo)"
  if [[ -z "$workflow_repo" ]]; then
    error "No team workflow root is configured"
    info "Run: oo add $project_name"
    exit 1
  fi

  config_source_file="$(project_template_file "$workflow_repo" "$project_name")"
  if [[ ! -f "$config_source_file" ]]; then
    error "Workflow template not found for '$project_name': $config_source_file"
    info "Add the workflow first with: oo add $project_name"
    exit 1
  fi

  echo "[oo] Loading services..."
  echo "[oo] Applying overrides..."
  echo "[oo] Checking dependencies..."
  report_service_readiness_for_start "$workflow_repo" "$project_name"

  if [[ ${#START_MISSING_SERVICES[@]-0} -gt 0 || ${#START_TIMEOUT_SERVICES[@]-0} -gt 0 || ${#START_FAILED_SERVICES[@]-0} -gt 0 ]]; then
    echo
    local inferred_project
    inferred_project="$(infer_start_project_from_context)"
    local install_cmd="oo install --workflow $project_name"
    local doctor_cmd="oo doctor --workflow $project_name"
    if [[ "$inferred_project" == "$project_name" ]]; then
      install_cmd="oo install"
      doctor_cmd="oo doctor"
    fi

    if [[ "$strict_mode" == true ]]; then
      error_block "RUN-022" "Start blocked" "Strict mode requires a fully prepared environment, but setup is incomplete." --context "Workflow: $project_name" "Install environment: $install_cmd" "Check status: $doctor_cmd" "Retry (strict): oo start --strict"
      return 1
    fi

    if [[ ${#START_MISSING_SERVICES[@]-0} -gt 0 ]]; then
      echo "[oo] Run: $install_cmd"
    fi
    if [[ ${#START_TIMEOUT_SERVICES[@]-0} -gt 0 || ${#START_FAILED_SERVICES[@]-0} -gt 0 ]]; then
      echo "[oo] Run: $doctor_cmd"
    fi
    warn "RUN-012 Runtime may be degraded because environment setup is incomplete"
  fi

  config_override_file="$(project_override_file "$workflow_repo" "$project_name")"
  rendered_config_file="$(mktemp "${TMPDIR:-/tmp}/oo-${project_name}-XXXXXX")"

  if ! render_project_config_for_start "$config_source_file" "$config_override_file" "$rendered_config_file"; then
    rm -f "$rendered_config_file"
    error "Failed to render workflow template for '$project_name'"
    return 1
  fi

  local rendered_root
  rendered_root="$(read_rendered_config_root "$rendered_config_file")"
  if [[ -n "$rendered_root" && -d "$rendered_root" ]]; then
    ensure_local_workflow_link "$project_name" "$(project_dir "$workflow_repo" "$project_name")" "$rendered_root" true
  fi

  sanitize_tmux_env
  echo "[oo] Starting workflow..."
  set +e
  (
    cd "$workflow_repo"
    if [[ ${#start_args[@]} -gt 0 ]]; then
      tmuxinator start -p "$rendered_config_file" "${start_args[@]}"
    else
      tmuxinator start -p "$rendered_config_file"
    fi
  )
  tmuxinator_status=$?
  set -e
  rm -f "$rendered_config_file"
  if [[ "$tmuxinator_status" -ne 0 ]] && [[ "$had_session_before" == false ]] && tmux has-session -t "$project_name" 2>/dev/null; then
    if [[ ${#start_args[@]} -gt 0 ]] && start_requested_no_attach "${start_args[@]}"; then
      return 0
    fi
    warn "Workflow session '$project_name' started, but auto-attach failed"
    info "Attach manually: tmux attach-session -t $project_name"
    return 0
  fi
  if [[ "$tmuxinator_status" -eq 0 ]]; then
    echo "✔ Session started"
  fi
  return "$tmuxinator_status"
}

cmd_stop() {
  local project_name="${1:-}"

  if [[ -z "$project_name" || "$project_name" == -* ]]; then
    project_name="$(infer_start_project_from_context)"
    if [[ -z "$project_name" ]]; then
      error "Missing workflow name"
      info "Usage: oo stop <workflow-name>"
      exit 1
    fi
    info "No workflow name provided; inferred '$project_name'"
  fi

  if ! command -v tmux >/dev/null 2>&1; then
    error "tmux is not installed or not on PATH"
    exit 1
  fi

  if tmux has-session -t "$project_name" 2>/dev/null; then
    tmux kill-session -t "$project_name"
    ok "Stopped tmux session: $project_name"
  else
    info "No running tmux session found: $project_name"
  fi
}

cmd_uninstall() {
  local assume_yes=false
  local arg

  for arg in "$@"; do
    case "$arg" in
    --yes)
      assume_yes=true
      ;;
    -h | --help)
      cat <<'EOF'
Usage: oo uninstall [--yes]

Removes global oo CLI installation (symlink and install root).
This does not remove tmuxinator workflow aliases.
EOF
      return 0
      ;;
    *)
      error "Unknown option for uninstall: $arg"
      info "Usage: oo uninstall [--yes]"
      exit 1
      ;;
    esac
  done

  local bin_dir="${OO_BIN_DIR:-$DEFAULT_OO_BIN_DIR}"
  local install_root="${OO_INSTALL_ROOT:-$DEFAULT_OO_HOME}"
  local symlink_path="$bin_dir/oo"

  if [[ -L "$symlink_path" || -f "$symlink_path" ]]; then
    rm -f "$symlink_path"
    ok "Removed CLI link: $symlink_path"
  else
    info "CLI link not found: $symlink_path"
  fi

  if [[ ! -d "$install_root" ]]; then
    info "Install root not found: $install_root"
    return 0
  fi

  local can_remove_root=false
  if [[ -f "$install_root/oo" && -f "$install_root/scripts/bootstrap.sh" ]]; then
    can_remove_root=true
  fi

  if [[ "$can_remove_root" != true ]]; then
    warn "Install root does not look like a oo install: $install_root"
    warn "Skipping removal for safety"
    return 0
  fi

  local remove_root=false
  if [[ "$assume_yes" == true ]]; then
    remove_root=true
  else
    if confirm_remove "Remove install root '$install_root'?"; then
      remove_root=true
    fi
  fi

  if [[ "$remove_root" == true ]]; then
    rm -rf "$install_root"
    ok "Removed install root: $install_root"
  else
    info "Kept install root: $install_root"
  fi
}

main() {
  local command="${1:-help}"
  shift || true

  case "$command" in
  help | -h | --help)
    cmd_help "$@"
    ;;
  version | -v | --version)
    version
    ;;
  add)
    cmd_add "$@"
    ;;
  remove)
    cmd_remove "$@"
    ;;
  service)
    cmd_service "$@"
    ;;
  demo)
    cmd_demo "$@"
    ;;
  status)
    cmd_status "$@"
    ;;
  validate)
    cmd_validate "$@"
    ;;
  doctor)
    cmd_doctor "$@"
    ;;
  update)
    cmd_update "$@"
    ;;
  install)
    cmd_install "$@"
    ;;
  list)
    cmd_list "$@"
    ;;
  start)
    cmd_start "$@"
    ;;
  stop)
    cmd_stop "$@"
    ;;
  uninstall)
    cmd_uninstall "$@"
    ;;
  *)
    error "Unknown command: $command"
    local suggestion
    suggestion="$(closest_command "$command")"
    if [[ -n "$suggestion" ]]; then
      info "Did you mean: oo $suggestion"
    fi
    usage_quick
    exit 1
    ;;
  esac
}

main "$@"
